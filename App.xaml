<Application x:Class="Araci.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>

                <ResourceDictionary Source="Resources/Styles/Styles.xaml"/>
                <ResourceDictionary Source="Resources/Styles/PropertyStyles.xaml"/>
                <ResourceDictionary Source="Resources/Styles/RibbonStyles.xaml"/>
                <ResourceDictionary Source="Resources/Styles/MenuStyles.xaml"/>

                <ResourceDictionary Source="Resources/Templates/DataTemplates.xaml"/>
                <ResourceDictionary Source="Resources/Templates/TypePropertiesTemplates.xaml"/>

            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

</Application>