<UserControl x:Class="Araci.Ribbon.Tabs.DiagramaTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F4F4"
             Height="130" Loaded="UserControl_Loaded">

    <Grid Margin="8">

        <StackPanel Orientation="Horizontal">

            <Border Background="#F4F4F4"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1"
                    Padding="6"
                    Margin="0,0,0,0">

                <DockPanel>

                    <TextBlock Text="Inserir"
                               DockPanel.Dock="Bottom"
                               HorizontalAlignment="Center"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,8,0,0"/>

                    <WrapPanel>

                        <!-- BOTÃO BASE -->

                        <Button Width="80"
                                Height="70"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="CaboButton_Click">

                            <StackPanel HorizontalAlignment="Center">

                                <Image Source="pack://application:,,,/Resources/Icons/cabo.png"
                                       Width="50"
                                       Height="50"
                                       Margin="0,0,0,0"/>

                                <TextBlock Text="Cabo"
                                           Width="80"
                                           TextAlignment="Center"
                                           FontSize="11"
                                           Foreground="Black"/>

                            </StackPanel>

                        </Button>

                        <Button Width="80"
                                Height="70"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="CargaButton_Click">

                            <StackPanel HorizontalAlignment="Center">

                                <Image Source="pack://application:,,,/Resources/Icons/carga.png"
                                       Width="50"
                                       Height="50"
                                       Margin="0,0,0,0"/>

                                <TextBlock Text="Carga"
                                           Width="80"
                                           TextAlignment="Center"
                                           FontSize="11"
                                           Foreground="Black"/>

                            </StackPanel>

                        </Button>

                        <Button Width="80"
                                Height="70"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="GeradorButton_Click">

                            <StackPanel HorizontalAlignment="Center">

                                <Image Source="pack://application:,,,/Resources/Icons/fonte.png"
                                       Width="50"
                                       Height="50"
                                       Margin="0,0,0,0"/>

                                <TextBlock Text="Fonte"
                                           Width="80"
                                           TextAlignment="Center"
                                           FontSize="11"
                                           Foreground="Black"/>

                            </StackPanel>

                        </Button>

                    </WrapPanel>

                </DockPanel>

            </Border>

        </StackPanel>

    </Grid>

</UserControl>