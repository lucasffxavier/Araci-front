<UserControl x:Class="Araci.Ribbon.Tabs.EditarTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F4F4"
             Height="130">

    <Grid Margin="8">

        <StackPanel Orientation="Horizontal">

            <!-- ========================= -->
            <!-- EDIÇÃO -->
            <!-- ========================= -->

            <Border Background="#F4F4F4"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1"
                    Padding="6"
                    Margin="0,0,0,0">

                <DockPanel>

                    <TextBlock Text="Editar"
                               DockPanel.Dock="Bottom"
                               HorizontalAlignment="Center"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,8,0,0"/>

                    <WrapPanel>

                        <Button x:Name="SelecionarButton"
                                Width="80"
                                Height="70"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="SelecionarButton_Click">

                            <StackPanel HorizontalAlignment="Center">

                                <Image Source="pack://application:,,,/Resources/Icons/selecionar.png"
                                       Width="50"
                                       Height="50"/>

                                <TextBlock Text="Selecionar"
                                           Width="80"
                                           TextAlignment="Center"
                                           FontSize="11"
                                           Foreground="Black"/>

                            </StackPanel>

                        </Button>

                        <Button x:Name="MoverButton"
                                Width="80"
                                Height="70"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="MoverButton_Click">

                            <StackPanel HorizontalAlignment="Center">

                                <Image Source="pack://application:,,,/Resources/Icons/mover.png"
                                       Width="50"
                                       Height="50"/>

                                <TextBlock Text="Mover"
                                           Width="80"
                                           TextAlignment="Center"
                                           FontSize="11"
                                           Foreground="Black"/>

                            </StackPanel>

                        </Button>

                        <Button x:Name="CopiarButton"
                                Width="80"
                                Height="70"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="CopiarButton_Click">

                            <StackPanel HorizontalAlignment="Center">

                                <Image Source="pack://application:,,,/Resources/Icons/copiar.png"
                                       Width="50"
                                       Height="50"/>

                                <TextBlock Text="Copiar"
                                           Width="80"
                                           TextAlignment="Center"
                                           FontSize="11"
                                           Foreground="Black"/>

                            </StackPanel>

                        </Button>

                        <Button x:Name="ColarButton"
                                Width="80"
                                Height="70"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="ColarButton_Click">

                            <StackPanel HorizontalAlignment="Center">

                                <Image Source="pack://application:,,,/Resources/Icons/colar.png"
                                       Width="50"
                                       Height="50"/>

                                <TextBlock Text="Colar"
                                           Width="80"
                                           TextAlignment="Center"
                                           FontSize="11"
                                           Foreground="Black"/>

                            </StackPanel>

                        </Button>

                        <Button x:Name="DeletarButton"
                                Width="80"
                                Height="70"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="DeletarButton_Click">

                            <StackPanel HorizontalAlignment="Center">

                                <Image Source="pack://application:,,,/Resources/Icons/deletar.png"
                                       Width="50"
                                       Height="50"/>

                                <TextBlock Text="Deletar"
                                           Width="80"
                                           TextAlignment="Center"
                                           FontSize="11"
                                           Foreground="Black"/>

                            </StackPanel>

                        </Button>

                        <Button x:Name="RotacionarButton"
                                Width="80"
                                Height="70"
                                Background="Transparent"
                                BorderThickness="0">

                            <StackPanel HorizontalAlignment="Center">

                                <Image Source="pack://application:,,,/Resources/Icons/rotacionar.png"
                                       Width="50"
                                       Height="50"/>

                                <TextBlock Text="Rotacionar"
                                           Width="80"
                                           TextAlignment="Center"
                                           FontSize="11"
                                           Foreground="Black"/>

                            </StackPanel>

                        </Button>

                        <Button x:Name="DesfazerButton"
                                Width="80"
                                Height="70"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="DesfazerButton_Click">

                            <StackPanel HorizontalAlignment="Center">

                                <Image Source="pack://application:,,,/Resources/Icons/desfazer.png"
                                       Width="50"
                                       Height="50"/>

                                <TextBlock Text="Desfazer"
                                           Width="80"
                                           TextAlignment="Center"
                                           FontSize="11"
                                           Foreground="Black"/>

                            </StackPanel>

                        </Button>

                        <Button x:Name="RefazerButton"
                                Width="80"
                                Height="70"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="RefazerButton_Click">

                            <StackPanel HorizontalAlignment="Center">

                                <Image Source="pack://application:,,,/Resources/Icons/refazer.png"
                                       Width="50"
                                       Height="50"/>

                                <TextBlock Text="Refazer"
                                           Width="80"
                                           TextAlignment="Center"
                                           FontSize="11"
                                           Foreground="Black"/>

                            </StackPanel>

                        </Button>

                    </WrapPanel>

                </DockPanel>

            </Border>

        </StackPanel>

    </Grid>

</UserControl>