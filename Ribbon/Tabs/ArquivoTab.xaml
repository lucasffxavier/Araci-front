<UserControl x:Class="Araci.Ribbon.Tabs.ArquivoTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             Background="#F4F4F4"
             Height="130">

    <Grid Margin="8">

        <StackPanel Orientation="Horizontal">

            <Border Background="#F4F4F4"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1"
                    Padding="6">

                <DockPanel>

                    <TextBlock Text="Projeto"
                               DockPanel.Dock="Bottom"
                               HorizontalAlignment="Center"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,8,0,0"/>

                    <WrapPanel>

                        <Button Width="80" Height="70" Background="Transparent" BorderThickness="0">
                            <StackPanel HorizontalAlignment="Center">
                                <svgc:SvgViewbox Source="pack://application:,,,/Resources/Icons/novo.svg" Width="32" Height="32"/>
                                <TextBlock Text="Novo" Width="80" TextAlignment="Center" FontSize="11" Foreground="Black"/>
                            </StackPanel>
                        </Button>

                        <Button Width="80" Height="70" Background="Transparent" BorderThickness="0">
                            <StackPanel HorizontalAlignment="Center">
                                <svgc:SvgViewbox Source="pack://application:,,,/Resources/Icons/abrir.svg" Width="32" Height="32"/>
                                <TextBlock Text="Abrir" Width="80" TextAlignment="Center" FontSize="11" Foreground="Black"/>
                            </StackPanel>
                        </Button>

                        <Button Width="80" Height="70" Background="Transparent" BorderThickness="0">
                            <StackPanel HorizontalAlignment="Center">
                                <svgc:SvgViewbox Source="pack://application:,,,/Resources/Icons/salvar.svg" Width="32" Height="32"/>
                                <TextBlock Text="Salvar" Width="80" TextAlignment="Center" FontSize="11" Foreground="Black"/>
                            </StackPanel>
                        </Button>

                    </WrapPanel>

                </DockPanel>

            </Border>

        </StackPanel>

    </Grid>

</UserControl>
