<UserControl x:Class="Araci.Ribbon.Tabs.ArquivoMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="300">

    <!-- 🔥 GARANTE STYLE -->
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Araci;component/Resources/Styles/MenuStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- 🔴 CONTAINER COM BORDA REAL DE JANELA -->
    <Border Background="White"
            BorderBrush="#B8B8B8"
            BorderThickness="1"
            CornerRadius="3">

        <!-- 🔥 SOMBRA (EFEITO DE JANELA FLUTUANTE) -->
        <Border.Effect>
            <DropShadowEffect BlurRadius="12"
                              ShadowDepth="2"
                              Opacity="0.35"/>
        </Border.Effect>

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 🔵 HEADER OPCIONAL (estilo app) -->

            <!-- 🔵 CONTEÚDO -->
            <StackPanel Grid.Row="1"
                        Background="#F4F4F4">

                <!-- NOVO -->
                <Button Style="{StaticResource MenuButton}"
                        Click="Novo_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="pack://application:,,,/Araci;component/Resources/Icons/novo.png"
                               Width="40"
                               Height="40"
                               Margin="5,0,10,0"/>
                        <TextBlock Text="Novo"
                                   VerticalAlignment="Center"
                                   FontSize="13"/>
                    </StackPanel>
                </Button>

                <!-- ABRIR -->
                <Button Style="{StaticResource MenuButton}"
                        Click="Abrir_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="pack://application:,,,/Araci;component/Resources/Icons/abrir.png"
                               Width="40"
                               Height="40"
                               Margin="5,0,10,0"/>
                        <TextBlock Text="Abrir"
                                   VerticalAlignment="Center"
                                   FontSize="13"/>
                    </StackPanel>
                </Button>

                <!-- SALVAR -->
                <Button Style="{StaticResource MenuButton}"
                        Click="Salvar_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="pack://application:,,,/Araci;component/Resources/Icons/salvar.png"
                               Width="40"
                               Height="40"
                               Margin="5,0,10,0"/>
                        <TextBlock Text="Salvar"
                                   VerticalAlignment="Center"
                                   FontSize="13"/>
                    </StackPanel>
                </Button>

            </StackPanel>

        </Grid>

    </Border>

</UserControl>
