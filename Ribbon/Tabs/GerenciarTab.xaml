<UserControl x:Class="Araci.Ribbon.Tabs.GerenciarTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F4F4"
             Height="130">

    <Grid Margin="8">

        <StackPanel Orientation="Horizontal">

            <Border Background="#F4F4F4"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1"
                    Padding="6">

                <DockPanel>

                    <TextBlock Text="Sistema"
                               DockPanel.Dock="Bottom"
                               HorizontalAlignment="Center"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,8,0,0"/>

                    <WrapPanel>

                        <Button Width="80" Height="70" Background="Transparent" BorderThickness="0">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="pack://application:,,,/Resources/Icons/configuracoes.png" Width="50" Height="50"/>
                                <TextBlock Text="Config" Width="80" TextAlignment="Center" FontSize="11" Foreground="Black"/>
                            </StackPanel>
                        </Button>

                        <Button Width="80" Height="70" Background="Transparent" BorderThickness="0">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="pack://application:,,,/Resources/Icons/biblioteca.png" Width="50" Height="50"/>
                                <TextBlock Text="Biblioteca" Width="80" TextAlignment="Center" FontSize="11" Foreground="Black"/>
                            </StackPanel>
                        </Button>

                    </WrapPanel>

                </DockPanel>

            </Border>

        </StackPanel>

    </Grid>

</UserControl>