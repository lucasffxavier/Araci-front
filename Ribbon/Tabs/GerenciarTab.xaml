<UserControl x:Class="Araci.Ribbon.Tabs.GerenciarTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             Background="#F4F4F4"
             Height="100">
    <Grid Margin="3">
        <StackPanel Orientation="Horizontal">
            <Border Background="#F4F4F4"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1"
                    Padding="3"
                    Margin="0,0,4,0">
                <DockPanel>
                    <TextBlock Text="Sistema"
                               DockPanel.Dock="Bottom"
                               HorizontalAlignment="Center"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,2,0,0"/>
                    <WrapPanel>
                        <Button Style="{StaticResource RibbonToolButton}">
                            <StackPanel HorizontalAlignment="Center">
                                <svgc:SvgViewbox Source="pack://application:,,,/Resources/Icons/configuracoes.svg" Width="32" Height="32"/>
                                <TextBlock Text="Config" Width="68" TextAlignment="Center" FontSize="11" Foreground="Black" Margin="0,1,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource RibbonToolButton}">
                            <StackPanel HorizontalAlignment="Center">
                                <svgc:SvgViewbox Source="pack://application:,,,/Resources/Icons/biblioteca.svg" Width="32" Height="32"/>
                                <TextBlock Text="Biblioteca" Width="68" TextAlignment="Center" FontSize="11" Foreground="Black" Margin="0,1,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource RibbonToolButton}" Click="PropriedadesButton_Click">
                            <StackPanel HorizontalAlignment="Center">
                                <svgc:SvgViewbox Source="pack://application:,,,/Resources/Icons/propriedades.svg" Width="32" Height="32"/>
                                <TextBlock Text="Propriedades" Width="68" TextAlignment="Center" FontSize="11" Foreground="Black" Margin="0,1,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource RibbonToolButton}" Click="NavegadorButton_Click">
                            <StackPanel HorizontalAlignment="Center">
                                <svgc:SvgViewbox Source="pack://application:,,,/Resources/Icons/navegador.svg" Width="32" Height="32"/>
                                <TextBlock Text="Navegador" Width="68" TextAlignment="Center" FontSize="11" Foreground="Black" Margin="0,1,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource RibbonToolButton}" Click="UnidadesButton_Click">
                            <StackPanel HorizontalAlignment="Center">
                                <svgc:SvgViewbox Source="pack://application:,,,/Resources/Icons/unidades.svg" Width="32" Height="32"/>
                                <TextBlock Text="Unidades" Width="68" TextAlignment="Center" FontSize="11" Foreground="Black" Margin="0,1,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </DockPanel>
            </Border>
            <Border Background="#F4F4F4"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1"
                    Padding="3">
                <DockPanel>
                    <TextBlock Text="Projeto"
                               DockPanel.Dock="Bottom"
                               HorizontalAlignment="Center"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,2,0,0"/>
                    <WrapPanel>
                        <Button Style="{StaticResource RibbonToolButton}" Click="NovaVistaButton_Click">
                            <StackPanel HorizontalAlignment="Center">
                                <svgc:SvgViewbox Source="pack://application:,,,/Resources/Icons/vistas.svg" Width="32" Height="32"/>
                                <TextBlock Text="Nova Vista" Width="68" TextAlignment="Center" FontSize="11" Foreground="Black" Margin="0,1,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource RibbonToolButton}" Click="NovaTabelaButton_Click">
                            <StackPanel HorizontalAlignment="Center">
                                <svgc:SvgViewbox Source="pack://application:,,,/Resources/Icons/tabela.svg" Width="32" Height="32"/>
                                <TextBlock Text="Nova Tabela" Width="68" TextAlignment="Center" FontSize="11" Foreground="Black" Margin="0,1,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource RibbonToolButton}" Click="ExportarTabelaButton_Click">
                            <StackPanel HorizontalAlignment="Center">
                                <svgc:SvgViewbox Source="pack://application:,,,/Resources/Icons/tabela.svg" Width="32" Height="32"/>
                                <TextBlock Text="Exportar CSV" Width="68" TextAlignment="Center" FontSize="11" Foreground="Black" Margin="0,1,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource RibbonToolButton}" Click="NovaPranchaButton_Click">
                            <StackPanel HorizontalAlignment="Center">
                                <svgc:SvgViewbox Source="pack://application:,,,/Resources/Icons/prancha.svg" Width="32" Height="32"/>
                                <TextBlock Text="Nova Prancha" Width="68" TextAlignment="Center" FontSize="11" Foreground="Black" Margin="0,1,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </DockPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
