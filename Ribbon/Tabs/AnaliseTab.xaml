<UserControl x:Class="Araci.Ribbon.Tabs.AnaliseTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F4F4"
             Height="130">

    <Grid Margin="8">

        <!-- 🔑 ESSENCIAL: StackPanel horizontal -->
        <StackPanel Orientation="Horizontal">

            <Border Background="#F4F4F4"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1"
                    Padding="6">

                <DockPanel>

                    <!-- TÍTULO -->
                    <TextBlock Text="Simulação"
                               DockPanel.Dock="Bottom"
                               HorizontalAlignment="Center"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,8,0,0"/>

                    <!-- BOTÕES -->
                    <WrapPanel>

                        <Button Width="80" Height="70"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="FluxoButton_Click">

                            <StackPanel HorizontalAlignment="Center">

                                <Image Source="pack://application:,,,/Resources/Icons/fluxo.png"
                                       Width="50"
                                       Height="50"/>

                                <TextBlock Text="Fluxo"
                                           Width="80"
                                           TextAlignment="Center"
                                           FontSize="11"
                                           Foreground="Black"/>

                            </StackPanel>

                        </Button>

                    </WrapPanel>

                </DockPanel>

            </Border>

        </StackPanel>

    </Grid>

</UserControl>
