<UserControl x:Class="Araci.Views.ProjectTableGridView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<UserControl.Resources>
		<BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
		<Style x:Key="TableDataGridCellStyle" TargetType="{x:Type DataGridCell}">
			<Setter Property="BorderBrush" Value="#D0D0D0"/>
			<Setter Property="BorderThickness" Value="0,0,0,1"/>
			<Setter Property="Padding" Value="6,3"/>
		</Style>
		<Style x:Key="TableDataGridColumnHeaderStyle" TargetType="{x:Type DataGridColumnHeader}">
			<Setter Property="BorderBrush" Value="#B8B8B8"/>
			<Setter Property="BorderThickness" Value="0,0,1,1"/>
			<Setter Property="Padding" Value="6,4"/>
			<Setter Property="Background" Value="#E8E8E8"/>
			<Setter Property="Foreground" Value="#202020"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
		</Style>
	</UserControl.Resources>
	<Border Margin="10"
            BorderBrush="#252526"
            BorderThickness="1"
            Background="#F4F4F4">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="42"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<Border Grid.Row="0"
                    Background="#252526"
                    BorderBrush="#3A3A3A"
                    BorderThickness="0,0,0,1">
				<TextBlock Text="{Binding Titulo}"
                           Foreground="#F4F4F4"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="12,0"/>
			</Border>

			<Grid x:Name="TableGridHost" Grid.Row="1">
				<Border x:Name="TableTopSeparator"
                        BorderBrush="#B8B8B8"
                        BorderThickness="0,1,0,0"/>
				<DataGrid x:Name="TableDataGrid"
                          ItemsSource="{Binding Rows}"
                          HorizontalAlignment="Left"
                          MaxWidth="{Binding ActualWidth, ElementName=TableGridHost}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="False"
                          CanUserSortColumns="False"
                          IsTabStop="False"
                          KeyboardNavigation.TabNavigation="None"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Vertical"
                          ColumnWidth="SizeToCells"
                          MinColumnWidth="90"
                          Background="{Binding BodyBackgroundBrush}"
                          BorderThickness="0"
                          RowHeaderWidth="0"
                          Foreground="{Binding BodyForegroundBrush}"
                          FontFamily="{Binding BodyFontFamily}"
                          FontSize="{Binding BodyFontSize}"
                          CellStyle="{StaticResource TableDataGridCellStyle}"
                          ColumnHeaderStyle="{StaticResource TableDataGridColumnHeaderStyle}"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"/>

				<Border Background="#CCF4F4F4"
                        Visibility="{Binding HasEmptyMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
					<TextBlock Text="{Binding EmptyMessage}"
                               Foreground="#404040"
                               FontSize="14"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="16"/>
				</Border>
			</Grid>
		</Grid>
	</Border>
</UserControl>