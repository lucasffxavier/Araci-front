<UserControl x:Class="Araci.Views.ViewportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Araci.Controls"
             xmlns:viewModels="clr-namespace:Araci.ViewModels"
             xmlns:app="clr-namespace:Araci"
             Focusable="True"
             PreviewMouseLeftButtonDown="OnPreviewMouseLeftButtonDown"
             PreviewMouseMove="OnPreviewMouseMove"
             PreviewMouseLeftButtonUp="OnPreviewMouseLeftButtonUp"
             PreviewKeyDown="OnPreviewKeyDown"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <BooleanToVisibilityConverter
            x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Border x:Name="RootBorder"
            BorderThickness="1"
            BorderBrush="#252526"
            Background="#F4F4F4"
            ClipToBounds="True"
            SnapsToDevicePixels="True"
            UseLayoutRounding="True">

        <Grid ClipToBounds="True">

            <!-- ========================= -->
            <!-- ELEMENTOS -->
            <!-- ========================= -->

            <ItemsControl ItemsSource="{Binding Elementos}"
                          ClipToBounds="True"
                          SnapsToDevicePixels="True"
                          HorizontalContentAlignment="Left"
                          VerticalContentAlignment="Top">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>

                        <Canvas x:Name="ViewportCanvas"
                                Background="#F4F4F4"
                                ClipToBounds="True"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True"/>

                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">

                        <Setter Property="Canvas.Left"
                            Value="{Binding ScreenX}"/>

                        <Setter Property="Canvas.Top"
                            Value="{Binding ScreenY}"/>

                    </Style>
                </ItemsControl.ItemContainerStyle>

                <ItemsControl.Resources>

                    <DataTemplate DataType="{x:Type viewModels:CaboViewModel}">
                        <controls:CaboControl/>
                    </DataTemplate>

                    <DataTemplate DataType="{x:Type viewModels:CargaViewModel}">
                        <controls:CargaControl/>
                    </DataTemplate>

                    <DataTemplate DataType="{x:Type viewModels:GeradorViewModel}">
                        <controls:GeradorControl/>
                    </DataTemplate>

                </ItemsControl.Resources>

            </ItemsControl>

            <!-- ========================= -->
            <!-- JANELA DE SELEÇÃO -->
            <!-- ========================= -->

            <Canvas IsHitTestVisible="False">

                <Rectangle
                    Stroke="#007ACC"
                    StrokeThickness="1.5"
                    Fill="#22007ACC"
                    StrokeDashArray="3 2"

                    Canvas.Left="{Binding Source={x:Static app:AppServices.SelectionBox}, Path=X}"
                    Canvas.Top="{Binding Source={x:Static app:AppServices.SelectionBox}, Path=Y}"

                    Width="{Binding Source={x:Static app:AppServices.SelectionBox}, Path=Largura}"
                    Height="{Binding Source={x:Static app:AppServices.SelectionBox}, Path=Altura}"

                    Visibility="{Binding Source={x:Static app:AppServices.SelectionBox},
                                         Path=Visivel,
                                         Converter={StaticResource BooleanToVisibilityConverter}}"/>

            </Canvas>

            <!-- ========================= -->
            <!-- HUD -->
            <!-- ========================= -->

            <Canvas IsHitTestVisible="False"
                    ClipToBounds="True">

                <Border
                    Background="#AA1E1E1E"
                    CornerRadius="6"
                    Padding="8"

                    Canvas.Left="{Binding Source={x:Static app:AppServices.MoveHud}, Path=X}"
                    Canvas.Top="{Binding Source={x:Static app:AppServices.MoveHud}, Path=Y}"

                    Visibility="{Binding Source={x:Static app:AppServices.MoveHud},
                                         Path=Visivel,
                                         Converter={StaticResource BooleanToVisibilityConverter}}">

                    <StackPanel>

                        <TextBlock
                            Foreground="White"
                            FontSize="12"
                            Text="{Binding Source={x:Static app:AppServices.MoveHud},
                                           Path=DeltaX,
                                           StringFormat=ΔX: {0:F1}}"/>

                        <TextBlock
                            Foreground="White"
                            FontSize="12"
                            Text="{Binding Source={x:Static app:AppServices.MoveHud},
                                           Path=DeltaY,
                                           StringFormat=ΔY: {0:F1}}"/>

                    </StackPanel>

                </Border>

            </Canvas>

        </Grid>

    </Border>

</UserControl>
