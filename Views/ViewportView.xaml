<UserControl x:Class="Araci.Views.ViewportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Araci.Controls"
             xmlns:viewModels="clr-namespace:Araci.ViewModels"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             Focusable="True"
             PreviewMouseLeftButtonDown="OnPreviewMouseLeftButtonDown"
             PreviewMouseMove="OnPreviewMouseMove"
             PreviewMouseLeftButtonUp="OnPreviewMouseLeftButtonUp"
             PreviewMouseDown="OnPreviewMouseDown"
             PreviewMouseUp="OnPreviewMouseUp"
             PreviewMouseWheel="OnPreviewMouseWheel"
             PreviewKeyDown="OnPreviewKeyDown"
             PreviewKeyUp="OnPreviewKeyUp"
             MouseLeave="OnMouseLeave"
             Loaded="OnLoaded">

	<UserControl.Resources>
		<BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
	</UserControl.Resources>

	<Border x:Name="RootBorder" BorderThickness="1" BorderBrush="#252526" Background="#F4F4F4" ClipToBounds="True" SnapsToDevicePixels="True" UseLayoutRounding="True">
		<Grid ClipToBounds="True">
			<ItemsControl x:Name="WorldLayer" ItemsSource="{Binding Elementos}" ClipToBounds="False" SnapsToDevicePixels="True" HorizontalContentAlignment="Left" VerticalContentAlignment="Top">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<Canvas x:Name="ViewportCanvas" Background="#F4F4F4" ClipToBounds="False" SnapsToDevicePixels="True" UseLayoutRounding="True"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>

				<ItemsControl.ItemContainerStyle>
					<Style TargetType="ContentPresenter">
						<Setter Property="Canvas.Left" Value="{Binding WorldX}"/>
						<Setter Property="Canvas.Top" Value="{Binding WorldY}"/>
					</Style>
				</ItemsControl.ItemContainerStyle>

				<ItemsControl.Resources>
					<DataTemplate DataType="{x:Type viewModels:BarraViewModel}">
						<controls:BarraControl/>
					</DataTemplate>
					<DataTemplate DataType="{x:Type viewModels:CaboViewModel}">
						<controls:CaboControl/>
					</DataTemplate>
					<DataTemplate DataType="{x:Type viewModels:LinhaAnotativaViewModel}">
						<Line X1="{Binding RenderData.PontoLocalInicial.X}" Y1="{Binding RenderData.PontoLocalInicial.Y}" X2="{Binding RenderData.PontoLocalFinal.X}" Y2="{Binding RenderData.PontoLocalFinal.Y}" Stroke="{Binding RenderData.Stroke}" StrokeThickness="{Binding RenderData.StrokeThickness}" StrokeDashArray="{Binding RenderData.StrokeDashArray}" Visibility="{Binding Visivel, Converter={StaticResource BooleanToVisibilityConverter}}" SnapsToDevicePixels="True"/>
					</DataTemplate>
					<DataTemplate DataType="{x:Type viewModels:RetanguloAnotativoViewModel}">
						<Rectangle Width="{Binding Largura}" Height="{Binding Altura}" Stroke="{Binding StrokeBrush}" Fill="{x:Null}" StrokeThickness="{Binding EspessuraLinha}" StrokeDashArray="{Binding StrokeDashArray}" Visibility="{Binding Visivel, Converter={StaticResource BooleanToVisibilityConverter}}" SnapsToDevicePixels="True"/>
					</DataTemplate>
					<DataTemplate DataType="{x:Type viewModels:CirculoAnotativoViewModel}">
						<Ellipse Width="{Binding Largura}" Height="{Binding Altura}" Stroke="{Binding StrokeBrush}" Fill="{x:Null}" StrokeThickness="{Binding EspessuraLinha}" StrokeDashArray="{Binding StrokeDashArray}" Visibility="{Binding Visivel, Converter={StaticResource BooleanToVisibilityConverter}}" SnapsToDevicePixels="True"/>
					</DataTemplate>
					<DataTemplate DataType="{x:Type viewModels:TextoAnotativoViewModel}">
						<Grid Width="{Binding Largura}" Height="{Binding AlturaVisual}" Visibility="{Binding Visivel, Converter={StaticResource BooleanToVisibilityConverter}}" SnapsToDevicePixels="True" ClipToBounds="False" RenderTransformOrigin="0.5,0.5">
							<Grid.RenderTransform>
								<RotateTransform Angle="{Binding Rotacao}"/>
							</Grid.RenderTransform>
							<Rectangle Fill="Transparent" Stroke="#007ACC" StrokeThickness="1" SnapsToDevicePixels="True">
								<Rectangle.Style>
									<Style TargetType="Rectangle">
										<Setter Property="Visibility" Value="Collapsed"/>
										<Style.Triggers>
											<DataTrigger Binding="{Binding IsHover}" Value="True">
												<Setter Property="Visibility" Value="Visible"/>
											</DataTrigger>
											<DataTrigger Binding="{Binding IsSelecionado}" Value="True">
												<Setter Property="Visibility" Value="Visible"/>
											</DataTrigger>
											<DataTrigger Binding="{Binding IsEditingInline}" Value="True">
												<Setter Property="Visibility" Value="Visible"/>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</Rectangle.Style>
							</Rectangle>
							<TextBlock Width="{Binding Largura}" Height="{Binding Altura}" Text="{Binding Conteudo}" FontFamily="{Binding FontFamily}" FontSize="{Binding AlturaTexto}" TextAlignment="{Binding TextAlignment}" TextWrapping="Wrap" Padding="2,0,2,0" SnapsToDevicePixels="True">
								<TextBlock.Style>
									<Style TargetType="TextBlock">
										<Setter Property="Visibility" Value="Visible"/>
										<Setter Property="Foreground" Value="{Binding ForegroundBrush}"/>
										<Style.Triggers>
											<DataTrigger Binding="{Binding IsHover}" Value="True">
												<Setter Property="Foreground" Value="#007ACC"/>
											</DataTrigger>
											<DataTrigger Binding="{Binding IsSelecionado}" Value="True">
												<Setter Property="Foreground" Value="#007ACC"/>
											</DataTrigger>
											<DataTrigger Binding="{Binding IsEditingInline}" Value="True">
												<Setter Property="Visibility" Value="Collapsed"/>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</TextBlock.Style>
							</TextBlock>
							<TextBox Text="{Binding ConteudoEdicao, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="{Binding Largura}"
                                     Height="{Binding AlturaVisual}"
                                     MinHeight="{Binding Altura}"
                                     FontFamily="{Binding FontFamily}"
                                     FontSize="{Binding AlturaTexto}"
                                     Foreground="{Binding ForegroundBrush}"
                                     Background="#FFFFFFFF"
                                     BorderBrush="#007ACC"
                                     BorderThickness="1"
                                     Padding="2,0,2,0"
                                     HorizontalContentAlignment="{Binding TextBoxHorizontalContentAlignment}"
                                     VerticalContentAlignment="Top"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Disabled"
                                     HorizontalScrollBarVisibility="Disabled"
                                     PreviewKeyDown="OnInlineTextBoxPreviewKeyDown"
                                     LostKeyboardFocus="OnInlineTextBoxLostKeyboardFocus"
                                     Loaded="OnInlineTextBoxLoaded"
                                     MouseDoubleClick="OnInlineTextBoxMouseDoubleClick"
                                     SnapsToDevicePixels="True">
								<TextBox.Style>
									<Style TargetType="TextBox">
										<Setter Property="Visibility" Value="Collapsed"/>
										<Style.Triggers>
											<DataTrigger Binding="{Binding IsEditingInline}" Value="True">
												<Setter Property="Visibility" Value="Visible"/>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</TextBox.Style>
							</TextBox>

							<Line X1="0"
                                  Y1="0"
                                  X2="0"
                                  Y2="-32"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Top"
                                  Stroke="#007ACC"
                                  StrokeThickness="0.8"
                                  StrokeDashArray="2 2"
                                  IsHitTestVisible="False"
                                  SnapsToDevicePixels="True"
                                  Panel.ZIndex="29">
								<Line.Style>
									<Style TargetType="Line">
										<Setter Property="Visibility" Value="Collapsed"/>
										<Style.Triggers>
											<MultiDataTrigger>
												<MultiDataTrigger.Conditions>
													<Condition Binding="{Binding IsSelecionado}" Value="True"/>
													<Condition Binding="{Binding IsEditingInline}" Value="False"/>
												</MultiDataTrigger.Conditions>
												<Setter Property="Visibility" Value="Visible"/>
											</MultiDataTrigger>
										</Style.Triggers>
									</Style>
								</Line.Style>
							</Line>

							<primitives:Thumb Tag="Rotate"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Top"
                                              Width="{Binding DataContext.TextoHandleVisualSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              Height="{Binding DataContext.TextoHandleVisualSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              Cursor="Hand"
                                              DragStarted="OnTextoRotationHandleDragStarted"
                                              DragDelta="OnTextoRotationHandleDragDelta"
                                              DragCompleted="OnTextoRotationHandleDragCompleted"
                                              Focusable="False"
                                              SnapsToDevicePixels="True"
                                              Panel.ZIndex="30">
								<primitives:Thumb.Style>
									<Style TargetType="primitives:Thumb">
										<Setter Property="Visibility" Value="Collapsed"/>
										<Setter Property="Template">
											<Setter.Value>
												<ControlTemplate TargetType="primitives:Thumb">
													<Ellipse Fill="White" Stroke="#007ACC" StrokeThickness="{Binding DataContext.TextoHandleStrokeThickness, RelativeSource={RelativeSource AncestorType=UserControl}}" SnapsToDevicePixels="True"/>
												</ControlTemplate>
											</Setter.Value>
										</Setter>
										<Style.Triggers>
											<MultiDataTrigger>
												<MultiDataTrigger.Conditions>
													<Condition Binding="{Binding IsSelecionado}" Value="True"/>
													<Condition Binding="{Binding IsEditingInline}" Value="False"/>
												</MultiDataTrigger.Conditions>
												<Setter Property="Visibility" Value="Visible"/>
											</MultiDataTrigger>
										</Style.Triggers>
									</Style>
								</primitives:Thumb.Style>
								<primitives:Thumb.RenderTransform>
									<TranslateTransform Y="-32"/>
								</primitives:Thumb.RenderTransform>
							</primitives:Thumb>

							<primitives:Thumb Tag="Left"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Width="{Binding DataContext.TextoHandleVisualSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              Height="{Binding DataContext.TextoHandleVisualSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              Cursor="SizeWE"
                                              DragStarted="OnTextoWidthHandleDragStarted"
                                              DragDelta="OnTextoWidthHandleDragDelta"
                                              DragCompleted="OnTextoWidthHandleDragCompleted"
                                              Focusable="False"
                                              SnapsToDevicePixels="True"
                                              Panel.ZIndex="20">
								<primitives:Thumb.Style>
									<Style TargetType="primitives:Thumb">
										<Setter Property="Visibility" Value="Collapsed"/>
										<Setter Property="Template">
											<Setter.Value>
												<ControlTemplate TargetType="primitives:Thumb">
													<Rectangle Fill="White" Stroke="#007ACC" StrokeThickness="{Binding DataContext.TextoHandleStrokeThickness, RelativeSource={RelativeSource AncestorType=UserControl}}" SnapsToDevicePixels="True"/>
												</ControlTemplate>
											</Setter.Value>
										</Setter>
										<Style.Triggers>
											<MultiDataTrigger>
												<MultiDataTrigger.Conditions>
													<Condition Binding="{Binding IsSelecionado}" Value="True"/>
													<Condition Binding="{Binding IsEditingInline}" Value="False"/>
												</MultiDataTrigger.Conditions>
												<Setter Property="Visibility" Value="Visible"/>
											</MultiDataTrigger>
										</Style.Triggers>
									</Style>
								</primitives:Thumb.Style>
								<primitives:Thumb.RenderTransform>
									<TranslateTransform X="{Binding DataContext.TextoHandleVisualNegativeHalfOffset, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
								</primitives:Thumb.RenderTransform>
							</primitives:Thumb>

							<primitives:Thumb Tag="Right"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center"
                                              Width="{Binding DataContext.TextoHandleVisualSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              Height="{Binding DataContext.TextoHandleVisualSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              Cursor="SizeWE"
                                              DragStarted="OnTextoWidthHandleDragStarted"
                                              DragDelta="OnTextoWidthHandleDragDelta"
                                              DragCompleted="OnTextoWidthHandleDragCompleted"
                                              Focusable="False"
                                              SnapsToDevicePixels="True"
                                              Panel.ZIndex="20">
								<primitives:Thumb.Style>
									<Style TargetType="primitives:Thumb">
										<Setter Property="Visibility" Value="Collapsed"/>
										<Setter Property="Template">
											<Setter.Value>
												<ControlTemplate TargetType="primitives:Thumb">
													<Rectangle Fill="White" Stroke="#007ACC" StrokeThickness="{Binding DataContext.TextoHandleStrokeThickness, RelativeSource={RelativeSource AncestorType=UserControl}}" SnapsToDevicePixels="True"/>
												</ControlTemplate>
											</Setter.Value>
										</Setter>
										<Style.Triggers>
											<MultiDataTrigger>
												<MultiDataTrigger.Conditions>
													<Condition Binding="{Binding IsSelecionado}" Value="True"/>
													<Condition Binding="{Binding IsEditingInline}" Value="False"/>
												</MultiDataTrigger.Conditions>
												<Setter Property="Visibility" Value="Visible"/>
											</MultiDataTrigger>
										</Style.Triggers>
									</Style>
								</primitives:Thumb.Style>
								<primitives:Thumb.RenderTransform>
									<TranslateTransform X="{Binding DataContext.TextoHandleVisualHalfOffset, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
								</primitives:Thumb.RenderTransform>
							</primitives:Thumb>
						</Grid>
					</DataTemplate>
					<DataTemplate DataType="{x:Type viewModels:CargaViewModel}">
						<controls:CargaControl/>
					</DataTemplate>
					<DataTemplate DataType="{x:Type viewModels:GeradorViewModel}">
						<controls:GeradorControl/>
					</DataTemplate>
					<DataTemplate DataType="{x:Type viewModels:SinViewModel}">
						<controls:SinControl/>
					</DataTemplate>
					<DataTemplate DataType="{x:Type viewModels:TransformadorViewModel}">
						<controls:TransformadorControl/>
					</DataTemplate>
				</ItemsControl.Resources>
			</ItemsControl>

			<ItemsControl x:Name="LeaderLayer" ItemsSource="{Binding Elementos}" ClipToBounds="False" HorizontalContentAlignment="Left" VerticalContentAlignment="Top">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<Canvas ClipToBounds="False" SnapsToDevicePixels="True" UseLayoutRounding="True"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemContainerStyle>
					<Style TargetType="ContentPresenter">
						<Setter Property="Canvas.Left" Value="0"/>
						<Setter Property="Canvas.Top" Value="0"/>
					</Style>
				</ItemsControl.ItemContainerStyle>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Canvas ClipToBounds="False" Visibility="{Binding LeaderVisivel, Converter={StaticResource BooleanToVisibilityConverter}}">
							<Line X1="{Binding LeaderInicioWorld.X}"
                                  Y1="{Binding LeaderInicioWorld.Y}"
                                  X2="{Binding LeaderPoint.X}"
                                  Y2="{Binding LeaderPoint.Y}"
                                  Stroke="{Binding LeaderBrush}"
                                  StrokeThickness="{Binding LeaderEspessura}"
                                  IsHitTestVisible="False"
                                  SnapsToDevicePixels="True"
                                  Visibility="{Binding LeaderRetoVisivel, Converter={StaticResource BooleanToVisibilityConverter}}"/>
							<Polyline Points="{Binding LeaderPolylineWorldPoints}"
                                      Stroke="{Binding LeaderBrush}"
                                      StrokeThickness="{Binding LeaderEspessura}"
                                      Fill="{x:Null}"
                                      StrokeStartLineCap="Square"
                                      StrokeEndLineCap="Square"
                                      StrokeLineJoin="Miter"
                                      IsHitTestVisible="False"
                                      SnapsToDevicePixels="True"
                                      Visibility="{Binding LeaderCotoveloVisivel, Converter={StaticResource BooleanToVisibilityConverter}}"/>
							<Polygon Points="{Binding LeaderArrowWorldPoints}"
                                     Fill="{Binding LeaderBrush}"
                                     Stroke="{Binding LeaderBrush}"
                                     StrokeThickness="{Binding LeaderEspessura}"
                                     IsHitTestVisible="False"
                                     SnapsToDevicePixels="True">
								<Polygon.Style>
									<Style TargetType="Polygon">
										<Setter Property="Visibility" Value="Collapsed"/>
										<Style.Triggers>
											<DataTrigger Binding="{Binding LeaderArrowFillVisivel}" Value="True">
												<Setter Property="Visibility" Value="Visible"/>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</Polygon.Style>
							</Polygon>
							<Polyline Points="{Binding LeaderOpenArrowWorldPoints}"
                                      Stroke="{Binding LeaderBrush}"
                                      StrokeThickness="{Binding LeaderEspessura}"
                                      Fill="{x:Null}"
                                      StrokeStartLineCap="Square"
                                      StrokeEndLineCap="Square"
                                      StrokeLineJoin="Miter"
                                      IsHitTestVisible="False"
                                      SnapsToDevicePixels="True">
								<Polyline.Style>
									<Style TargetType="Polyline">
										<Setter Property="Visibility" Value="Collapsed"/>
										<Style.Triggers>
											<DataTrigger Binding="{Binding LeaderArrowOpenVisivel}" Value="True">
												<Setter Property="Visibility" Value="Visible"/>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</Polyline.Style>
							</Polyline>
							<primitives:Thumb Canvas.Left="{Binding LeaderCotoveloPoint.X}"
                                              Canvas.Top="{Binding LeaderCotoveloPoint.Y}"
                                              Width="{Binding DataContext.TextoHandleVisualSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              Height="{Binding DataContext.TextoHandleVisualSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              Cursor="Hand"
                                              DragStarted="OnTextoLeaderCotoveloHandleDragStarted"
                                              DragDelta="OnTextoLeaderCotoveloHandleDragDelta"
                                              DragCompleted="OnTextoLeaderCotoveloHandleDragCompleted"
                                              Focusable="False"
                                              SnapsToDevicePixels="True">
								<primitives:Thumb.Style>
									<Style TargetType="primitives:Thumb">
										<Setter Property="Visibility" Value="Collapsed"/>
										<Setter Property="Template">
											<Setter.Value>
												<ControlTemplate TargetType="primitives:Thumb">
													<Rectangle Fill="White" Stroke="#007ACC" StrokeThickness="{Binding DataContext.TextoHandleStrokeThickness, RelativeSource={RelativeSource AncestorType=UserControl}}" SnapsToDevicePixels="True"/>
												</ControlTemplate>
											</Setter.Value>
										</Setter>
										<Style.Triggers>
											<MultiDataTrigger>
												<MultiDataTrigger.Conditions>
													<Condition Binding="{Binding IsSelecionado}" Value="True"/>
													<Condition Binding="{Binding LeaderVisivel}" Value="True"/>
													<Condition Binding="{Binding LeaderComCotovelo}" Value="True"/>
												</MultiDataTrigger.Conditions>
												<Setter Property="Visibility" Value="Visible"/>
											</MultiDataTrigger>
										</Style.Triggers>
									</Style>
								</primitives:Thumb.Style>
								<primitives:Thumb.RenderTransform>
									<TranslateTransform X="{Binding DataContext.TextoHandleVisualNegativeHalfOffset, RelativeSource={RelativeSource AncestorType=UserControl}}" Y="{Binding DataContext.TextoHandleVisualNegativeHalfOffset, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
								</primitives:Thumb.RenderTransform>
							</primitives:Thumb>
							<primitives:Thumb Canvas.Left="{Binding LeaderPoint.X}"
                                              Canvas.Top="{Binding LeaderPoint.Y}"
                                              Width="{Binding DataContext.TextoHandleVisualSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              Height="{Binding DataContext.TextoHandleVisualSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              Cursor="Hand"
                                              DragStarted="OnTextoLeaderHandleDragStarted"
                                              DragDelta="OnTextoLeaderHandleDragDelta"
                                              DragCompleted="OnTextoLeaderHandleDragCompleted"
                                              Focusable="False"
                                              SnapsToDevicePixels="True">
								<primitives:Thumb.Style>
									<Style TargetType="primitives:Thumb">
										<Setter Property="Visibility" Value="Collapsed"/>
										<Setter Property="Template">
											<Setter.Value>
												<ControlTemplate TargetType="primitives:Thumb">
													<Ellipse Fill="White" Stroke="#007ACC" StrokeThickness="{Binding DataContext.TextoHandleStrokeThickness, RelativeSource={RelativeSource AncestorType=UserControl}}" SnapsToDevicePixels="True"/>
												</ControlTemplate>
											</Setter.Value>
										</Setter>
										<Style.Triggers>
											<MultiDataTrigger>
												<MultiDataTrigger.Conditions>
													<Condition Binding="{Binding IsSelecionado}" Value="True"/>
													<Condition Binding="{Binding LeaderVisivel}" Value="True"/>
												</MultiDataTrigger.Conditions>
												<Setter Property="Visibility" Value="Visible"/>
											</MultiDataTrigger>
										</Style.Triggers>
									</Style>
								</primitives:Thumb.Style>
								<primitives:Thumb.RenderTransform>
									<TranslateTransform X="{Binding DataContext.TextoHandleVisualNegativeHalfOffset, RelativeSource={RelativeSource AncestorType=UserControl}}" Y="{Binding DataContext.TextoHandleVisualNegativeHalfOffset, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
								</primitives:Thumb.RenderTransform>
							</primitives:Thumb>
						</Canvas>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<ItemsControl x:Name="AlignmentGuideLayer" ItemsSource="{Binding AlignmentGuides}" IsHitTestVisible="False" ClipToBounds="False">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<Canvas ClipToBounds="False"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Line X1="{Binding X1}" Y1="{Binding Y1}" X2="{Binding X2}" Y2="{Binding Y2}" Stroke="#CC007ACC" StrokeThickness="1" StrokeDashArray="6 4" SnapsToDevicePixels="True"/>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<Canvas x:Name="SelectionLayer" IsHitTestVisible="False">
				<Rectangle Stroke="#007ACC" StrokeThickness="1.5" Fill="#22007ACC" StrokeDashArray="3 2" Canvas.Left="{Binding SelectionBox.X}" Canvas.Top="{Binding SelectionBox.Y}" Width="{Binding SelectionBox.Largura}" Height="{Binding SelectionBox.Altura}" Visibility="{Binding SelectionBox.Visivel, Converter={StaticResource BooleanToVisibilityConverter}}"/>
			</Canvas>

			<Canvas x:Name="CableVertexHandleLayer" IsHitTestVisible="False"/>
			<ItemsControl x:Name="CirculoResizeHandleLayer" ItemsSource="{Binding CirculoResize.Handles}" IsHitTestVisible="False" ClipToBounds="False">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<Canvas ClipToBounds="False"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemContainerStyle>
					<Style TargetType="ContentPresenter">
						<Setter Property="Canvas.Left" Value="{Binding X}"/>
						<Setter Property="Canvas.Top" Value="{Binding Y}"/>
					</Style>
				</ItemsControl.ItemContainerStyle>
				<ItemsControl.ItemTemplate>
					<DataTemplate DataType="{x:Type viewModels:CirculoResizeHandleViewModel}">
						<Ellipse Width="9" Height="9" Fill="White" Stroke="#007ACC" StrokeThickness="1.5" RenderTransformOrigin="0.5,0.5" SnapsToDevicePixels="True">
							<Ellipse.RenderTransform>
								<TranslateTransform X="-4.5" Y="-4.5"/>
							</Ellipse.RenderTransform>
						</Ellipse>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
			<ItemsControl x:Name="RetanguloResizeHandleLayer" ItemsSource="{Binding RetanguloResize.Handles}" IsHitTestVisible="False" ClipToBounds="False">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<Canvas ClipToBounds="False"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemContainerStyle>
					<Style TargetType="ContentPresenter">
						<Setter Property="Canvas.Left" Value="{Binding X}"/>
						<Setter Property="Canvas.Top" Value="{Binding Y}"/>
					</Style>
				</ItemsControl.ItemContainerStyle>
				<ItemsControl.ItemTemplate>
					<DataTemplate DataType="{x:Type viewModels:RetanguloResizeHandleViewModel}">
						<Rectangle Width="9" Height="9" Fill="White" Stroke="#007ACC" StrokeThickness="1.5" RenderTransformOrigin="0.5,0.5" SnapsToDevicePixels="True">
							<Rectangle.RenderTransform>
								<TranslateTransform X="-4.5" Y="-4.5"/>
							</Rectangle.RenderTransform>
						</Rectangle>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
			<ItemsControl x:Name="LinhaEndpointInsertionSnapLayer" ItemsSource="{Binding LinhaEndpointEdit.InsertionSnapHandles}" IsHitTestVisible="False" ClipToBounds="False">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<Canvas ClipToBounds="False"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemContainerStyle>
					<Style TargetType="ContentPresenter">
						<Setter Property="Canvas.Left" Value="{Binding X}"/>
						<Setter Property="Canvas.Top" Value="{Binding Y}"/>
					</Style>
				</ItemsControl.ItemContainerStyle>
				<ItemsControl.ItemTemplate>
					<DataTemplate DataType="{x:Type viewModels:LinhaEndpointSnapViewModel}">
						<Ellipse Width="7" Height="7" Fill="#FFFFFFFF" Stroke="#AA007ACC" StrokeThickness="1.25" RenderTransformOrigin="0.5,0.5" SnapsToDevicePixels="True">
							<Ellipse.RenderTransform>
								<TranslateTransform X="-3.5" Y="-3.5"/>
							</Ellipse.RenderTransform>
						</Ellipse>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
			<ItemsControl x:Name="LinhaEndpointHandleLayer" ItemsSource="{Binding LinhaEndpointEdit.Handles}" IsHitTestVisible="False" ClipToBounds="False">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<Canvas ClipToBounds="False"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemContainerStyle>
					<Style TargetType="ContentPresenter">
						<Setter Property="Canvas.Left" Value="{Binding X}"/>
						<Setter Property="Canvas.Top" Value="{Binding Y}"/>
					</Style>
				</ItemsControl.ItemContainerStyle>
				<ItemsControl.ItemTemplate>
					<DataTemplate DataType="{x:Type viewModels:LinhaEndpointHandleViewModel}">
						<Ellipse Width="9" Height="9" Fill="White" Stroke="#007ACC" StrokeThickness="1.5" RenderTransformOrigin="0.5,0.5" SnapsToDevicePixels="True">
							<Ellipse.RenderTransform>
								<TranslateTransform X="-4.5" Y="-4.5"/>
							</Ellipse.RenderTransform>
						</Ellipse>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
			<Canvas x:Name="TerminalSnapLayer" IsHitTestVisible="False" ClipToBounds="False">
				<Ellipse Canvas.Left="{Binding TerminalSnap.X}"
                         Canvas.Top="{Binding TerminalSnap.Y}"
                         Width="{Binding TerminalMarkerVisualSize}"
                         Height="{Binding TerminalMarkerVisualSize}"
                         Fill="#FFFFFFFF"
                         Stroke="#007ACC"
                         StrokeThickness="{Binding TerminalMarkerStrokeThickness}"
                         Visibility="{Binding TerminalSnap.MarcadorValidoVisivel, Converter={StaticResource BooleanToVisibilityConverter}}"
                         RenderTransformOrigin="0.5,0.5"
                         SnapsToDevicePixels="True">
					<Ellipse.RenderTransform>
						<TranslateTransform X="{Binding TerminalMarkerVisualOffset}" Y="{Binding TerminalMarkerVisualOffset}"/>
					</Ellipse.RenderTransform>
				</Ellipse>
				<Ellipse Canvas.Left="{Binding TerminalSnap.X}"
                         Canvas.Top="{Binding TerminalSnap.Y}"
                         Width="{Binding TerminalMarkerVisualSize}"
                         Height="{Binding TerminalMarkerVisualSize}"
                         Fill="#FFFFE5E5"
                         Stroke="#D13438"
                         StrokeThickness="{Binding TerminalMarkerStrokeThickness}"
                         Visibility="{Binding TerminalSnap.MarcadorInvalidoVisivel, Converter={StaticResource BooleanToVisibilityConverter}}"
                         RenderTransformOrigin="0.5,0.5"
                         SnapsToDevicePixels="True">
					<Ellipse.RenderTransform>
						<TranslateTransform X="{Binding TerminalMarkerVisualOffset}" Y="{Binding TerminalMarkerVisualOffset}"/>
					</Ellipse.RenderTransform>
				</Ellipse>
				<Border Canvas.Left="{Binding TerminalSnap.MensagemX}"
                        Canvas.Top="{Binding TerminalSnap.MensagemY}"
                        Background="#CC1E1E1E"
                        BorderBrush="#D13438"
                        BorderThickness="{Binding TerminalMarkerStrokeThickness}"
                        CornerRadius="{Binding TerminalMessageCornerRadius}"
                        Padding="{Binding TerminalMessagePadding}"
                        Visibility="{Binding TerminalSnap.MensagemVisivel, Converter={StaticResource BooleanToVisibilityConverter}}">
					<Border.RenderTransform>
						<TranslateTransform X="{Binding TerminalMessageVisualOffsetX}" Y="{Binding TerminalMessageVisualOffsetY}"/>
					</Border.RenderTransform>
					<TextBlock Text="{Binding TerminalSnap.Mensagem}"
                               Foreground="#FFFFFFFF"
                               FontSize="{Binding TerminalMessageFontSize}"
                               FontWeight="SemiBold"
                               TextWrapping="NoWrap"/>
				</Border>
			</Canvas>
			<Canvas IsHitTestVisible="False" ClipToBounds="True">
				<Border Background="#AA1E1E1E" CornerRadius="6" Padding="8" Canvas.Left="{Binding MoveHud.X}" Canvas.Top="{Binding MoveHud.Y}" Visibility="{Binding MoveHud.Visivel, Converter={StaticResource BooleanToVisibilityConverter}}">
					<StackPanel>
						<TextBlock Foreground="White" FontSize="12" Text="{Binding MoveHud.DeltaX, StringFormat=ΔX: {0:F1}}"/>
						<TextBlock Foreground="White" FontSize="12" Text="{Binding MoveHud.DeltaY, StringFormat=ΔY: {0:F1}}"/>
					</StackPanel>
				</Border>
			</Canvas>
		</Grid>
	</Border>
</UserControl>