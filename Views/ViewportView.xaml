<UserControl x:Class="Araci.Views.ViewportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Araci.Controls"
             xmlns:viewModels="clr-namespace:Araci.ViewModels"
             xmlns:services="clr-namespace:Araci.Services"
             Focusable="True">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Border Margin="8"
            BorderThickness="1"
            BorderBrush="#252526"
            Background="#F4F4F4"
            ClipToBounds="True">

        <Grid ClipToBounds="True">

            <!-- ELEMENTOS -->
            <ItemsControl ItemsSource="{Binding Elementos}">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas Background="#F4F4F4"
                                ClipToBounds="True"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>

                <ItemsControl.Resources>

                    <DataTemplate DataType="{x:Type viewModels:CaboViewModel}">
                        <controls:CaboControl/>
                    </DataTemplate>

                    <DataTemplate DataType="{x:Type viewModels:CargaViewModel}">
                        <controls:CargaControl/>
                    </DataTemplate>

                    <DataTemplate DataType="{x:Type viewModels:GeradorViewModel}">
                        <controls:GeradorControl/>
                    </DataTemplate>

                </ItemsControl.Resources>

            </ItemsControl>

            <Canvas IsHitTestVisible="False">

                <Border Background="#AA1E1E1E"
            CornerRadius="6"
            Padding="8"

            Canvas.Left="{Binding Source={x:Static services:AppServices.MoveHud}, Path=X}"
            Canvas.Top="{Binding Source={x:Static services:AppServices.MoveHud}, Path=Y}"

            Visibility="{Binding Source={x:Static services:AppServices.MoveHud},
                                 Path=Visivel,
                                 Converter={StaticResource BooleanToVisibilityConverter}}">

                    <StackPanel>

                        <TextBlock Foreground="White"
                       FontSize="12"
                       Text="{Binding Source={x:Static services:AppServices.MoveHud},
                                      Path=DeltaX,
                                      StringFormat=ΔX: {0:F1}}"/>

                        <TextBlock Foreground="White"
                       FontSize="12"
                       Text="{Binding Source={x:Static services:AppServices.MoveHud},
                                      Path=DeltaY,
                                      StringFormat=ΔY: {0:F1}}"/>

                    </StackPanel>

                </Border>

            </Canvas>

        </Grid>

    </Border>
</UserControl>