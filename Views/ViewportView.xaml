<UserControl x:Class="Araci.Views.ViewportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Araci.Controls"
             xmlns:viewModels="clr-namespace:Araci.ViewModels"
             Focusable="True"
             PreviewMouseDown="OnPreviewMouseDown"
             PreviewMouseLeftButtonDown="OnPreviewMouseLeftButtonDown"
             PreviewMouseMove="OnPreviewMouseMove"
             PreviewMouseUp="OnPreviewMouseUp"
             PreviewMouseLeftButtonUp="OnPreviewMouseLeftButtonUp"
             PreviewMouseWheel="OnPreviewMouseWheel"
             PreviewKeyDown="OnPreviewKeyDown"
             PreviewKeyUp="OnPreviewKeyUp"
             MouseLeave="OnMouseLeave"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <BooleanToVisibilityConverter
            x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Border x:Name="RootBorder"
            BorderThickness="1"
            BorderBrush="#252526"
            Background="#F4F4F4"
            ClipToBounds="True"
            SnapsToDevicePixels="True"
            UseLayoutRounding="True">

        <Grid ClipToBounds="True">

            <!-- ========================= -->
            <!-- ELEMENTOS -->
            <!-- ========================= -->

            <ItemsControl x:Name="WorldLayer"
                          ItemsSource="{Binding Elementos}"
                          ClipToBounds="False"
                          SnapsToDevicePixels="True"
                          HorizontalContentAlignment="Left"
                          VerticalContentAlignment="Top">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>

                        <Canvas x:Name="ViewportCanvas"
                                Background="#F4F4F4"
                                ClipToBounds="False"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True"/>

                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">

                        <Setter Property="Canvas.Left"
                            Value="{Binding WorldX}"/>

                        <Setter Property="Canvas.Top"
                            Value="{Binding WorldY}"/>

                    </Style>
                </ItemsControl.ItemContainerStyle>

                <ItemsControl.Resources>

                    <DataTemplate DataType="{x:Type viewModels:CaboViewModel}">
                        <controls:CaboControl/>
                    </DataTemplate>

                    <DataTemplate DataType="{x:Type viewModels:CargaViewModel}">
                        <controls:CargaControl/>
                    </DataTemplate>

                    <DataTemplate DataType="{x:Type viewModels:GeradorViewModel}">
                        <controls:GeradorControl/>
                    </DataTemplate>

                    <DataTemplate DataType="{x:Type viewModels:BarraViewModel}">
                        <controls:BarraControl/>
                    </DataTemplate>

                </ItemsControl.Resources>

            </ItemsControl>

            <!-- ========================= -->
            <!-- JANELA DE SELECAO -->
            <!-- ========================= -->

            <Canvas x:Name="SelectionLayer"
                    IsHitTestVisible="False">

                <Rectangle
                    Stroke="#007ACC"
                    StrokeThickness="1.5"
                    Fill="#22007ACC"
                    StrokeDashArray="3 2"

                    Canvas.Left="{Binding SelectionBox.X}"
                    Canvas.Top="{Binding SelectionBox.Y}"

                    Width="{Binding SelectionBox.Largura}"
                    Height="{Binding SelectionBox.Altura}"

                    Visibility="{Binding SelectionBox.Visivel,
                                         Converter={StaticResource BooleanToVisibilityConverter}}"/>

            </Canvas>

            <!-- ========================= -->
            <!-- TERMINAL SNAP -->
            <!-- ========================= -->

            <Canvas x:Name="TerminalSnapLayer"
                    IsHitTestVisible="False">

                <Ellipse
                    Width="14"
                    Height="14"
                    Stroke="#007ACC"
                    StrokeThickness="2"
                    Fill="#33007ACC"

                    Canvas.Left="{Binding TerminalSnap.X}"
                    Canvas.Top="{Binding TerminalSnap.Y}"

                    Visibility="{Binding TerminalSnap.MarcadorValidoVisivel,
                                         Converter={StaticResource BooleanToVisibilityConverter}}">

                    <Ellipse.RenderTransform>
                        <TranslateTransform X="-7" Y="-7"/>
                    </Ellipse.RenderTransform>

                </Ellipse>

                <Ellipse
                    Width="14"
                    Height="14"
                    Stroke="#D93025"
                    StrokeThickness="2"
                    Fill="#33D93025"

                    Canvas.Left="{Binding TerminalSnap.X}"
                    Canvas.Top="{Binding TerminalSnap.Y}"

                    Visibility="{Binding TerminalSnap.MarcadorInvalidoVisivel,
                                         Converter={StaticResource BooleanToVisibilityConverter}}">

                    <Ellipse.RenderTransform>
                        <TranslateTransform X="-7" Y="-7"/>
                    </Ellipse.RenderTransform>

                </Ellipse>

            </Canvas>

            <Canvas IsHitTestVisible="False"
                    ClipToBounds="True">

                <Border
                    Background="#DD2A1E1E"
                    BorderBrush="#D93025"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="6,3"

                    Canvas.Left="{Binding TerminalSnap.MensagemX}"
                    Canvas.Top="{Binding TerminalSnap.MensagemY}"

                    Visibility="{Binding TerminalSnap.MensagemVisivel,
                                         Converter={StaticResource BooleanToVisibilityConverter}}">

                    <TextBlock
                        Foreground="White"
                        FontSize="12"
                        Text="{Binding TerminalSnap.Mensagem}"/>

                </Border>

            </Canvas>

            <!-- ========================= -->
            <!-- HUD -->
            <!-- ========================= -->

            <Canvas IsHitTestVisible="False"
                    ClipToBounds="True">

                <Border
                    Background="#AA1E1E1E"
                    CornerRadius="6"
                    Padding="8"

                    Canvas.Left="{Binding MoveHud.X}"
                    Canvas.Top="{Binding MoveHud.Y}"

                    Visibility="{Binding MoveHud.Visivel,
                                         Converter={StaticResource BooleanToVisibilityConverter}}">

                    <StackPanel>

                        <TextBlock
                            Foreground="White"
                            FontSize="12"
                            Text="{Binding MoveHud.DeltaX,
                                           StringFormat=ΔX: {0:F1}}"/>

                        <TextBlock
                            Foreground="White"
                            FontSize="12"
                            Text="{Binding MoveHud.DeltaY,
                                           StringFormat=ΔY: {0:F1}}"/>

                    </StackPanel>

                </Border>

            </Canvas>

        </Grid>

    </Border>

</UserControl>
