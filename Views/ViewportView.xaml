<UserControl x:Class="Araci.Views.ViewportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Araci.Controls"
             xmlns:viewModels="clr-namespace:Araci.ViewModels"
             Focusable="True">

    <Border Margin="8"
            BorderThickness="1"
            BorderBrush="#252526"
            Background="#F4F4F4"
            ClipToBounds="True">

        <Grid ClipToBounds="True">

            <ItemsControl ItemsSource="{Binding Elementos}"
                          ClipToBounds="True">

                <!-- ================================================= -->
                <!-- CANVAS -->
                <!-- ================================================= -->

                <ItemsControl.ItemsPanel>

                    <ItemsPanelTemplate>

                        <Canvas x:Name="ViewportCanvas"
                                Background="#F4F4F4"
                                ClipToBounds="True"/>

                    </ItemsPanelTemplate>

                </ItemsControl.ItemsPanel>

                <!-- ================================================= -->
                <!-- POSIÇÃO -->
                <!-- ================================================= -->

                <ItemsControl.ItemContainerStyle>

                    <Style TargetType="ContentPresenter">

                        <Setter Property="Canvas.Left"
                                Value="{Binding X}"/>

                        <Setter Property="Canvas.Top"
                                Value="{Binding Y}"/>

                    </Style>

                </ItemsControl.ItemContainerStyle>

                <!-- ================================================= -->
                <!-- TEMPLATES -->
                <!-- ================================================= -->

                <ItemsControl.Resources>

                    <!-- CABO -->

                    <DataTemplate
                        DataType="{x:Type viewModels:CaboViewModel}">

                        <controls:CaboControl
                            DataContext="{Binding}"/>

                    </DataTemplate>

                    <!-- CARGA -->

                    <DataTemplate
                        DataType="{x:Type viewModels:CargaViewModel}">

                        <controls:CargaControl
                            DataContext="{Binding}"/>

                    </DataTemplate>

                    <!-- GERADOR -->

                    <DataTemplate
                        DataType="{x:Type viewModels:GeradorViewModel}">

                        <controls:GeradorControl
                            DataContext="{Binding}"/>

                    </DataTemplate>

                </ItemsControl.Resources>

            </ItemsControl>

        </Grid>

    </Border>

</UserControl>