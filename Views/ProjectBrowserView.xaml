<UserControl x:Class="Araci.Views.ProjectBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Margin="8"
            Background="#252526"
            BorderBrush="#F4F4F4"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0"
                    Background="#1E1E1E"
                    BorderBrush="#3A3A3A"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock Text="Gerenciador de Projeto"
                               Foreground="#F4F4F4"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="12,0,42,0"/>
                    <Button Content="×"
                            Width="28"
                            Height="28"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,6,0"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="#F4F4F4"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Click="OnCloseClick"/>
                </Grid>
            </Border>
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Secoes}"
                              Margin="10,10,10,6">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Expander IsExpanded="True"
                                      Margin="0,0,0,8"
                                      Foreground="#F4F4F4"
                                      Background="Transparent">
                                <Expander.Header>
                                    <TextBlock Text="{Binding Titulo}"
                                               Foreground="#F4F4F4"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </Expander.Header>
                                <ItemsControl ItemsSource="{Binding Itens}"
                                              Margin="24,6,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       Foreground="#DCDCDC"
                                                       Margin="0,0,0,6"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
