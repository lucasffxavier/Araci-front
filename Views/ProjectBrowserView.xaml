<UserControl x:Class="Araci.Views.ProjectBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True"
             PreviewKeyDown="OnProjectBrowserPreviewKeyDown">
    <Border Margin="8"
            Background="#252526"
            BorderBrush="#F4F4F4"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0"
                    Background="#1E1E1E"
                    BorderBrush="#3A3A3A"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock Text="Gerenciador de Projeto"
                               Foreground="#F4F4F4"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="12,0,42,0"/>
                    <Button Content="×"
                            Width="28"
                            Height="28"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,6,0"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="#F4F4F4"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Click="OnCloseClick"/>
                </Grid>
            </Border>
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Secoes}"
                              Margin="10,10,10,6">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Expander IsExpanded="True"
                                      Margin="0,0,0,8"
                                      Foreground="#F4F4F4"
                                      Background="Transparent">
                                <Expander.Header>
                                    <TextBlock Text="{Binding Titulo}"
                                               Foreground="#F4F4F4"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </Expander.Header>
                                <ItemsControl ItemsSource="{Binding Itens}"
                                              Margin="24,6,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding SelecionarCommand}"
                                                    IsEnabled="{Binding IsSelectable}"
                                                    HorizontalContentAlignment="Stretch"
                                                    Margin="0,0,0,4"
                                                    Padding="6,3"
                                                    MouseDoubleClick="OnItemMouseDoubleClick">
                                                <Button.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="Duplicar"
                                                                  Command="{Binding PlacementTarget.DataContext.DuplicarCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="Excluir"
                                                                  Command="{Binding PlacementTarget.DataContext.ExcluirCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                    </ContextMenu>
                                                </Button.ContextMenu>
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                        <Setter Property="Foreground" Value="#DCDCDC"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Background" Value="#3A4F6B"/>
                                                                <Setter Property="BorderBrush" Value="#5B7FA8"/>
                                                                <Setter Property="Foreground" Value="#F4F4F4"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsSelectable}" Value="False">
                                                                <Setter Property="Foreground" Value="#8A8A8A"/>
                                                                <Setter Property="Opacity" Value="0.65"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsActiveView}" Value="True">
                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="ItemBorder"
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="2"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="ItemBorder" Property="Background" Value="#333333"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <Grid>
                                                    <TextBlock Text="{Binding Nome}"
                                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                                               TextTrimming="CharacterEllipsis">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBox Text="{Binding TextoEdicao, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             MinHeight="22"
                                                             Padding="3,1"
                                                             BorderThickness="1"
                                                             Background="#1E1E1E"
                                                             BorderBrush="#5B7FA8"
                                                             Foreground="#F4F4F4"
                                                             Loaded="OnRenameTextBoxLoaded"
                                                             IsVisibleChanged="OnRenameTextBoxIsVisibleChanged"
                                                             LostKeyboardFocus="OnRenameTextBoxLostKeyboardFocus"
                                                             PreviewKeyDown="OnRenameTextBoxPreviewKeyDown">
                                                        <TextBox.Style>
                                                            <Style TargetType="TextBox">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBox.Style>
                                                    </TextBox>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
