<UserControl x:Class="Araci.Views.ProjectSheetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True"
             Loaded="ProjectSheetView_Loaded"
             DataContextChanged="ProjectSheetView_DataContextChanged"
             KeyDown="ProjectSheetView_KeyDown"
             PreviewMouseWheel="ProjectSheetView_PreviewMouseWheel">
	<UserControl.Resources>
		<BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
		<Style x:Key="SheetTableCellTextStyle" TargetType="{x:Type TextBlock}">
			<Setter Property="Foreground" Value="#202020"/>
			<Setter Property="FontSize" Value="10"/>
			<Setter Property="VerticalAlignment" Value="Center"/>
			<Setter Property="TextTrimming" Value="CharacterEllipsis"/>
			<Setter Property="Margin" Value="6,0"/>
		</Style>
		<Style x:Key="ResizeHandleStyle" TargetType="{x:Type Border}">
			<Setter Property="Width" Value="10"/>
			<Setter Property="Height" Value="10"/>
			<Setter Property="Background" Value="#FFFFFFFF"/>
			<Setter Property="BorderBrush" Value="#1E90FF"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Visibility" Value="Collapsed"/>
			<Setter Property="Panel.ZIndex" Value="10"/>
			<Style.Triggers>
				<DataTrigger Binding="{Binding IsSelected}" Value="True">
					<Setter Property="Visibility" Value="Visible"/>
				</DataTrigger>
			</Style.Triggers>
		</Style>
	</UserControl.Resources>

	<Border Margin="10"
            BorderBrush="#252526"
            BorderThickness="1"
            Background="#D8D8D8">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="42"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<Border Grid.Row="0"
                    Background="#252526"
                    BorderBrush="#3A3A3A"
                    BorderThickness="0,0,0,1">
				<DockPanel LastChildFill="True">
					<StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,10,0">
						<Button Content="-"
                                Width="28"
                                Height="26"
                                Margin="0,0,4,0"
                                Click="ZoomOutButton_Click"/>
						<Button Content="{Binding ZoomPercentText}"
                                Width="58"
                                Height="26"
                                Margin="0,0,4,0"
                                Click="ResetZoomButton_Click"/>
						<Button Content="+"
                                Width="28"
                                Height="26"
                                Margin="0,0,12,0"
                                Click="ZoomInButton_Click"/>
						<Button Content="Remover selecionada"
                                Padding="10,0"
                                MinWidth="130"
                                Height="26"
                                IsEnabled="{Binding HasSelectedInstance}"
                                Click="RemoveSelectedButton_Click"/>
					</StackPanel>

					<TextBlock Text="{Binding Titulo}"
                               Foreground="#F4F4F4"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="12,0"/>
				</DockPanel>
			</Border>

			<ScrollViewer x:Name="SheetScrollViewer"
                          Grid.Row="1"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Background="#BFBFBF"
                          ClipToBounds="True">
				<Grid x:Name="ZoomHost"
                      Margin="18"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top"
                      Background="#BFBFBF">
					<Grid.LayoutTransform>
						<ScaleTransform ScaleX="{Binding ZoomScale}"
                                        ScaleY="{Binding ZoomScale}"/>
					</Grid.LayoutTransform>

					<Canvas x:Name="SheetSurface"
                            Width="{Binding WorkspaceWidth}"
                            Height="{Binding WorkspaceHeight}"
                            MinWidth="{Binding MinimumWorkspaceWidth}"
                            MinHeight="{Binding MinimumWorkspaceHeight}"
                            Background="#BFBFBF"
                            ClipToBounds="False"
                            MouseLeftButtonDown="SheetSurface_MouseLeftButtonDown"
                            LostMouseCapture="SheetSurface_LostMouseCapture">
						<Border x:Name="SheetPageBorder"
                                Canvas.Left="{Binding SheetOriginOffsetX}"
                                Canvas.Top="{Binding SheetOriginOffsetY}"
                                Width="{Binding SheetWidth}"
                                Height="{Binding SheetHeight}"
                                Background="#FFFFFF"
                                BorderBrush="#A8A8A8"
                                BorderThickness="1"/>

						<ItemsControl ItemsSource="{Binding TableInstances}"
                                      Width="{Binding WorkspaceWidth}"
                                      Height="{Binding WorkspaceHeight}"
                                      ClipToBounds="False">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<Canvas Background="Transparent"
                                            ClipToBounds="False"
                                            Width="{Binding DataContext.WorkspaceWidth, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                            Height="{Binding DataContext.WorkspaceHeight, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"/>
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
							<ItemsControl.ItemContainerStyle>
								<Style TargetType="{x:Type ContentPresenter}">
									<Setter Property="Canvas.Left" Value="{Binding ViewX}"/>
									<Setter Property="Canvas.Top" Value="{Binding ViewY}"/>
									<Setter Property="Panel.ZIndex" Value="5"/>
								</Style>
							</ItemsControl.ItemContainerStyle>
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Border Width="{Binding Width}"
                                            Height="{Binding Height}"
                                            Background="#FAFAFA"
                                            ClipToBounds="True"
                                            Cursor="SizeAll"
                                            MouseLeftButtonDown="TableInstance_MouseLeftButtonDown"
                                            MouseMove="TableInstance_MouseMove"
                                            MouseLeftButtonUp="TableInstance_MouseLeftButtonUp"
                                            LostMouseCapture="TableInstance_LostMouseCapture">
										<Border.Style>
											<Style TargetType="{x:Type Border}">
												<Setter Property="BorderBrush" Value="#303030"/>
												<Setter Property="BorderThickness" Value="1"/>
												<Style.Triggers>
													<DataTrigger Binding="{Binding IsSelected}" Value="True">
														<Setter Property="BorderBrush" Value="#1E90FF"/>
														<Setter Property="BorderThickness" Value="2"/>
													</DataTrigger>
												</Style.Triggers>
											</Style>
										</Border.Style>

										<Grid>
											<Grid>
												<Grid.RowDefinitions>
													<RowDefinition Height="30"/>
													<RowDefinition Height="*"/>
												</Grid.RowDefinitions>

												<Border Grid.Row="0"
                                                        Background="#E8E8E8"
                                                        BorderBrush="#C8C8C8"
                                                        BorderThickness="0,0,0,1">
													<TextBlock Text="{Binding TableName}"
                                                               Foreground="#202020"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="8,0"/>
												</Border>

												<Grid Grid.Row="1"
                                                      ClipToBounds="True"
                                                      Background="#FFFFFF">
													<Grid Visibility="{Binding HasRenderableTable, Converter={StaticResource BooleanToVisibilityConverter}}">
														<Grid.RowDefinitions>
															<RowDefinition Height="24"/>
															<RowDefinition Height="*"/>
														</Grid.RowDefinitions>

														<ItemsControl Grid.Row="0"
                                                                      ItemsSource="{Binding Columns}">
															<ItemsControl.ItemsPanel>
																<ItemsPanelTemplate>
																	<StackPanel Orientation="Horizontal"/>
																</ItemsPanelTemplate>
															</ItemsControl.ItemsPanel>
															<ItemsControl.ItemTemplate>
																<DataTemplate>
																	<Border Width="110"
                                                                            Height="24"
                                                                            Background="#F1F1F1"
                                                                            BorderBrush="#D0D0D0"
                                                                            BorderThickness="0,0,1,1">
																		<TextBlock Text="{Binding NomeExibicao}"
                                                                                   FontWeight="SemiBold"
                                                                                   Style="{StaticResource SheetTableCellTextStyle}"/>
																	</Border>
																</DataTemplate>
															</ItemsControl.ItemTemplate>
														</ItemsControl>

														<ItemsControl Grid.Row="1"
                                                                      ItemsSource="{Binding Rows}">
															<ItemsControl.ItemTemplate>
																<DataTemplate>
																	<ItemsControl ItemsSource="{Binding Cells}">
																		<ItemsControl.ItemsPanel>
																			<ItemsPanelTemplate>
																				<StackPanel Orientation="Horizontal"/>
																			</ItemsPanelTemplate>
																		</ItemsControl.ItemsPanel>
																		<ItemsControl.ItemTemplate>
																			<DataTemplate>
																				<Border Width="110"
                                                                                        Height="22"
                                                                                        Background="#FFFFFF"
                                                                                        BorderBrush="#E4E4E4"
                                                                                        BorderThickness="0,0,1,1">
																					<TextBlock Text="{Binding DisplayValue}"
                                                                                               Style="{StaticResource SheetTableCellTextStyle}"/>
																				</Border>
																			</DataTemplate>
																		</ItemsControl.ItemTemplate>
																	</ItemsControl>
																</DataTemplate>
															</ItemsControl.ItemTemplate>
														</ItemsControl>
													</Grid>

													<Border Background="#FFFFFF"
                                                            Visibility="{Binding HasEmptyDataMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
														<TextBlock Text="{Binding EmptyDataMessage}"
                                                                   Foreground="#707070"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   TextAlignment="Center"
                                                                   TextWrapping="Wrap"
                                                                   FontSize="12"
                                                                   Margin="10"/>
													</Border>
												</Grid>
											</Grid>

											<Border Style="{StaticResource ResizeHandleStyle}"
                                                    Tag="Right"
                                                    Cursor="SizeWE"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
                                                    MouseMove="ResizeHandle_MouseMove"
                                                    MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp"
                                                    LostMouseCapture="ResizeHandle_LostMouseCapture"/>

											<Border Style="{StaticResource ResizeHandleStyle}"
                                                    Tag="Bottom"
                                                    Cursor="SizeNS"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Bottom"
                                                    MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
                                                    MouseMove="ResizeHandle_MouseMove"
                                                    MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp"
                                                    LostMouseCapture="ResizeHandle_LostMouseCapture"/>

											<Border Style="{StaticResource ResizeHandleStyle}"
                                                    Tag="BottomRight"
                                                    Cursor="SizeNWSE"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Bottom"
                                                    MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
                                                    MouseMove="ResizeHandle_MouseMove"
                                                    MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp"
                                                    LostMouseCapture="ResizeHandle_LostMouseCapture"/>
										</Grid>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>

						<Border Canvas.Left="{Binding SheetOriginOffsetX}"
                                Canvas.Top="{Binding SheetOriginOffsetY}"
                                Width="{Binding SheetWidth}"
                                Height="{Binding SheetHeight}"
                                Background="#CCFFFFFF"
                                Panel.ZIndex="20"
                                Visibility="{Binding HasEmptyMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
							<TextBlock Text="{Binding EmptyMessage}"
                                       Foreground="#404040"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="16"/>
						</Border>
					</Canvas>
				</Grid>
			</ScrollViewer>
		</Grid>
	</Border>
</UserControl>
