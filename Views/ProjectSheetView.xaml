<UserControl x:Class="Araci.Views.ProjectSheetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True"
             Loaded="ProjectSheetView_Loaded"
             DataContextChanged="ProjectSheetView_DataContextChanged"
             KeyDown="ProjectSheetView_KeyDown"
             PreviewMouseWheel="ProjectSheetView_PreviewMouseWheel">
	<UserControl.Resources>
		<BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
		<Style x:Key="SheetTableTitleTextStyle" TargetType="{x:Type TextBlock}">
			<Setter Property="Foreground" Value="#FFFFFF"/>
			<Setter Property="FontSize" Value="11"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="VerticalAlignment" Value="Center"/>
			<Setter Property="TextTrimming" Value="CharacterEllipsis"/>
			<Setter Property="Margin" Value="10,0,8,0"/>
		</Style>
		<Style x:Key="SheetTableCellTextStyle" TargetType="{x:Type TextBlock}">
			<Setter Property="Foreground" Value="#1F2933"/>
			<Setter Property="FontSize" Value="10.5"/>
			<Setter Property="VerticalAlignment" Value="Center"/>
			<Setter Property="TextTrimming" Value="CharacterEllipsis"/>
			<Setter Property="Margin" Value="7,0"/>
		</Style>
		<Style x:Key="SheetTableHeaderTextStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource SheetTableCellTextStyle}">
			<Setter Property="Foreground" Value="#1C252C"/>
			<Setter Property="FontSize" Value="10"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
		</Style>
		<Style x:Key="SheetTableHeaderCellStyle" TargetType="{x:Type Border}">
			<Setter Property="Background" Value="#DDE5EA"/>
			<Setter Property="BorderBrush" Value="#B7C3CB"/>
			<Setter Property="BorderThickness" Value="0,0,1,1"/>
		</Style>
		<Style x:Key="SheetTableBodyCellStyle" TargetType="{x:Type Border}">
			<Setter Property="Background" Value="#FFFFFF"/>
			<Setter Property="BorderBrush" Value="#E0E6EA"/>
			<Setter Property="BorderThickness" Value="0,0,1,1"/>
		</Style>
		<Style x:Key="SheetTableEmptyMessageTextStyle" TargetType="{x:Type TextBlock}">
			<Setter Property="Foreground" Value="#64707A"/>
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="HorizontalAlignment" Value="Center"/>
			<Setter Property="VerticalAlignment" Value="Center"/>
			<Setter Property="TextAlignment" Value="Center"/>
			<Setter Property="TextWrapping" Value="Wrap"/>
			<Setter Property="Margin" Value="12"/>
		</Style>
		<Style x:Key="ResizeHandleStyle" TargetType="{x:Type Border}">
			<Setter Property="Width" Value="10"/>
			<Setter Property="Height" Value="10"/>
			<Setter Property="Background" Value="#FFFFFFFF"/>
			<Setter Property="BorderBrush" Value="#1E90FF"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Visibility" Value="Collapsed"/>
			<Setter Property="Panel.ZIndex" Value="40"/>
			<Style.Triggers>
				<DataTrigger Binding="{Binding IsSelected}" Value="True">
					<Setter Property="Visibility" Value="Visible"/>
				</DataTrigger>
			</Style.Triggers>
		</Style>
	</UserControl.Resources>

	<Border Margin="10"
            BorderBrush="#252526"
            BorderThickness="1"
            Background="#D8D8D8">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="42"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<Border Grid.Row="0"
                    Background="#252526"
                    BorderBrush="#3A3A3A"
                    BorderThickness="0,0,0,1">
				<DockPanel LastChildFill="True">
					<StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,10,0">
						<Button Content="-"
                                Width="28"
                                Height="26"
                                Margin="0,0,4,0"
                                Click="ZoomOutButton_Click"/>
						<Button Content="{Binding ZoomPercentText}"
                                Width="58"
                                Height="26"
                                Margin="0,0,4,0"
                                Click="ResetZoomButton_Click"/>
						<Button Content="+"
                                Width="28"
                                Height="26"
                                Margin="0,0,12,0"
                                Click="ZoomInButton_Click"/>
						<Button Content="Remover selecionada"
                                Padding="10,0"
                                MinWidth="130"
                                Height="26"
                                IsEnabled="{Binding HasSelectedInstance}"
                                Click="RemoveSelectedButton_Click"/>
					</StackPanel>

					<TextBlock Text="{Binding Titulo}"
                               Foreground="#F4F4F4"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="12,0"/>
				</DockPanel>
			</Border>

			<ScrollViewer x:Name="SheetScrollViewer"
                          Grid.Row="1"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Background="#BFBFBF"
                          ClipToBounds="True">
				<Grid x:Name="ZoomHost"
                      Margin="18"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top"
                      Background="#BFBFBF">
					<Grid.LayoutTransform>
						<ScaleTransform ScaleX="{Binding ZoomScale}"
                                        ScaleY="{Binding ZoomScale}"/>
					</Grid.LayoutTransform>

					<Canvas x:Name="SheetSurface"
                            Width="{Binding WorkspaceWidth}"
                            Height="{Binding WorkspaceHeight}"
                            MinWidth="{Binding MinimumWorkspaceWidth}"
                            MinHeight="{Binding MinimumWorkspaceHeight}"
                            Background="#BFBFBF"
                            ClipToBounds="False"
                            MouseLeftButtonDown="SheetSurface_MouseLeftButtonDown"
                            LostMouseCapture="SheetSurface_LostMouseCapture">
						<Border x:Name="SheetPageBorder"
                                Canvas.Left="{Binding SheetOriginOffsetX}"
                                Canvas.Top="{Binding SheetOriginOffsetY}"
                                Width="{Binding SheetWidth}"
                                Height="{Binding SheetHeight}"
                                Background="#FFFFFF"
                                BorderBrush="#A8A8A8"
                                BorderThickness="1"/>

						<Canvas Canvas.Left="{Binding SheetOriginOffsetX}"
                                Canvas.Top="{Binding SheetOriginOffsetY}"
                                Width="{Binding SheetWidth}"
                                Height="{Binding SheetHeight}"
                                Background="Transparent"
                                ClipToBounds="True"
                                IsHitTestVisible="False"
                                Panel.ZIndex="1">
							<ItemsControl ItemsSource="{Binding TemplateCircles}"
                                          Width="{Binding SheetWidth}"
                                          Height="{Binding SheetHeight}"
                                          ClipToBounds="True"
                                          IsHitTestVisible="False"
                                          Panel.ZIndex="1">
								<ItemsControl.ItemsPanel>
									<ItemsPanelTemplate>
										<Canvas Background="Transparent"
                                                ClipToBounds="True"
                                                Width="{Binding DataContext.SheetWidth, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                Height="{Binding DataContext.SheetHeight, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"/>
									</ItemsPanelTemplate>
								</ItemsControl.ItemsPanel>
								<ItemsControl.ItemContainerStyle>
									<Style TargetType="{x:Type ContentPresenter}">
										<Setter Property="Canvas.Left" Value="{Binding Left}"/>
										<Setter Property="Canvas.Top" Value="{Binding Top}"/>
										<Setter Property="Panel.ZIndex" Value="1"/>
									</Style>
								</ItemsControl.ItemContainerStyle>
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Ellipse Width="{Binding Diametro}"
                                                 Height="{Binding Diametro}"
                                                 Fill="{Binding FillBrush}"
                                                 Stroke="{Binding StrokeBrush}"
                                                 StrokeThickness="{Binding StrokeThickness}"
                                                 StrokeDashArray="{Binding StrokeDashArray}"
                                                 SnapsToDevicePixels="True"
                                                 IsHitTestVisible="False"/>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>

							<ItemsControl ItemsSource="{Binding TemplateRectangles}"
                                          Width="{Binding SheetWidth}"
                                          Height="{Binding SheetHeight}"
                                          ClipToBounds="True"
                                          IsHitTestVisible="False"
                                          Panel.ZIndex="2">
								<ItemsControl.ItemsPanel>
									<ItemsPanelTemplate>
										<Canvas Background="Transparent"
                                                ClipToBounds="True"
                                                Width="{Binding DataContext.SheetWidth, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                Height="{Binding DataContext.SheetHeight, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"/>
									</ItemsPanelTemplate>
								</ItemsControl.ItemsPanel>
								<ItemsControl.ItemContainerStyle>
									<Style TargetType="{x:Type ContentPresenter}">
										<Setter Property="Canvas.Left" Value="{Binding X}"/>
										<Setter Property="Canvas.Top" Value="{Binding Y}"/>
										<Setter Property="Panel.ZIndex" Value="2"/>
									</Style>
								</ItemsControl.ItemContainerStyle>
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Rectangle Width="{Binding Largura}"
                                                   Height="{Binding Altura}"
                                                   Fill="{Binding FillBrush}"
                                                   Stroke="{Binding StrokeBrush}"
                                                   StrokeThickness="{Binding StrokeThickness}"
                                                   StrokeDashArray="{Binding StrokeDashArray}"
                                                   SnapsToDevicePixels="True"
                                                   IsHitTestVisible="False"/>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>

							<ItemsControl ItemsSource="{Binding TemplateLines}"
                                          Width="{Binding SheetWidth}"
                                          Height="{Binding SheetHeight}"
                                          ClipToBounds="True"
                                          IsHitTestVisible="False"
                                          Panel.ZIndex="3">
								<ItemsControl.ItemsPanel>
									<ItemsPanelTemplate>
										<Canvas Background="Transparent"
                                                ClipToBounds="True"
                                                Width="{Binding DataContext.SheetWidth, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                Height="{Binding DataContext.SheetHeight, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"/>
									</ItemsPanelTemplate>
								</ItemsControl.ItemsPanel>
								<ItemsControl.ItemContainerStyle>
									<Style TargetType="{x:Type ContentPresenter}">
										<Setter Property="Canvas.Left" Value="0"/>
										<Setter Property="Canvas.Top" Value="0"/>
										<Setter Property="Panel.ZIndex" Value="3"/>
									</Style>
								</ItemsControl.ItemContainerStyle>
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Line X1="{Binding X1}"
                                              Y1="{Binding Y1}"
                                              X2="{Binding X2}"
                                              Y2="{Binding Y2}"
                                              Stroke="{Binding StrokeBrush}"
                                              StrokeThickness="{Binding StrokeThickness}"
                                              StrokeDashArray="{Binding StrokeDashArray}"
                                              StrokeStartLineCap="Square"
                                              StrokeEndLineCap="Square"
                                              SnapsToDevicePixels="True"
                                              IsHitTestVisible="False"/>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>

							<ItemsControl ItemsSource="{Binding TemplateTexts}"
                                          Width="{Binding SheetWidth}"
                                          Height="{Binding SheetHeight}"
                                          ClipToBounds="True"
                                          IsHitTestVisible="False"
                                          Panel.ZIndex="4">
								<ItemsControl.ItemsPanel>
									<ItemsPanelTemplate>
										<Canvas Background="Transparent"
                                                ClipToBounds="True"
                                                Width="{Binding DataContext.SheetWidth, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                Height="{Binding DataContext.SheetHeight, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"/>
									</ItemsPanelTemplate>
								</ItemsControl.ItemsPanel>
								<ItemsControl.ItemContainerStyle>
									<Style TargetType="{x:Type ContentPresenter}">
										<Setter Property="Canvas.Left" Value="0"/>
										<Setter Property="Canvas.Top" Value="0"/>
										<Setter Property="Panel.ZIndex" Value="4"/>
									</Style>
								</ItemsControl.ItemContainerStyle>
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Canvas Width="{Binding DataContext.SheetWidth, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                Height="{Binding DataContext.SheetHeight, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                Background="Transparent"
                                                ClipToBounds="False"
                                                IsHitTestVisible="False">
											<Canvas.Style>
												<Style TargetType="{x:Type Canvas}">
													<Setter Property="Visibility" Value="Collapsed"/>
													<Style.Triggers>
														<DataTrigger Binding="{Binding LeaderVisivel}" Value="True">
															<Setter Property="Visibility" Value="Visible"/>
														</DataTrigger>
													</Style.Triggers>
												</Style>
											</Canvas.Style>
											<Line X1="{Binding LeaderInicioWorld.X}"
                                                  Y1="{Binding LeaderInicioWorld.Y}"
                                                  X2="{Binding LeaderPoint.X}"
                                                  Y2="{Binding LeaderPoint.Y}"
                                                  Stroke="{Binding LeaderBrush}"
                                                  StrokeThickness="{Binding LeaderEspessura}"
                                                  SnapsToDevicePixels="True"
                                                  IsHitTestVisible="False">
												<Line.Style>
													<Style TargetType="{x:Type Line}">
														<Setter Property="Visibility" Value="Collapsed"/>
														<Style.Triggers>
															<DataTrigger Binding="{Binding LeaderRetoVisivel}" Value="True">
																<Setter Property="Visibility" Value="Visible"/>
															</DataTrigger>
														</Style.Triggers>
													</Style>
												</Line.Style>
											</Line>
											<Polyline Points="{Binding LeaderPolylineWorldPoints}"
                                                      Stroke="{Binding LeaderBrush}"
                                                      StrokeThickness="{Binding LeaderEspessura}"
                                                      Fill="{x:Null}"
                                                      StrokeStartLineCap="Square"
                                                      StrokeEndLineCap="Square"
                                                      StrokeLineJoin="Miter"
                                                      SnapsToDevicePixels="True"
                                                      IsHitTestVisible="False">
												<Polyline.Style>
													<Style TargetType="{x:Type Polyline}">
														<Setter Property="Visibility" Value="Collapsed"/>
														<Style.Triggers>
															<DataTrigger Binding="{Binding LeaderCotoveloVisivel}" Value="True">
																<Setter Property="Visibility" Value="Visible"/>
															</DataTrigger>
														</Style.Triggers>
													</Style>
												</Polyline.Style>
											</Polyline>
											<Polygon Points="{Binding LeaderArrowWorldPoints}"
                                                     Fill="{Binding LeaderBrush}"
                                                     Stroke="{Binding LeaderBrush}"
                                                     StrokeThickness="{Binding LeaderEspessura}"
                                                     SnapsToDevicePixels="True"
                                                     IsHitTestVisible="False">
												<Polygon.Style>
													<Style TargetType="{x:Type Polygon}">
														<Setter Property="Visibility" Value="Collapsed"/>
														<Style.Triggers>
															<DataTrigger Binding="{Binding LeaderArrowFillVisivel}" Value="True">
																<Setter Property="Visibility" Value="Visible"/>
															</DataTrigger>
														</Style.Triggers>
													</Style>
												</Polygon.Style>
											</Polygon>
											<Polyline Points="{Binding LeaderOpenArrowWorldPoints}"
                                                      Stroke="{Binding LeaderBrush}"
                                                      StrokeThickness="{Binding LeaderEspessura}"
                                                      Fill="{x:Null}"
                                                      StrokeStartLineCap="Square"
                                                      StrokeEndLineCap="Square"
                                                      StrokeLineJoin="Miter"
                                                      SnapsToDevicePixels="True"
                                                      IsHitTestVisible="False">
												<Polyline.Style>
													<Style TargetType="{x:Type Polyline}">
														<Setter Property="Visibility" Value="Collapsed"/>
														<Style.Triggers>
															<DataTrigger Binding="{Binding LeaderArrowOpenVisivel}" Value="True">
																<Setter Property="Visibility" Value="Visible"/>
															</DataTrigger>
														</Style.Triggers>
													</Style>
												</Polyline.Style>
											</Polyline>
										</Canvas>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>

							<ItemsControl ItemsSource="{Binding TemplateTexts}"
                                          Width="{Binding SheetWidth}"
                                          Height="{Binding SheetHeight}"
                                          ClipToBounds="True"
                                          IsHitTestVisible="False"
                                          Panel.ZIndex="5">
								<ItemsControl.ItemsPanel>
									<ItemsPanelTemplate>
										<Canvas Background="Transparent"
                                                ClipToBounds="True"
                                                Width="{Binding DataContext.SheetWidth, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                Height="{Binding DataContext.SheetHeight, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"/>
									</ItemsPanelTemplate>
								</ItemsControl.ItemsPanel>
								<ItemsControl.ItemContainerStyle>
									<Style TargetType="{x:Type ContentPresenter}">
										<Setter Property="Canvas.Left" Value="{Binding X}"/>
										<Setter Property="Canvas.Top" Value="{Binding Y}"/>
										<Setter Property="Panel.ZIndex" Value="5"/>
									</Style>
								</ItemsControl.ItemContainerStyle>
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Grid Width="{Binding LarguraCaixa}"
                                              MinHeight="{Binding AlturaVisual}"
                                              Background="Transparent"
                                              RenderTransform="{Binding RenderTransform}"
                                              RenderTransformOrigin="0,0"
                                              IsHitTestVisible="False">
											<TextBlock Text="{Binding Conteudo}"
                                                       Width="{Binding LarguraCaixa}"
                                                       MinHeight="{Binding AlturaEstimada}"
                                                       Foreground="{Binding ForegroundBrush}"
                                                       FontFamily="{Binding FontFamily}"
                                                       FontSize="{Binding AlturaTexto}"
                                                       LineHeight="{Binding LineHeight}"
                                                       TextAlignment="{Binding TextAlignment}"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="None"
                                                       SnapsToDevicePixels="True"
                                                       IsHitTestVisible="False"/>
										</Grid>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</Canvas>

						<ItemsControl ItemsSource="{Binding TableInstances}"
                                      Width="{Binding WorkspaceWidth}"
                                      Height="{Binding WorkspaceHeight}"
                                      ClipToBounds="False">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<Canvas Background="Transparent"
                                            ClipToBounds="False"
                                            Width="{Binding DataContext.WorkspaceWidth, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                            Height="{Binding DataContext.WorkspaceHeight, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"/>
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
							<ItemsControl.ItemContainerStyle>
								<Style TargetType="{x:Type ContentPresenter}">
									<Setter Property="Canvas.Left" Value="{Binding ViewX}"/>
									<Setter Property="Canvas.Top" Value="{Binding ViewY}"/>
									<Setter Property="Panel.ZIndex" Value="5"/>
								</Style>
							</ItemsControl.ItemContainerStyle>
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Border Width="{Binding Width}"
                                            MaxHeight="{Binding Height}"
                                            Background="Transparent"
                                            ClipToBounds="True"
                                            Cursor="SizeAll"
                                            MouseLeftButtonDown="TableInstance_MouseLeftButtonDown"
                                            MouseMove="TableInstance_MouseMove"
                                            MouseLeftButtonUp="TableInstance_MouseLeftButtonUp"
                                            LostMouseCapture="TableInstance_LostMouseCapture">
										<Border.Style>
											<Style TargetType="{x:Type Border}">
												<Setter Property="BorderBrush" Value="#303030"/>
												<Setter Property="BorderThickness" Value="1"/>
												<Style.Triggers>
													<DataTrigger Binding="{Binding IsSelected}" Value="True">
														<Setter Property="BorderBrush" Value="#1E90FF"/>
														<Setter Property="BorderThickness" Value="2"/>
													</DataTrigger>
												</Style.Triggers>
											</Style>
										</Border.Style>

										<Grid>
											<Grid>
												<Grid.RowDefinitions>
													<RowDefinition Height="Auto"/>
													<RowDefinition Height="*"/>
												</Grid.RowDefinitions>

												<Border Grid.Row="0"
                                                        Height="{Binding TitleHeight}"
                                                        Visibility="{Binding ExibirTitulo, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                        Background="{Binding TitleBackgroundBrush}"
                                                        BorderBrush="{Binding GridBrush}"
                                                        BorderThickness="{Binding GridBorderThickness}">
													<TextBlock Text="{Binding TableName}"
                                                               Foreground="{Binding TitleForegroundBrush}"
                                                               FontFamily="{Binding TitleFontFamily}"
                                                               FontSize="{Binding TitleFontSize}"
                                                               FontWeight="{Binding TitleFontWeight}"
                                                               TextAlignment="{Binding TitleTextAlignment}"
                                                               HorizontalAlignment="Stretch"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="10,0,8,0"/>
												</Border>

												<Grid Grid.Row="1"
                                                      ClipToBounds="True"
                                                      Background="Transparent">
													<Grid Visibility="{Binding HasRenderableTable, Converter={StaticResource BooleanToVisibilityConverter}}">
														<Grid.RowDefinitions>
															<RowDefinition Height="Auto"/>
															<RowDefinition Height="Auto"/>
														</Grid.RowDefinitions>

														<ItemsControl Grid.Row="0"
                                                                      Width="{Binding TableGridWidth}"
                                                                      Height="{Binding HeaderRowHeight}"
                                                                      Visibility="{Binding ExibirCabecalho, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                      HorizontalAlignment="Left"
                                                                      ClipToBounds="True"
                                                                      ItemsSource="{Binding RenderColumns}">
															<ItemsControl.ItemsPanel>
																<ItemsPanelTemplate>
																	<StackPanel Orientation="Horizontal"/>
																</ItemsPanelTemplate>
															</ItemsControl.ItemsPanel>
															<ItemsControl.ItemTemplate>
																<DataTemplate>
																	<Border Width="{Binding Width}"
                                                                            Height="{Binding DataContext.HeaderRowHeight, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                                            Background="{Binding DataContext.HeaderBackgroundBrush, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                                            BorderBrush="{Binding DataContext.GridBrush, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                                            BorderThickness="{Binding DataContext.GridBorderThickness, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}">
																		<TextBlock Text="{Binding NomeExibicao}"
                                                                                   Foreground="{Binding DataContext.HeaderForegroundBrush, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                                                   FontFamily="{Binding DataContext.HeaderFontFamily, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                                                   FontSize="{Binding DataContext.HeaderFontSize, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                                                   FontWeight="{Binding DataContext.HeaderFontWeight, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                                                   TextAlignment="{Binding DataContext.HeaderTextAlignment, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                                                   HorizontalAlignment="Stretch"
                                                                                   VerticalAlignment="Center"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   Margin="7,0"/>
																	</Border>
																</DataTemplate>
															</ItemsControl.ItemTemplate>
														</ItemsControl>

														<ItemsControl Grid.Row="1"
                                                                      Width="{Binding TableGridWidth}"
                                                                      MaxHeight="{Binding RowsViewportHeight}"
                                                                      HorizontalAlignment="Left"
                                                                      ClipToBounds="True"
                                                                      ItemsSource="{Binding Rows}">
															<ItemsControl.ItemTemplate>
																<DataTemplate>
																	<ItemsControl ItemsSource="{Binding Cells}">
																		<ItemsControl.ItemsPanel>
																			<ItemsPanelTemplate>
																				<StackPanel Orientation="Horizontal"/>
																			</ItemsPanelTemplate>
																		</ItemsControl.ItemsPanel>
																		<ItemsControl.ItemTemplate>
																			<DataTemplate>
																				<Border Width="{Binding Width}"
                                                                                        Height="{Binding DataContext.BodyRowHeight, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}, AncestorLevel=2}}"
                                                                                        Background="{Binding DataContext.BackgroundBrush, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                                                        BorderBrush="{Binding DataContext.GridBrush, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}, AncestorLevel=2}}"
                                                                                        BorderThickness="{Binding DataContext.GridBorderThickness, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}, AncestorLevel=2}}">
																					<TextBlock Text="{Binding DisplayValue}"
                                                                                               Foreground="{Binding DataContext.BodyForegroundBrush, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}, AncestorLevel=2}}"
                                                                                               FontFamily="{Binding DataContext.BodyFontFamily, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}, AncestorLevel=2}}"
                                                                                               FontSize="{Binding DataContext.BodyFontSize, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}, AncestorLevel=2}}"
                                                                                               TextAlignment="{Binding DataContext.BodyTextAlignment, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}, AncestorLevel=2}}"
                                                                                               VerticalAlignment="Center"
                                                                                               TextTrimming="CharacterEllipsis"
                                                                                               Margin="7,0"/>
																				</Border>
																			</DataTemplate>
																		</ItemsControl.ItemTemplate>
																	</ItemsControl>
																</DataTemplate>
															</ItemsControl.ItemTemplate>
														</ItemsControl>
													</Grid>

													<Border Background="#F8FAFB"
                                                            Visibility="{Binding HasEmptyDataMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
														<TextBlock Text="{Binding EmptyDataMessage}"
                                                                   Style="{StaticResource SheetTableEmptyMessageTextStyle}"/>
													</Border>
												</Grid>
											</Grid>

											<Border Width="22"
                                                    Height="24"
                                                    Margin="0,0,14,0"
                                                    Background="#FFFFFFFF"
                                                    BorderBrush="#1E90FF"
                                                    BorderThickness="1"
                                                    Cursor="Hand"
                                                    ToolTip="Dividir ou unir tabela"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    Panel.ZIndex="60"
                                                    MouseLeftButtonDown="ToggleSplitInlineControl_MouseLeftButtonDown">
												<Border.Style>
													<Style TargetType="{x:Type Border}">
														<Setter Property="Visibility" Value="Collapsed"/>
														<Style.Triggers>
															<MultiDataTrigger>
																<MultiDataTrigger.Conditions>
																	<Condition Binding="{Binding IsSelected}" Value="True"/>
																	<Condition Binding="{Binding CanSplit}" Value="True"/>
																</MultiDataTrigger.Conditions>
																<Setter Property="Visibility" Value="Visible"/>
															</MultiDataTrigger>
														</Style.Triggers>
													</Style>
												</Border.Style>
												<TextBlock Text="Z"
                                                           Foreground="#1F2933"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
											</Border>

											<Border Style="{StaticResource ResizeHandleStyle}"
                                                    Tag="Right"
                                                    Cursor="SizeWE"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
                                                    MouseMove="ResizeHandle_MouseMove"
                                                    MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp"
                                                    LostMouseCapture="ResizeHandle_LostMouseCapture"/>

											<Border Style="{StaticResource ResizeHandleStyle}"
                                                    Tag="Bottom"
                                                    Cursor="SizeNS"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Bottom"
                                                    MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
                                                    MouseMove="ResizeHandle_MouseMove"
                                                    MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp"
                                                    LostMouseCapture="ResizeHandle_LostMouseCapture"/>

											<Border Style="{StaticResource ResizeHandleStyle}"
                                                    Tag="BottomRight"
                                                    Cursor="SizeNWSE"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Bottom"
                                                    MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
                                                    MouseMove="ResizeHandle_MouseMove"
                                                    MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp"
                                                    LostMouseCapture="ResizeHandle_LostMouseCapture"/>
										</Grid>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>

						<Border Canvas.Left="{Binding SheetOriginOffsetX}"
                                Canvas.Top="{Binding SheetOriginOffsetY}"
                                Width="{Binding SheetWidth}"
                                Height="{Binding SheetHeight}"
                                Background="#CCFFFFFF"
                                Panel.ZIndex="20"
                                Visibility="{Binding HasEmptyMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
							<TextBlock Text="{Binding EmptyMessage}"
                                       Foreground="#404040"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="16"/>
						</Border>
					</Canvas>
				</Grid>
			</ScrollViewer>
		</Grid>
	</Border>
</UserControl>