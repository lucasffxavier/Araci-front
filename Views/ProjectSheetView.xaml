<UserControl x:Class="Araci.Views.ProjectSheetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True"
             KeyDown="ProjectSheetView_KeyDown">
	<UserControl.Resources>
		<BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
		<Style x:Key="ResizeHandleStyle" TargetType="{x:Type Border}">
			<Setter Property="Width" Value="10"/>
			<Setter Property="Height" Value="10"/>
			<Setter Property="Background" Value="#FFFFFFFF"/>
			<Setter Property="BorderBrush" Value="#1E90FF"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Visibility" Value="Collapsed"/>
			<Setter Property="Panel.ZIndex" Value="10"/>
			<Style.Triggers>
				<DataTrigger Binding="{Binding IsSelected}" Value="True">
					<Setter Property="Visibility" Value="Visible"/>
				</DataTrigger>
			</Style.Triggers>
		</Style>
	</UserControl.Resources>
	<Border Margin="10"
            BorderBrush="#252526"
            BorderThickness="1"
            Background="#D8D8D8">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="42"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<Border Grid.Row="0"
                    Background="#252526"
                    BorderBrush="#3A3A3A"
                    BorderThickness="0,0,0,1">
				<DockPanel LastChildFill="True">
					<Button DockPanel.Dock="Right"
                            Content="Remover selecionada"
                            Margin="0,7,10,7"
                            Padding="10,0"
                            MinWidth="130"
                            IsEnabled="{Binding HasSelectedInstance}"
                            Click="RemoveSelectedButton_Click"/>
					<TextBlock Text="{Binding Titulo}"
                               Foreground="#F4F4F4"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="12,0"/>
				</DockPanel>
			</Border>

			<Grid x:Name="SheetSurface"
                  Grid.Row="1"
                  Margin="18"
                  ClipToBounds="True"
                  MouseLeftButtonDown="SheetSurface_MouseLeftButtonDown"
                  LostMouseCapture="SheetSurface_LostMouseCapture">
				<Border Background="#FFFFFF"
                        BorderBrush="#A8A8A8"
                        BorderThickness="1"/>

				<ItemsControl ItemsSource="{Binding TableInstances}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<Canvas Background="Transparent"/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemContainerStyle>
						<Style TargetType="{x:Type ContentPresenter}">
							<Setter Property="Canvas.Left" Value="{Binding X}"/>
							<Setter Property="Canvas.Top" Value="{Binding Y}"/>
						</Style>
					</ItemsControl.ItemContainerStyle>
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Border Width="{Binding Width}"
                                    Height="{Binding Height}"
                                    Background="#FAFAFA"
                                    ClipToBounds="True"
                                    Cursor="SizeAll"
                                    MouseLeftButtonDown="TableInstance_MouseLeftButtonDown"
                                    MouseMove="TableInstance_MouseMove"
                                    MouseLeftButtonUp="TableInstance_MouseLeftButtonUp"
                                    LostMouseCapture="TableInstance_LostMouseCapture">
								<Border.Style>
									<Style TargetType="{x:Type Border}">
										<Setter Property="BorderBrush" Value="#303030"/>
										<Setter Property="BorderThickness" Value="1"/>
										<Style.Triggers>
											<DataTrigger Binding="{Binding IsSelected}" Value="True">
												<Setter Property="BorderBrush" Value="#1E90FF"/>
												<Setter Property="BorderThickness" Value="2"/>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</Border.Style>
								<Grid>
									<Grid>
										<Grid.RowDefinitions>
											<RowDefinition Height="30"/>
											<RowDefinition Height="*"/>
										</Grid.RowDefinitions>
										<Border Grid.Row="0"
                                                Background="#E8E8E8"
                                                BorderBrush="#C8C8C8"
                                                BorderThickness="0,0,0,1">
											<TextBlock Text="{Binding TableName}"
                                                       Foreground="#202020"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="8,0"/>
										</Border>
										<TextBlock Grid.Row="1"
                                                   Text="Tabela"
                                                   Foreground="#707070"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"/>
									</Grid>

									<Border Style="{StaticResource ResizeHandleStyle}"
                                            Tag="Right"
                                            Cursor="SizeWE"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
                                            MouseMove="ResizeHandle_MouseMove"
                                            MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp"
                                            LostMouseCapture="ResizeHandle_LostMouseCapture"/>

									<Border Style="{StaticResource ResizeHandleStyle}"
                                            Tag="Bottom"
                                            Cursor="SizeNS"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Bottom"
                                            MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
                                            MouseMove="ResizeHandle_MouseMove"
                                            MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp"
                                            LostMouseCapture="ResizeHandle_LostMouseCapture"/>

									<Border Style="{StaticResource ResizeHandleStyle}"
                                            Tag="BottomRight"
                                            Cursor="SizeNWSE"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
                                            MouseMove="ResizeHandle_MouseMove"
                                            MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp"
                                            LostMouseCapture="ResizeHandle_LostMouseCapture"/>
								</Grid>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>

				<Border Background="#CCFFFFFF"
                        Visibility="{Binding HasEmptyMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
					<TextBlock Text="{Binding EmptyMessage}"
                               Foreground="#404040"
                               FontSize="14"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="16"/>
				</Border>
			</Grid>
		</Grid>
	</Border>
</UserControl>