<UserControl x:Class="Araci.Views.ProjectSheetTypeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True"
             PreviewKeyDown="OnPreviewKeyDown">
	<Border Margin="10"
            BorderBrush="#252526"
            BorderThickness="1"
            Background="#D8D8D8">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="42"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<Border Grid.Row="0"
                    Background="#252526"
                    BorderBrush="#3A3A3A"
                    BorderThickness="0,0,0,1">
				<DockPanel LastChildFill="True">
					<TextBlock DockPanel.Dock="Right"
                               Text="{Binding Descricao}"
                               Foreground="#CFCFCF"
                               VerticalAlignment="Center"
                               Margin="12,0"
                               TextTrimming="CharacterEllipsis"/>
					<TextBlock Text="{Binding Titulo}"
                               Foreground="#F4F4F4"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="12,0"
                               TextTrimming="CharacterEllipsis"/>
				</DockPanel>
			</Border>

			<ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Background="#BFBFBF"
                          ClipToBounds="True">
				<Canvas x:Name="SheetTypeSurface"
                        Width="{Binding WorkspaceWidth}"
                        Height="{Binding WorkspaceHeight}"
                        Background="#BFBFBF"
                        ClipToBounds="False">
					<Border x:Name="TemplatePageBorder"
                            Canvas.Left="{Binding SheetOriginOffsetX}"
                            Canvas.Top="{Binding SheetOriginOffsetY}"
                            Width="{Binding SheetWidth}"
                            Height="{Binding SheetHeight}"
                            Background="#FFFFFF"
                            BorderBrush="#A8A8A8"
                            BorderThickness="1"
                            MouseLeftButtonDown="TemplatePageBorder_MouseLeftButtonDown"
                            MouseMove="TemplatePageBorder_MouseMove"
                            MouseLeftButtonUp="TemplatePageBorder_MouseLeftButtonUp"
                            LostMouseCapture="TemplatePageBorder_LostMouseCapture">
						<Grid x:Name="TemplatePageContent"
                              Background="Transparent"
                              ClipToBounds="True">
							<TextBlock Text="{Binding Nome}"
                                       Foreground="#808080"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       Margin="18"
                                       TextTrimming="CharacterEllipsis"
                                       IsHitTestVisible="False"/>
							<ItemsControl ItemsSource="{Binding Lines}"
                                          Width="{Binding SheetWidth}"
                                          Height="{Binding SheetHeight}"
                                          ClipToBounds="True"
                                          IsHitTestVisible="False">
								<ItemsControl.ItemsPanel>
									<ItemsPanelTemplate>
										<Canvas Background="Transparent"
                                                ClipToBounds="True"
                                                Width="{Binding DataContext.SheetWidth, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                Height="{Binding DataContext.SheetHeight, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"/>
									</ItemsPanelTemplate>
								</ItemsControl.ItemsPanel>
								<ItemsControl.ItemContainerStyle>
									<Style TargetType="{x:Type ContentPresenter}">
										<Setter Property="Canvas.Left" Value="0"/>
										<Setter Property="Canvas.Top" Value="0"/>
									</Style>
								</ItemsControl.ItemContainerStyle>
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Line X1="{Binding X1}"
                                              Y1="{Binding Y1}"
                                              X2="{Binding X2}"
                                              Y2="{Binding Y2}"
                                              Stroke="{Binding SelectionStrokeBrush}"
                                              StrokeThickness="{Binding SelectionStrokeThickness}"
                                              StrokeStartLineCap="Square"
                                              StrokeEndLineCap="Square"/>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
							<Line X1="{Binding PreviewLine.X1, TargetNullValue=0}"
                                  Y1="{Binding PreviewLine.Y1, TargetNullValue=0}"
                                  X2="{Binding PreviewLine.X2, TargetNullValue=0}"
                                  Y2="{Binding PreviewLine.Y2, TargetNullValue=0}"
                                  Stroke="#FF1E90FF"
                                  StrokeThickness="{Binding PreviewLine.StrokeThickness, TargetNullValue=1}"
                                  StrokeDashArray="4 2"
                                  IsHitTestVisible="False">
								<Line.Style>
									<Style TargetType="Line">
										<Setter Property="Visibility" Value="Collapsed"/>
										<Style.Triggers>
											<DataTrigger Binding="{Binding HasPreviewLine}" Value="True">
												<Setter Property="Visibility" Value="Visible"/>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</Line.Style>
							</Line>
						</Grid>
					</Border>
				</Canvas>
			</ScrollViewer>
		</Grid>
	</Border>
</UserControl>