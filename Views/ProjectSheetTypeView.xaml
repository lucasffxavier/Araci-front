<UserControl x:Class="Araci.Views.ProjectSheetTypeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True">
    <Border Margin="10"
            BorderBrush="#252526"
            BorderThickness="1"
            Background="#D8D8D8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#252526"
                    BorderBrush="#3A3A3A"
                    BorderThickness="0,0,0,1">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding Descricao}"
                               Foreground="#CFCFCF"
                               VerticalAlignment="Center"
                               Margin="12,0"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Titulo}"
                               Foreground="#F4F4F4"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="12,0"
                               TextTrimming="CharacterEllipsis"/>
                </DockPanel>
            </Border>

            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Background="#BFBFBF"
                          ClipToBounds="True">
                <Canvas x:Name="SheetTypeSurface"
                        Width="{Binding WorkspaceWidth}"
                        Height="{Binding WorkspaceHeight}"
                        Background="#BFBFBF"
                        ClipToBounds="False">
                    <Border x:Name="TemplatePageBorder"
                            Canvas.Left="{Binding SheetOriginOffsetX}"
                            Canvas.Top="{Binding SheetOriginOffsetY}"
                            Width="{Binding SheetWidth}"
                            Height="{Binding SheetHeight}"
                            Background="#FFFFFF"
                            BorderBrush="#A8A8A8"
                            BorderThickness="1">
                        <Grid>
                            <TextBlock Text="{Binding Nome}"
                                       Foreground="#808080"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       Margin="18"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </Border>
                </Canvas>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
