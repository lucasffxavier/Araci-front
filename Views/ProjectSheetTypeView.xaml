<UserControl x:Class="Araci.Views.ProjectSheetTypeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True"
             PreviewKeyDown="OnPreviewKeyDown">
	<Border Margin="10"
            BorderBrush="#252526"
            BorderThickness="1"
            Background="#D8D8D8">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="42"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<Border Grid.Row="0"
                    Background="#252526"
                    BorderBrush="#3A3A3A"
                    BorderThickness="0,0,0,1">
				<DockPanel LastChildFill="True">
					<TextBlock DockPanel.Dock="Right"
                               Text="{Binding Descricao}"
                               Foreground="#CFCFCF"
                               VerticalAlignment="Center"
                               Margin="12,0"
                               TextTrimming="CharacterEllipsis"/>
					<TextBlock Text="{Binding Titulo}"
                               Foreground="#F4F4F4"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="12,0"
                               TextTrimming="CharacterEllipsis"/>
				</DockPanel>
			</Border>

			<ScrollViewer x:Name="SheetTypeScrollViewer"
                          Grid.Row="1"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Background="#BFBFBF"
                          ClipToBounds="True">
				<Canvas x:Name="SheetTypeSurface"
                        Width="{Binding WorkspaceWidth}"
                        Height="{Binding WorkspaceHeight}"
                        Background="#BFBFBF"
                        ClipToBounds="False">
					<Border x:Name="TemplatePageBorder"
                            Canvas.Left="{Binding SheetOriginOffsetX}"
                            Canvas.Top="{Binding SheetOriginOffsetY}"
                            Width="{Binding SheetWidth}"
                            Height="{Binding SheetHeight}"
                            Background="#FFFFFF"
                            BorderBrush="#A8A8A8"
                            BorderThickness="1"
                            MouseLeftButtonDown="TemplatePageBorder_MouseLeftButtonDown"
                            MouseMove="TemplatePageBorder_MouseMove"
                            MouseLeftButtonUp="TemplatePageBorder_MouseLeftButtonUp"
                            LostMouseCapture="TemplatePageBorder_LostMouseCapture">
						<Grid x:Name="TemplatePageContent"
                              Background="Transparent"
                              ClipToBounds="True">
							<TextBlock Text="{Binding Nome}"
                                       Foreground="#808080"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       Margin="18"
                                       TextTrimming="CharacterEllipsis"
                                       IsHitTestVisible="False"/>
							<ItemsControl ItemsSource="{Binding Circles}"
                                          Width="{Binding SheetWidth}"
                                          Height="{Binding SheetHeight}"
                                          ClipToBounds="True"
                                          IsHitTestVisible="False"
                                          Panel.ZIndex="7">
								<ItemsControl.ItemsPanel>
									<ItemsPanelTemplate>
										<Canvas Background="Transparent"
                                                ClipToBounds="True"
                                                Width="{Binding DataContext.SheetWidth, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                Height="{Binding DataContext.SheetHeight, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"/>
									</ItemsPanelTemplate>
								</ItemsControl.ItemsPanel>
								<ItemsControl.ItemContainerStyle>
									<Style TargetType="{x:Type ContentPresenter}">
										<Setter Property="Canvas.Left" Value="{Binding Left}"/>
										<Setter Property="Canvas.Top" Value="{Binding Top}"/>
										<Setter Property="Panel.ZIndex" Value="7"/>
									</Style>
								</ItemsControl.ItemContainerStyle>
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Grid Width="{Binding Diametro}"
                                              Height="{Binding Diametro}"
                                              IsHitTestVisible="False">
											<Ellipse Width="{Binding Diametro}"
                                                     Height="{Binding Diametro}"
                                                     Fill="{Binding FillBrush}"
                                                     Stroke="{Binding StrokeBrush}"
                                                     StrokeThickness="{Binding StrokeThickness}"
                                                     StrokeDashArray="{Binding StrokeDashArray}"
                                                     SnapsToDevicePixels="True"
                                                     IsHitTestVisible="False"/>
											<Ellipse Width="{Binding Diametro}"
                                                     Height="{Binding Diametro}"
                                                     Fill="Transparent"
                                                     Stroke="DodgerBlue"
                                                     StrokeThickness="{Binding SelectionStrokeThickness}"
                                                     StrokeDashArray="{Binding StrokeDashArray}"
                                                     SnapsToDevicePixels="True"
                                                     IsHitTestVisible="False">
												<Ellipse.Style>
													<Style TargetType="{x:Type Ellipse}">
														<Setter Property="Visibility" Value="Collapsed"/>
														<Style.Triggers>
															<DataTrigger Binding="{Binding IsSelected}" Value="True">
																<Setter Property="Visibility" Value="Visible"/>
															</DataTrigger>
														</Style.Triggers>
													</Style>
												</Ellipse.Style>
											</Ellipse>
										</Grid>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
							<ItemsControl ItemsSource="{Binding Rectangles}"
                                          Width="{Binding SheetWidth}"
                                          Height="{Binding SheetHeight}"
                                          ClipToBounds="True"
                                          IsHitTestVisible="False"
                                          Panel.ZIndex="8">
								<ItemsControl.ItemsPanel>
									<ItemsPanelTemplate>
										<Canvas Background="Transparent"
                                                ClipToBounds="True"
                                                Width="{Binding DataContext.SheetWidth, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                Height="{Binding DataContext.SheetHeight, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"/>
									</ItemsPanelTemplate>
								</ItemsControl.ItemsPanel>
								<ItemsControl.ItemContainerStyle>
									<Style TargetType="{x:Type ContentPresenter}">
										<Setter Property="Canvas.Left" Value="{Binding X}"/>
										<Setter Property="Canvas.Top" Value="{Binding Y}"/>
										<Setter Property="Panel.ZIndex" Value="8"/>
									</Style>
								</ItemsControl.ItemContainerStyle>
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Rectangle Width="{Binding Largura}"
                                                   Height="{Binding Altura}"
                                                   Fill="{Binding FillBrush}"
                                                   Stroke="{Binding SelectionStrokeBrush}"
                                                   StrokeThickness="{Binding SelectionStrokeThickness}"
                                                   StrokeDashArray="{Binding StrokeDashArray}"
                                                   SnapsToDevicePixels="True"
                                                   IsHitTestVisible="False"/>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
							<ItemsControl ItemsSource="{Binding Lines}"
                                          Width="{Binding SheetWidth}"
                                          Height="{Binding SheetHeight}"
                                          ClipToBounds="True"
                                          IsHitTestVisible="False"
                                          Panel.ZIndex="10">
								<ItemsControl.ItemsPanel>
									<ItemsPanelTemplate>
										<Canvas Background="Transparent"
                                                ClipToBounds="True"
                                                Width="{Binding DataContext.SheetWidth, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                Height="{Binding DataContext.SheetHeight, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"/>
									</ItemsPanelTemplate>
								</ItemsControl.ItemsPanel>
								<ItemsControl.ItemContainerStyle>
									<Style TargetType="{x:Type ContentPresenter}">
										<Setter Property="Canvas.Left" Value="0"/>
										<Setter Property="Canvas.Top" Value="0"/>
									</Style>
								</ItemsControl.ItemContainerStyle>
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Canvas Width="{Binding DataContext.SheetWidth, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                Height="{Binding DataContext.SheetHeight, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                Background="Transparent"
                                                ClipToBounds="False">
											<Line X1="{Binding X1}"
                                                  Y1="{Binding Y1}"
                                                  X2="{Binding X2}"
                                                  Y2="{Binding Y2}"
                                                  Stroke="{Binding SelectionStrokeBrush}"
                                                  StrokeThickness="{Binding SelectionStrokeThickness}"
                                                  StrokeDashArray="{Binding StrokeDashArray}"
                                                  StrokeStartLineCap="Square"
                                                  StrokeEndLineCap="Square"
                                                  IsHitTestVisible="False"/>
										</Canvas>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
							<ItemsControl ItemsSource="{Binding Texts}"
                                          Width="{Binding SheetWidth}"
                                          Height="{Binding SheetHeight}"
                                          ClipToBounds="True"
                                          IsHitTestVisible="False"
                                          Panel.ZIndex="20">
								<ItemsControl.ItemsPanel>
									<ItemsPanelTemplate>
										<Canvas Background="Transparent"
                                                ClipToBounds="True"
                                                Width="{Binding DataContext.SheetWidth, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                Height="{Binding DataContext.SheetHeight, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"/>
									</ItemsPanelTemplate>
								</ItemsControl.ItemsPanel>
								<ItemsControl.ItemContainerStyle>
									<Style TargetType="{x:Type ContentPresenter}">
										<Setter Property="Canvas.Left" Value="{Binding X}"/>
										<Setter Property="Canvas.Top" Value="{Binding Y}"/>
										<Setter Property="Panel.ZIndex" Value="20"/>
									</Style>
								</ItemsControl.ItemContainerStyle>
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Border Width="{Binding LarguraCaixa}"
                                                MinHeight="{Binding AlturaEstimada}"
                                                Background="Transparent"
                                                RenderTransform="{Binding RenderTransform}"
                                                RenderTransformOrigin="0,0"
                                                IsHitTestVisible="False">
											<TextBlock Text="{Binding Conteudo}"
                                                       Width="{Binding LarguraCaixa}"
                                                       MinHeight="{Binding AlturaEstimada}"
                                                       Foreground="{Binding ForegroundBrush}"
                                                       FontFamily="{Binding FontFamily}"
                                                       FontSize="{Binding AlturaTexto}"
                                                       LineHeight="{Binding LineHeight}"
                                                       TextAlignment="{Binding TextAlignment}"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="None"
                                                       SnapsToDevicePixels="True"
                                                       IsHitTestVisible="False"/>
										</Border>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
							<ItemsControl x:Name="TemplateEndpointHandlesOverlay"
                                          ItemsSource="{Binding EndpointHandles}"
                                          Width="{Binding SheetWidth}"
                                          Height="{Binding SheetHeight}"
                                          ClipToBounds="False"
                                          IsHitTestVisible="False"
                                          Panel.ZIndex="30">
								<ItemsControl.Style>
									<Style TargetType="{x:Type ItemsControl}">
										<Setter Property="Visibility" Value="Collapsed"/>
										<Style.Triggers>
											<DataTrigger Binding="{Binding EndpointHandlesVisible}" Value="True">
												<Setter Property="Visibility" Value="Visible"/>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</ItemsControl.Style>
								<ItemsControl.ItemsPanel>
									<ItemsPanelTemplate>
										<Canvas Background="Transparent"
                                                ClipToBounds="False"
                                                Width="{Binding DataContext.SheetWidth, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                Height="{Binding DataContext.SheetHeight, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"/>
									</ItemsPanelTemplate>
								</ItemsControl.ItemsPanel>
								<ItemsControl.ItemContainerStyle>
									<Style TargetType="{x:Type ContentPresenter}">
										<Setter Property="Canvas.Left" Value="{Binding Left}"/>
										<Setter Property="Canvas.Top" Value="{Binding Top}"/>
										<Setter Property="Panel.ZIndex" Value="30"/>
									</Style>
								</ItemsControl.ItemContainerStyle>
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Ellipse Width="{Binding Size}"
                                                 Height="{Binding Size}"
                                                 Fill="{Binding Fill}"
                                                 Stroke="{Binding Stroke}"
                                                 StrokeThickness="{Binding StrokeThickness}"
                                                 SnapsToDevicePixels="True"
                                                 IsHitTestVisible="False"/>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
							<ItemsControl x:Name="TemplateRectangleResizeHandlesOverlay"
                                          ItemsSource="{Binding RectangleResizeHandles}"
                                          Width="{Binding SheetWidth}"
                                          Height="{Binding SheetHeight}"
                                          ClipToBounds="False"
                                          IsHitTestVisible="False"
                                          Panel.ZIndex="35">
								<ItemsControl.Style>
									<Style TargetType="{x:Type ItemsControl}">
										<Setter Property="Visibility" Value="Collapsed"/>
										<Style.Triggers>
											<DataTrigger Binding="{Binding RectangleResizeHandlesVisible}" Value="True">
												<Setter Property="Visibility" Value="Visible"/>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</ItemsControl.Style>
								<ItemsControl.ItemsPanel>
									<ItemsPanelTemplate>
										<Canvas Background="Transparent"
                                                ClipToBounds="False"
                                                Width="{Binding DataContext.SheetWidth, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                Height="{Binding DataContext.SheetHeight, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"/>
									</ItemsPanelTemplate>
								</ItemsControl.ItemsPanel>
								<ItemsControl.ItemContainerStyle>
									<Style TargetType="{x:Type ContentPresenter}">
										<Setter Property="Canvas.Left" Value="{Binding Left}"/>
										<Setter Property="Canvas.Top" Value="{Binding Top}"/>
										<Setter Property="Panel.ZIndex" Value="35"/>
									</Style>
								</ItemsControl.ItemContainerStyle>
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Rectangle Width="{Binding Size}"
                                                   Height="{Binding Size}"
                                                   Fill="{Binding Fill}"
                                                   Stroke="{Binding Stroke}"
                                                   StrokeThickness="{Binding StrokeThickness}"
                                                   SnapsToDevicePixels="True"
                                                   IsHitTestVisible="False"/>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
							<ItemsControl x:Name="TemplateCircleResizeHandlesOverlay"
                                          ItemsSource="{Binding CircleResizeHandles}"
                                          Width="{Binding SheetWidth}"
                                          Height="{Binding SheetHeight}"
                                          ClipToBounds="False"
                                          IsHitTestVisible="False"
                                          Panel.ZIndex="36">
								<ItemsControl.Style>
									<Style TargetType="{x:Type ItemsControl}">
										<Setter Property="Visibility" Value="Collapsed"/>
										<Style.Triggers>
											<DataTrigger Binding="{Binding CircleResizeHandlesVisible}" Value="True">
												<Setter Property="Visibility" Value="Visible"/>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</ItemsControl.Style>
								<ItemsControl.ItemsPanel>
									<ItemsPanelTemplate>
										<Canvas Background="Transparent"
                                                ClipToBounds="False"
                                                Width="{Binding DataContext.SheetWidth, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                Height="{Binding DataContext.SheetHeight, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"/>
									</ItemsPanelTemplate>
								</ItemsControl.ItemsPanel>
								<ItemsControl.ItemContainerStyle>
									<Style TargetType="{x:Type ContentPresenter}">
										<Setter Property="Canvas.Left" Value="{Binding Left}"/>
										<Setter Property="Canvas.Top" Value="{Binding Top}"/>
										<Setter Property="Panel.ZIndex" Value="36"/>
									</Style>
								</ItemsControl.ItemContainerStyle>
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Rectangle Width="{Binding Size}"
                                                   Height="{Binding Size}"
                                                   Fill="{Binding Fill}"
                                                   Stroke="{Binding Stroke}"
                                                   StrokeThickness="{Binding StrokeThickness}"
                                                   SnapsToDevicePixels="True"
                                                   IsHitTestVisible="False"/>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
							<Canvas Width="{Binding SheetWidth}"
                                    Height="{Binding SheetHeight}"
                                    Background="Transparent"
                                    ClipToBounds="True"
                                    IsHitTestVisible="False"
                                    Panel.ZIndex="41">
								<Canvas.Style>
									<Style TargetType="{x:Type Canvas}">
										<Setter Property="Visibility" Value="Collapsed"/>
										<Style.Triggers>
											<DataTrigger Binding="{Binding HasPreviewCircle}" Value="True">
												<Setter Property="Visibility" Value="Visible"/>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</Canvas.Style>
								<Ellipse Canvas.Left="{Binding PreviewCircle.Left, TargetNullValue=0}"
                                         Canvas.Top="{Binding PreviewCircle.Top, TargetNullValue=0}"
                                         Width="{Binding PreviewCircle.Diametro, TargetNullValue=0}"
                                         Height="{Binding PreviewCircle.Diametro, TargetNullValue=0}"
                                         Fill="{Binding PreviewCircle.FillBrush}"
                                         Stroke="#FF1E90FF"
                                         StrokeThickness="1"
                                         StrokeDashArray="4 2"
                                         SnapsToDevicePixels="True"
                                         IsHitTestVisible="False"/>
							</Canvas>
							<Canvas Width="{Binding SheetWidth}"
                                    Height="{Binding SheetHeight}"
                                    Background="Transparent"
                                    ClipToBounds="True"
                                    IsHitTestVisible="False"
                                    Panel.ZIndex="42">
								<Canvas.Style>
									<Style TargetType="{x:Type Canvas}">
										<Setter Property="Visibility" Value="Collapsed"/>
										<Style.Triggers>
											<DataTrigger Binding="{Binding HasPreviewRectangle}" Value="True">
												<Setter Property="Visibility" Value="Visible"/>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</Canvas.Style>
								<Rectangle Canvas.Left="{Binding PreviewRectangle.X, TargetNullValue=0}"
                                           Canvas.Top="{Binding PreviewRectangle.Y, TargetNullValue=0}"
                                           Width="{Binding PreviewRectangle.Largura, TargetNullValue=0}"
                                           Height="{Binding PreviewRectangle.Altura, TargetNullValue=0}"
                                           Fill="{Binding PreviewRectangle.FillBrush}"
                                           Stroke="#FF1E90FF"
                                           StrokeThickness="1"
                                           StrokeDashArray="4 2"
                                           SnapsToDevicePixels="True"
                                           IsHitTestVisible="False"/>
							</Canvas>
							<Line X1="{Binding PreviewLine.X1, TargetNullValue=0}"
                                  Y1="{Binding PreviewLine.Y1, TargetNullValue=0}"
                                  X2="{Binding PreviewLine.X2, TargetNullValue=0}"
                                  Y2="{Binding PreviewLine.Y2, TargetNullValue=0}"
                                  Stroke="#FF1E90FF"
                                  StrokeThickness="{Binding PreviewLine.StrokeThickness, TargetNullValue=1}"
                                  StrokeDashArray="4 2"
                                  IsHitTestVisible="False"
                                  Panel.ZIndex="40">
								<Line.Style>
									<Style TargetType="Line">
										<Setter Property="Visibility" Value="Collapsed"/>
										<Style.Triggers>
											<DataTrigger Binding="{Binding HasPreviewLine}" Value="True">
												<Setter Property="Visibility" Value="Visible"/>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</Line.Style>
							</Line>
						</Grid>
					</Border>
				</Canvas>
			</ScrollViewer>
		</Grid>
	</Border>
</UserControl>