<UserControl x:Class="Araci.Properties.CargaPropertiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#252526">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->

        <Border Background="#2D2D30"
                BorderBrush="#3E3E42"
                BorderThickness="0,0,0,1"
                Padding="12">

            <TextBlock Text="PROPRIEDADES DA CARGA"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="White"/>
        </Border>

        <!-- CONTEÚDO -->

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">

            <Grid Margin="12">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- NOME -->

                <TextBlock Text="Nome"
                           Foreground="#CCCCCC"
                           Margin="0,0,10,12"/>

                <TextBox Grid.Column="1"
                         Margin="0,0,0,12"
                         Text="{Binding Nome, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- BARRA -->

                <TextBlock Grid.Row="1"
                           Text="Barra"
                           Foreground="#CCCCCC"
                           Margin="0,0,10,12"/>

                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Margin="0,0,0,12"
                         Text="{Binding Barra, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- POTÊNCIA -->

                <TextBlock Grid.Row="2"
                           Text="Potência kW"
                           Foreground="#CCCCCC"
                           Margin="0,0,10,12"/>

                <TextBox Grid.Row="2"
                         Grid.Column="1"
                         Margin="0,0,0,12"
                         Text="{Binding PotenciaAtivaKW, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- TENSÃO -->

                <TextBlock Grid.Row="3"
                           Text="Tensão kV"
                           Foreground="#CCCCCC"
                           Margin="0,0,10,12"/>

                <TextBox Grid.Row="3"
                         Grid.Column="1"
                         Margin="0,0,0,12"
                         Text="{Binding TensaoKV, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- CONEXÃO -->

                <TextBlock Grid.Row="4"
                           Text="Conexão"
                           Foreground="#CCCCCC"
                           Margin="0,0,10,12"/>

                <TextBox Grid.Row="4"
                         Grid.Column="1"
                         Margin="0,0,0,12"
                         Text="{Binding Conexao, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            </Grid>

        </ScrollViewer>

    </Grid>

</UserControl>