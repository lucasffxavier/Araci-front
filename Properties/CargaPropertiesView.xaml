<UserControl x:Class="Araci.Properties.CargaPropertiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#252526">

        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <StackPanel Margin="12">

                <!-- HEADER -->

                <TextBlock Text="PROPRIEDADES DA CARGA"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Margin="0,0,0,20"/>

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- TIPO -->

                    <ComboBox Grid.ColumnSpan="2"
                              Margin="0,0,0,12"
                              ItemsSource="{Binding TiposDisponiveis}"
                              SelectedItem="{Binding Tipo}"
                              DisplayMemberPath="NomeTipo"/>

                    <Button Grid.Row="1"
                            Grid.ColumnSpan="2"
                            Content="Visualizar propriedades de tipo"
                            Height="32"
                            Margin="0,0,0,20"
                            Command="{Binding AbrirPropriedadesTipoCommand}"/>

                    <!-- NOME -->

                    <TextBlock Grid.Row="2"
                               Text="Nome"
                               Foreground="#CCCCCC"
                               VerticalAlignment="Center"
                               Margin="0,0,10,12"/>

                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Text="{Binding Nome}"
                             Margin="0,0,0,12"/>

                    <!-- BARRA -->

                    <TextBlock Grid.Row="3"
                               Text="Barra"
                               Foreground="#CCCCCC"
                               VerticalAlignment="Center"
                               Margin="0,0,10,12"/>

                    <TextBox Grid.Row="3"
                             Grid.Column="1"
                             Text="{Binding Barra}"
                             Margin="0,0,0,12"/>

                    <!-- ALIMENTADOR -->

                    <TextBlock Grid.Row="4"
                               Text="Alimentador"
                               Foreground="#CCCCCC"
                               VerticalAlignment="Center"
                               Margin="0,0,10,12"/>

                    <TextBox Grid.Row="4"
                             Grid.Column="1"
                             Text="{Binding Alimentador}"
                             Margin="0,0,0,12"/>

                    <!-- POTENCIA ATIVA -->

                    <TextBlock Grid.Row="5"
                               Text="Potencia ativa"
                               Foreground="#CCCCCC"
                               VerticalAlignment="Center"
                               Margin="0,0,10,12"/>

                    <TextBox Grid.Row="5"
                             Grid.Column="1"
                             Text="{Binding PotenciaAtivaKW}"
                             Margin="0,0,0,12"/>

                    <!-- POTENCIA REATIVA -->

                    <TextBlock Grid.Row="6"
                               Text="Potencia reativa"
                               Foreground="#CCCCCC"
                               VerticalAlignment="Center"
                               Margin="0,0,10,12"/>

                    <TextBox Grid.Row="6"
                             Grid.Column="1"
                             Text="{Binding PotenciaReativaKvar}"
                             Margin="0,0,0,12"/>

                </Grid>

            </StackPanel>

        </ScrollViewer>

    </Grid>

</UserControl>
