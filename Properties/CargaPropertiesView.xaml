<UserControl x:Class="Araci.Properties.CargaPropertiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:props="clr-namespace:Araci.Properties">
    <UserControl.Resources>
        <props:UnitValueConverter x:Key="UnitValueConverter"/>
    </UserControl.Resources>
    <Grid Style="{StaticResource PropertyRootGridStyle}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Style="{StaticResource PropertyPanelStackStyle}">
                <TextBlock Text="CARGA" Style="{StaticResource PropertyHeaderTextBlockStyle}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ComboBox Grid.ColumnSpan="2" Style="{StaticResource PropertyFullComboBoxStyle}" ItemsSource="{Binding TiposDisponiveis}" SelectedItem="{Binding Tipo}" DisplayMemberPath="NomeTipo"/>
                    <Button Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource PropertyFullButtonStyle}" Content="Visualizar propriedades de tipo" Command="{Binding AbrirPropriedadesTipoCommand}"/>
                    <TextBlock Grid.Row="2" Text="Nome" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Nome}" Style="{StaticResource PropertyReadOnlyTextBoxStyle}"/>
                    <TextBlock Grid.Row="3" Text="Potência ativa" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding PotenciaAtiva, Mode=TwoWay, UpdateSourceTrigger=LostFocus, Converter={StaticResource UnitValueConverter}, ConverterParameter=ActivePowerKW, ValidatesOnDataErrors=True, ValidatesOnExceptions=True, NotifyOnValidationError=True}" Style="{StaticResource PropertyNumericTextBoxStyle}"/>
                    <TextBlock Grid.Row="4" Text="Potência reativa" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding PotenciaReativa, Mode=TwoWay, UpdateSourceTrigger=LostFocus, Converter={StaticResource UnitValueConverter}, ConverterParameter=ReactivePowerKVAr, ValidatesOnDataErrors=True, ValidatesOnExceptions=True, NotifyOnValidationError=True}" Style="{StaticResource PropertyNumericTextBoxStyle}"/>
                    <TextBlock Grid.Row="5" Text="Alimentador" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Alimentador, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, ValidatesOnExceptions=True, NotifyOnValidationError=True}" Style="{StaticResource PropertyNumericTextBoxStyle}"/>
                    <TextBlock Grid.Row="6" Text="Corrente linha" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                    <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding CorrenteLinha, Mode=TwoWay, UpdateSourceTrigger=LostFocus, Converter={StaticResource UnitValueConverter}, ConverterParameter=CurrentAmpere}" Style="{StaticResource PropertyNumericTextBoxStyle}"/>
                    <TextBlock Grid.Row="7" Text="Corrente fase A" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                    <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding CorrenteFaseA, Mode=TwoWay, UpdateSourceTrigger=LostFocus, Converter={StaticResource UnitValueConverter}, ConverterParameter=CurrentAmpere}" Style="{StaticResource PropertyNumericTextBoxStyle}"/>
                    <TextBlock Grid.Row="8" Text="Corrente fase B" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                    <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding CorrenteFaseB, Mode=TwoWay, UpdateSourceTrigger=LostFocus, Converter={StaticResource UnitValueConverter}, ConverterParameter=CurrentAmpere}" Style="{StaticResource PropertyNumericTextBoxStyle}"/>
                    <TextBlock Grid.Row="9" Text="Corrente fase C" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                    <TextBox Grid.Row="9" Grid.Column="1" Text="{Binding CorrenteFaseC, Mode=TwoWay, UpdateSourceTrigger=LostFocus, Converter={StaticResource UnitValueConverter}, ConverterParameter=CurrentAmpere}" Style="{StaticResource PropertyNumericTextBoxStyle}"/>
                    <TextBlock Grid.Row="10" Text="Tensão linha" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                    <TextBox Grid.Row="10" Grid.Column="1" Text="{Binding TensaoLinha, Mode=TwoWay, UpdateSourceTrigger=LostFocus, Converter={StaticResource UnitValueConverter}, ConverterParameter=VoltageKV}" Style="{StaticResource PropertyNumericTextBoxStyle}"/>
                    <TextBlock Grid.Row="11" Text="Tensão fase A" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                    <TextBox Grid.Row="11" Grid.Column="1" Text="{Binding TensaoFaseA, Mode=TwoWay, UpdateSourceTrigger=LostFocus, Converter={StaticResource UnitValueConverter}, ConverterParameter=VoltageKV}" Style="{StaticResource PropertyNumericTextBoxStyle}"/>
                    <TextBlock Grid.Row="12" Text="Tensão fase B" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                    <TextBox Grid.Row="12" Grid.Column="1" Text="{Binding TensaoFaseB, Mode=TwoWay, UpdateSourceTrigger=LostFocus, Converter={StaticResource UnitValueConverter}, ConverterParameter=VoltageKV}" Style="{StaticResource PropertyNumericTextBoxStyle}"/>
                    <TextBlock Grid.Row="13" Text="Tensão fase C" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                    <TextBox Grid.Row="13" Grid.Column="1" Text="{Binding TensaoFaseC, Mode=TwoWay, UpdateSourceTrigger=LostFocus, Converter={StaticResource UnitValueConverter}, ConverterParameter=VoltageKV}" Style="{StaticResource PropertyNumericTextBoxStyle}"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>