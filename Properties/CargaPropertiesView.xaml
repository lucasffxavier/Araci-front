<UserControl x:Class="Araci.Properties.CargaPropertiesView"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#252526">

        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <StackPanel Margin="12">

                <TextBlock Text="PROPRIEDADES DA CARGA"
                       Style="{StaticResource PropertyHeaderTextBlockStyle}"/>

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ComboBox Grid.ColumnSpan="2"
                          Style="{StaticResource PropertyFullComboBoxStyle}"
                          ItemsSource="{Binding TiposDisponiveis}"
                          SelectedItem="{Binding Tipo}"
                          DisplayMemberPath="NomeTipo"/>

                    <Button Grid.Row="1"
                        Grid.ColumnSpan="2"
                        Style="{StaticResource PropertyFullButtonStyle}"
                        Content="Visualizar propriedades de tipo"
                        Command="{Binding AbrirPropriedadesTipoCommand}"/>

                    <TextBlock Grid.Row="2"
                           Text="Nome"
                           Style="{StaticResource PropertyLabelTextBlockStyle}"/>

                    <TextBox Grid.Row="2"
                         Grid.Column="1"
                         Text="{Binding Nome}"
                         Style="{StaticResource PropertyValueTextBoxStyle}"/>

                    <TextBlock Grid.Row="3"
                           Text="Alimentador"
                           Style="{StaticResource PropertyLabelTextBlockStyle}"/>

                    <TextBox Grid.Row="3"
                         Grid.Column="1"
                         Text="{Binding Alimentador}"
                         Style="{StaticResource PropertyValueTextBoxStyle}"/>

                    <TextBlock Grid.Row="4"
                           Text="Potencia ativa"
                           Style="{StaticResource PropertyLabelTextBlockStyle}"/>

                    <TextBox Grid.Row="4"
                         Grid.Column="1"
                         Text="{Binding PotenciaAtivaKW,
                         ValidatesOnDataErrors=True,
                         ValidatesOnExceptions=True,
                         NotifyOnValidationError=True}"
                         Style="{StaticResource PropertyNumericTextBoxStyle}"/>

                    <TextBlock Grid.Row="5"
                           Text="Potencia reativa"
                           Style="{StaticResource PropertyLabelTextBlockStyle}"/>

                    <TextBox Grid.Row="5"
                         Grid.Column="1"
                         Text="{Binding PotenciaReativaKvar,
                         ValidatesOnDataErrors=True,
                         ValidatesOnExceptions=True,
                         NotifyOnValidationError=True}"
                         Style="{StaticResource PropertyNumericTextBoxStyle}"/>

                </Grid>

            </StackPanel>

        </ScrollViewer>

    </Grid>
</UserControl>