<Window x:Class="Araci.Properties.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Selecionar cor"
        Width="460"
        Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#252526">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Cor hexadecimal"
                   Foreground="#F4F4F4"
                   Margin="0,0,0,6"/>

        <TextBox x:Name="HexTextBox"
                 Grid.Row="1"
                 Height="26"
                 TextChanged="OnHexTextChanged"/>

        <Border Grid.Row="2"
                Height="38"
                Margin="0,10,0,10"
                BorderBrush="#A0A0A0"
                BorderThickness="1"
                Background="{Binding ElementName=PreviewFill, Path=Background}">
            <TextBlock x:Name="ValidationText"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="#252526"
                       FontWeight="SemiBold"/>
        </Border>

        <Border x:Name="PreviewFill" Visibility="Collapsed"/>

        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <UniformGrid Columns="6" Rows="1" Margin="0,0,0,10">
                <Button Content="Preto" Tag="#FF000000" Margin="2" Click="OnColorClick"/>
                <Button Content="Vermelho" Tag="#FFFF0000" Margin="2" Click="OnColorClick"/>
                <Button Content="Verde" Tag="#FF00AA00" Margin="2" Click="OnColorClick"/>
                <Button Content="Azul" Tag="#FF0066CC" Margin="2" Click="OnColorClick"/>
                <Button Content="Cinza" Tag="#FF808080" Margin="2" Click="OnColorClick"/>
                <Button Content="Branco" Tag="#FFFFFFFF" Margin="2" Click="OnColorClick"/>
            </UniformGrid>

            <Border BorderBrush="#4A4A4A"
                    BorderThickness="1"
                    Background="#1E1E1E"
                    Padding="6">
                <ScrollViewer Height="300"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="ColorPaletteItemsControl"
                                  ItemsSource="{Binding PaletteColors}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="12"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Width="28"
                                        Height="24"
                                        Margin="2"
                                        Padding="0"
                                        BorderBrush="#3A3A3A"
                                        BorderThickness="1"
                                        Background="{Binding Brush}"
                                        Tag="{Binding Hex}"
                                        ToolTip="{Binding Hex}"
                                        Click="OnColorClick"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="OkButton"
                    Content="OK"
                    Width="76"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="OnOkClick"/>
            <Button Content="Cancelar"
                    Width="86"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
