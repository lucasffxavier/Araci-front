<Window x:Class="Araci.Properties.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Selecionar cor"
        Width="720"
        Height="760"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#252526">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Cor hexadecimal"
                   Foreground="#F4F4F4"
                   Margin="0,0,0,6"/>

        <TextBox x:Name="HexTextBox"
                 Grid.Row="1"
                 Height="26"
                 TextChanged="OnHexTextChanged"/>

        <Border Grid.Row="2"
                Height="38"
                Margin="0,10,0,10"
                BorderBrush="#A0A0A0"
                BorderThickness="1"
                Background="{Binding ElementName=PreviewFill, Path=Background}">
            <TextBlock x:Name="ValidationText"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="#252526"
                       FontWeight="SemiBold"/>
        </Border>

        <Border x:Name="PreviewFill" Visibility="Collapsed"/>

        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <WrapPanel Margin="0,0,0,10">
                <Button Width="24" Height="24" Margin="2" Padding="0" Tag="#FF000000" Background="#FF000000" ToolTip="#FF000000" Click="OnColorClick"/>
                <Button Width="24" Height="24" Margin="2" Padding="0" Tag="#FFFFFFFF" Background="#FFFFFFFF" ToolTip="#FFFFFFFF" Click="OnColorClick"/>
                <Button Width="24" Height="24" Margin="2" Padding="0" Tag="#FFFF0000" Background="#FFFF0000" ToolTip="#FFFF0000" Click="OnColorClick"/>
                <Button Width="24" Height="24" Margin="2" Padding="0" Tag="#FFFF8000" Background="#FFFF8000" ToolTip="#FFFF8000" Click="OnColorClick"/>
                <Button Width="24" Height="24" Margin="2" Padding="0" Tag="#FFFFFF00" Background="#FFFFFF00" ToolTip="#FFFFFF00" Click="OnColorClick"/>
                <Button Width="24" Height="24" Margin="2" Padding="0" Tag="#FF00AA00" Background="#FF00AA00" ToolTip="#FF00AA00" Click="OnColorClick"/>
                <Button Width="24" Height="24" Margin="2" Padding="0" Tag="#FF00FFFF" Background="#FF00FFFF" ToolTip="#FF00FFFF" Click="OnColorClick"/>
                <Button Width="24" Height="24" Margin="2" Padding="0" Tag="#FF0066CC" Background="#FF0066CC" ToolTip="#FF0066CC" Click="OnColorClick"/>
                <Button Width="24" Height="24" Margin="2" Padding="0" Tag="#FFFF00FF" Background="#FFFF00FF" ToolTip="#FFFF00FF" Click="OnColorClick"/>
                <Button Width="24" Height="24" Margin="2" Padding="0" Tag="#FF808080" Background="#FF808080" ToolTip="#FF808080" Click="OnColorClick"/>
            </WrapPanel>

            <ItemsControl x:Name="ColorPaletteItemsControl"
                          ItemsSource="{Binding PaletteColors}"
                          HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas Width="{Binding PaletteWidth}"
                                Height="{Binding PaletteHeight}"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Width="{Binding Width}"
                                Height="{Binding Height}"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Tag="{Binding Hex}"
                                ToolTip="{Binding Hex}"
                                Click="OnColorClick">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Polygon Points="{Binding Points}"
                                             Fill="{Binding Brush}"
                                             Stroke="#F2F2F2"
                                             StrokeThickness="1.4"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="OkButton"
                    Content="OK"
                    Width="76"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="OnOkClick"/>
            <Button Content="Cancelar"
                    Width="86"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
