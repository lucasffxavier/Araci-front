<Window x:Class="Araci.Properties.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Selecionar cor"
        Width="520"
        Height="570"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F2F2F2">
	<Grid Margin="14">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<TextBlock Grid.Row="0"
                   Text="Cores rápidas"
                   Foreground="#1F2933"
                   FontWeight="SemiBold"
                   Margin="0,0,0,6"/>

		<WrapPanel Grid.Row="1" Margin="0,0,0,12">
			<Button Width="24" Height="24" Margin="2" Padding="0" Tag="#FF000000" Background="#FF000000" ToolTip="#FF000000" Click="OnColorClick"/>
			<Button Width="24" Height="24" Margin="2" Padding="0" Tag="#FFFF0000" Background="#FFFF0000" ToolTip="#FFFF0000" Click="OnColorClick"/>
			<Button Width="24" Height="24" Margin="2" Padding="0" Tag="#FFFFFF00" Background="#FFFFFF00" ToolTip="#FFFFFF00" Click="OnColorClick"/>
			<Button Width="24" Height="24" Margin="2" Padding="0" Tag="#FF00FF00" Background="#FF00FF00" ToolTip="#FF00FF00" Click="OnColorClick"/>
			<Button Width="24" Height="24" Margin="2" Padding="0" Tag="#FF00FFFF" Background="#FF00FFFF" ToolTip="#FF00FFFF" Click="OnColorClick"/>
			<Button Width="24" Height="24" Margin="2" Padding="0" Tag="#FF0000FF" Background="#FF0000FF" ToolTip="#FF0000FF" Click="OnColorClick"/>
			<Button Width="24" Height="24" Margin="2" Padding="0" Tag="#FFFF00FF" Background="#FFFF00FF" ToolTip="#FFFF00FF" Click="OnColorClick"/>
			<Button Width="24" Height="24" Margin="2" Padding="0" Tag="#FFFFFFFF" Background="#FFFFFFFF" ToolTip="#FFFFFFFF" Click="OnColorClick"/>
			<Button Width="24" Height="24" Margin="2" Padding="0" Tag="#FFE0E6EA" Background="#FFE0E6EA" ToolTip="#FFE0E6EA" Click="OnColorClick"/>
			<Button Width="24" Height="24" Margin="2" Padding="0" Tag="#FF808080" Background="#FF808080" ToolTip="#FF808080" Click="OnColorClick"/>
			<Button Width="24" Height="24" Margin="2" Padding="0" Tag="#FF303030" Background="#FF303030" ToolTip="#FF303030" Click="OnColorClick"/>
			<Button Width="24" Height="24" Margin="2" Padding="0" Tag="#FF2F363D" Background="#FF2F363D" ToolTip="#FF2F363D" Click="OnColorClick"/>
			<Button Width="24" Height="24" Margin="2" Padding="0" Tag="#FFDDE5EA" Background="#FFDDE5EA" ToolTip="#FFDDE5EA" Click="OnColorClick"/>
			<Button Width="24" Height="24" Margin="2" Padding="0" Tag="#FFF3F6F8" Background="#FFF3F6F8" ToolTip="#FFF3F6F8" Click="OnColorClick"/>
			<Button Width="24" Height="24" Margin="2" Padding="0" Tag="#FF1E90FF" Background="#FF1E90FF" ToolTip="#FF1E90FF" Click="OnColorClick"/>
			<Button Width="24" Height="24" Margin="2" Padding="0" Tag="#FF0066CC" Background="#FF0066CC" ToolTip="#FF0066CC" Click="OnColorClick"/>
		</WrapPanel>

		<Grid Grid.Row="2" Margin="0,0,0,12">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="300"/>
				<ColumnDefinition Width="12"/>
				<ColumnDefinition Width="24"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>

			<Border Grid.Column="0"
                    BorderBrush="#C8C8C8"
                    BorderThickness="1"
                    Background="#FFFFFF">
				<Grid>
					<Image x:Name="PaletteImage"
                           Width="300"
                           Height="230"
                           Stretch="Fill"
                           MouseLeftButtonDown="OnPaletteMouseLeftButtonDown"
                           MouseMove="OnPaletteMouseMove"/>
					<Canvas x:Name="PaletteMarkerLayer"
                            Width="300"
                            Height="230"
                            IsHitTestVisible="False">
						<Ellipse x:Name="PaletteMarker"
                                 Width="12"
                                 Height="12"
                                 Stroke="#202020"
                                 StrokeThickness="1.4"
                                 Fill="Transparent"/>
						<Ellipse Width="8"
                                 Height="8"
                                 Stroke="#FFFFFF"
                                 StrokeThickness="1"
                                 Fill="Transparent"
                                 Canvas.Left="2"
                                 Canvas.Top="2"/>
					</Canvas>
				</Grid>
			</Border>

			<Border Grid.Column="2"
                    BorderBrush="#C8C8C8"
                    BorderThickness="1"
                    Background="#FFFFFF">
				<Grid>
					<Image x:Name="LuminosityImage"
                           Width="24"
                           Height="230"
                           Stretch="Fill"
                           MouseLeftButtonDown="OnLuminosityMouseLeftButtonDown"
                           MouseMove="OnLuminosityMouseMove"/>
					<Canvas x:Name="LuminosityMarkerLayer"
                            Width="24"
                            Height="230"
                            IsHitTestVisible="False">
						<Rectangle x:Name="LuminosityMarker"
                                   Width="28"
                                   Height="3"
                                   Fill="#202020"
                                   Stroke="#FFFFFF"
                                   StrokeThickness="1"
                                   Canvas.Left="-2"/>
					</Canvas>
				</Grid>
			</Border>

			<Grid Grid.Column="3" Margin="14,0,0,0">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="92"/>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>

				<TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Hexadecimal" FontWeight="SemiBold" Foreground="#1F2933" Margin="0,0,0,6"/>
				<TextBox Grid.Row="1" Grid.ColumnSpan="2" x:Name="HexTextBox" Height="26" TextChanged="OnHexTextChanged" Margin="0,0,0,10"/>

				<TextBlock Grid.Row="2" Text="Matiz" VerticalAlignment="Center" Margin="0,0,8,5"/>
				<TextBox Grid.Row="2" Grid.Column="1" x:Name="HueTextBox" Height="24" TextChanged="OnHsvTextChanged" Margin="0,0,0,5"/>
				<TextBlock Grid.Row="3" Text="Saturação" VerticalAlignment="Center" Margin="0,0,8,5"/>
				<TextBox Grid.Row="3" Grid.Column="1" x:Name="SaturationTextBox" Height="24" TextChanged="OnHsvTextChanged" Margin="0,0,0,5"/>
				<TextBlock Grid.Row="4" Text="Luminosidade" VerticalAlignment="Center" Margin="0,0,8,12"/>
				<TextBox Grid.Row="4" Grid.Column="1" x:Name="ValueTextBox" Height="24" TextChanged="OnHsvTextChanged" Margin="0,0,0,12"/>

				<TextBlock Grid.Row="5" Text="Vermelho" VerticalAlignment="Center" Margin="0,0,8,5"/>
				<TextBox Grid.Row="5" Grid.Column="1" x:Name="RedTextBox" Height="24" TextChanged="OnRgbTextChanged" Margin="0,0,0,5"/>
				<TextBlock Grid.Row="6" Text="Verde" VerticalAlignment="Center" Margin="0,0,8,5"/>
				<TextBox Grid.Row="6" Grid.Column="1" x:Name="GreenTextBox" Height="24" TextChanged="OnRgbTextChanged" Margin="0,0,0,5"/>
				<TextBlock Grid.Row="7" Text="Azul" VerticalAlignment="Center" Margin="0,0,8,0"/>
				<TextBox Grid.Row="7" Grid.Column="1" x:Name="BlueTextBox" Height="24" TextChanged="OnRgbTextChanged"/>
			</Grid>
		</Grid>

		<Grid Grid.Row="3" Margin="0,0,0,10">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>
			<GroupBox Header="Original" Margin="0,0,6,0">
				<Border x:Name="OriginalPreviewBorder"
                        Height="52"
                        Margin="8"
                        BorderBrush="#707070"
                        BorderThickness="1"/>
			</GroupBox>
			<GroupBox Grid.Column="1" Header="Novo" Margin="6,0,0,0">
				<Border x:Name="NewPreviewBorder"
                        Height="52"
                        Margin="8"
                        BorderBrush="#707070"
                        BorderThickness="1"/>
			</GroupBox>
		</Grid>

		<TextBlock Grid.Row="4"
                   x:Name="ValidationText"
                   Foreground="#C0392B"
                   VerticalAlignment="Top"/>

		<StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
			<Button x:Name="OkButton"
                    Content="OK"
                    Width="82"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="OnOkClick"/>
			<Button Content="Cancelar"
                    Width="88"
                    IsCancel="True"/>
		</StackPanel>
	</Grid>
</Window>