<UserControl x:Class="Araci.Properties.PropertiesHostView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:Araci.ViewModels">
	<UserControl.Resources>
		<BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

		<Style x:Key="LightComboBoxItemStyle" TargetType="{x:Type ComboBoxItem}">
			<Setter Property="Foreground" Value="#FF000000"/>
			<Setter Property="Background" Value="#FFFFFFFF"/>
			<Setter Property="Padding" Value="4,2"/>
			<Style.Triggers>
				<Trigger Property="IsHighlighted" Value="True">
					<Setter Property="Background" Value="#FFE5F1FB"/>
					<Setter Property="Foreground" Value="#FF000000"/>
				</Trigger>
				<Trigger Property="IsSelected" Value="True">
					<Setter Property="Background" Value="#FFDCEBFA"/>
					<Setter Property="Foreground" Value="#FF000000"/>
				</Trigger>
			</Style.Triggers>
		</Style>

		<DataTemplate x:Key="BooleanComboBoxSelectedTemplate">
			<TextBlock Text="{Binding DisplayName}"
                       Foreground="#FF000000"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
		</DataTemplate>

		<DataTemplate x:Key="TypeComboBoxSelectedTemplate">
			<TextBlock Text="{Binding NomeTipo}"
                       Foreground="#FF000000"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
		</DataTemplate>

		<DataTemplate x:Key="DefaultPropertyEditorTemplate" DataType="{x:Type viewModels:PropertyDescriptorViewModel}">
			<TextBox Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                     IsReadOnly="{Binding IsReadOnly}"
                     MinHeight="24"
                     Padding="5,2"
                     VerticalContentAlignment="Center"
                     Background="#FFFFFFFF"
                     Foreground="#FF000000"
                     BorderBrush="#3A3A3A"
                     BorderThickness="1"/>
		</DataTemplate>

		<DataTemplate x:Key="BooleanPropertyEditorTemplate" DataType="{x:Type viewModels:PropertyDescriptorViewModel}">
			<ComboBox ItemsSource="{Binding BooleanOptions}"
                      SelectedValue="{Binding BooleanValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      SelectedValuePath="Value"
                      ItemTemplate="{StaticResource BooleanComboBoxSelectedTemplate}"
                      ItemContainerStyle="{StaticResource LightComboBoxItemStyle}"
                      IsEnabled="{Binding IsEditable}"
                      MinHeight="24"
                      Padding="4,1"
                      Background="#FFFFFFFF"
                      Foreground="#FF000000"
                      BorderBrush="#3A3A3A"
                      BorderThickness="1"/>
		</DataTemplate>

		<DataTemplate x:Key="ColorPropertyEditorTemplate" DataType="{x:Type viewModels:PropertyDescriptorViewModel}">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="24"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="28"/>
				</Grid.ColumnDefinitions>
				<Border Grid.Column="0"
                        Width="18"
                        Height="18"
                        Margin="0,0,6,0"
                        BorderBrush="#808080"
                        BorderThickness="1"
                        Background="{Binding ColorBrush}"
                        VerticalAlignment="Center"/>
				<TextBox Grid.Column="1"
                         Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         IsReadOnly="{Binding IsReadOnly}"
                         MinHeight="24"
                         Padding="5,2"
                         VerticalContentAlignment="Center"
                         Background="#FFFFFFFF"
                         Foreground="#FF000000"
                         BorderBrush="#3A3A3A"
                         BorderThickness="1"/>
				<Button Grid.Column="2"
                        Content="..."
                        Command="{Binding EscolherCorCommand}"
                        IsEnabled="{Binding IsEditable}"
                        Margin="4,0,0,0"
                        Padding="0"
                        Background="#333333"
                        Foreground="#F4F4F4"
                        BorderBrush="#555555"/>
			</Grid>
		</DataTemplate>

		<DataTemplate DataType="{x:Type viewModels:ProjectTablePropertiesViewModel}">
