<UserControl x:Class="Araci.Properties.PropertiesHostView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Margin="8"
            Background="#252526"
            BorderBrush="#F4F4F4"
            BorderThickness="1">

        <Grid>

            <ContentControl
                Content="{Binding ElementoSelecionado}"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch"/>

        </Grid>

    </Border>

</UserControl>