<UserControl x:Class="Araci.Properties.PropertiesHostView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Margin="8"
            Background="#252526"
            BorderBrush="#F4F4F4"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0"
                    Background="#1E1E1E"
                    BorderBrush="#3A3A3A"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock Text="Propriedades"
                               Foreground="#F4F4F4"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="12,0,42,0"/>
                    <Button Content="×"
                            Width="28"
                            Height="28"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,6,0"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="#F4F4F4"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Click="OnCloseClick"/>
                </Grid>
            </Border>
            <ContentControl Grid.Row="1"
                            Content="{Binding Editor.ElementoSelecionado}"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"/>
        </Grid>
    </Border>
</UserControl>