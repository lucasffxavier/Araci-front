		<DataTemplate DataType="{x:Type viewModels:PropertiesViewModel}">
			<Grid Margin="0">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>

				<TextBlock Grid.Row="0"
                           Text="{Binding Titulo}"
                           Foreground="#F4F4F4"
                           FontWeight="SemiBold"
                           Margin="10,10,10,4"/>

				<Grid Grid.Row="1"
                      Margin="10,4,10,8"
                      Visibility="{Binding ExibirSeletorTipo, Converter={StaticResource BooleanToVisibilityConverter}}">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="110"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="32"/>
					</Grid.ColumnDefinitions>
					<TextBlock Grid.Column="0"
                               Text="Tipo"
                               Foreground="#DCDCDC"
                               VerticalAlignment="Center"/>
					<ComboBox Grid.Column="1"
                              ItemsSource="{Binding TiposDisponiveis}"
                              SelectedItem="{Binding Tipo, Mode=TwoWay}"
                              ItemTemplate="{StaticResource TypeComboBoxSelectedTemplate}"
                              ItemContainerStyle="{StaticResource LightComboBoxItemStyle}"
                              MinHeight="24"
                              Background="#FFFFFFFF"
                              Foreground="#FF000000"
                              BorderBrush="#3A3A3A"/>
					<Button Grid.Column="2"
                            Content="..."
                            Command="{Binding AbrirPropriedadesTipoCommand}"
                            IsEnabled="{Binding PodeAbrirPropriedadesTipo}"
                            Margin="4,0,0,0"
                            Background="#333333"
                            Foreground="#F4F4F4"
                            BorderBrush="#555555"/>
				</Grid>

				<ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
					<ItemsControl ItemsSource="{Binding Propriedades}"
                                  Margin="10,0,10,10">
						<ItemsControl.ItemTemplate>
							<DataTemplate DataType="{x:Type viewModels:PropertyDescriptorViewModel}">
								<Grid Margin="0,0,0,6">
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="110"/>
										<ColumnDefinition Width="*"/>
									</Grid.ColumnDefinitions>
									<TextBlock Grid.Column="0"
                                               Text="{Binding DisplayName}"
                                               Foreground="#DCDCDC"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,8,0"/>
									<ContentControl Grid.Column="1"
                                                    Content="{Binding}">
										<ContentControl.Style>
											<Style TargetType="ContentControl">
												<Setter Property="ContentTemplate" Value="{StaticResource DefaultPropertyEditorTemplate}"/>
												<Style.Triggers>
													<DataTrigger Binding="{Binding IsBoolean}" Value="True">
														<Setter Property="ContentTemplate" Value="{StaticResource BooleanPropertyEditorTemplate}"/>
													</DataTrigger>
													<DataTrigger Binding="{Binding IsColor}" Value="True">
														<Setter Property="ContentTemplate" Value="{StaticResource ColorPropertyEditorTemplate}"/>
													</DataTrigger>
												</Style.Triggers>
											</Style>
										</ContentControl.Style>
									</ContentControl>
								</Grid>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</ScrollViewer>
			</Grid>
		</DataTemplate>
	</UserControl.Resources>

