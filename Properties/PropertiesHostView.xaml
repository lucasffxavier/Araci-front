<UserControl x:Class="Araci.Properties.PropertiesHostView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:Araci.ViewModels">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="LightComboBoxItemStyle" TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="#FF000000"/>
            <Setter Property="Background" Value="#FFFFFFFF"/>
            <Setter Property="Padding" Value="4,2"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#FFE5F1FB"/>
                    <Setter Property="Foreground" Value="#FF000000"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFDCEBFA"/>
                    <Setter Property="Foreground" Value="#FF000000"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="BooleanComboBoxSelectedTemplate">
            <TextBlock Text="{Binding DisplayName}"
                       Foreground="#FF000000"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
        </DataTemplate>

        <DataTemplate x:Key="TypeComboBoxSelectedTemplate">
            <TextBlock Text="{Binding NomeTipo}"
                       Foreground="#FF000000"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
        </DataTemplate>

        <DataTemplate x:Key="DefaultPropertyEditorTemplate" DataType="{x:Type viewModels:PropertyDescriptorViewModel}">
            <TextBox Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                     IsReadOnly="{Binding IsReadOnly}"
                     MinHeight="24"
                     Padding="5,2"
                     VerticalContentAlignment="Center"
                     Background="#FFFFFFFF"
                     Foreground="#FF000000"
                     BorderBrush="#3A3A3A"
                     BorderThickness="1"/>
        </DataTemplate>

        <DataTemplate x:Key="BooleanPropertyEditorTemplate" DataType="{x:Type viewModels:PropertyDescriptorViewModel}">
            <ComboBox ItemsSource="{Binding BooleanOptions}"
                      SelectedValue="{Binding BooleanValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      SelectedValuePath="Value"
                      ItemTemplate="{StaticResource BooleanComboBoxSelectedTemplate}"
                      ItemContainerStyle="{StaticResource LightComboBoxItemStyle}"
                      IsEnabled="{Binding IsEditable}"
                      MinHeight="24"
                      Padding="4,1"
                      Background="#FFFFFFFF"
                      Foreground="#FF000000"
                      BorderBrush="#3A3A3A"
                      BorderThickness="1"/>
        </DataTemplate>

        <DataTemplate x:Key="ColorPropertyEditorTemplate" DataType="{x:Type viewModels:PropertyDescriptorViewModel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="28"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Width="18"
                        Height="18"
                        Margin="0,0,6,0"
                        BorderBrush="#808080"
                        BorderThickness="1"
                        Background="{Binding ColorBrush}"
                        VerticalAlignment="Center"/>
                <TextBox Grid.Column="1"
                         Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         IsReadOnly="{Binding IsReadOnly}"
                         MinHeight="24"
                         Padding="5,2"
                         VerticalContentAlignment="Center"
                         Background="#FFFFFFFF"
                         Foreground="#FF000000"
                         BorderBrush="#3A3A3A"
                         BorderThickness="1"/>
                <Button Grid.Column="2"
                        Content="..."
                        Command="{Binding EscolherCorCommand}"
                        IsEnabled="{Binding IsEditable}"
                        Margin="4,0,0,0"
                        Padding="0"
                        Background="#333333"
                        Foreground="#F4F4F4"
                        BorderBrush="#555555"/>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:ProjectTablePropertiesViewModel}">
            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding Titulo}"
                           Foreground="#F4F4F4"
                           FontWeight="SemiBold"
                           Margin="10,10,10,8"/>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="10,0,10,10">
                        <Button Content="Exportar CSV"
                                Command="{Binding ExportarCsvCommand}"
                                MinHeight="24"
                                Margin="0,0,0,6"
                                Padding="6,2"
                                HorizontalContentAlignment="Center"
                                Background="#333333"
                                Foreground="#F4F4F4"
                                BorderBrush="#555555"/>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Nome"
                                       Foreground="#DCDCDC"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding Nome, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     MinHeight="24"
                                     Padding="5,2"
                                     VerticalContentAlignment="Center"
                                     Background="#FFFFFFFF"
                                     Foreground="#FF000000"
                                     BorderBrush="#3A3A3A"
                                     BorderThickness="1"/>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Disciplina"
                                       Foreground="#DCDCDC"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding Disciplinas}"
                                      SelectedItem="{Binding Disciplina, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      ItemContainerStyle="{StaticResource LightComboBoxItemStyle}"
                                      MinHeight="24"
                                      Background="#FFFFFFFF"
                                      Foreground="#FF000000"
                                      BorderBrush="#3A3A3A"/>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="32"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Elementos"
                                       Foreground="#DCDCDC"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,0,8,0"/>
                            <Button Grid.Column="2"
                                    Content="..."
                                    Command="{Binding ElementosTabelaCommand}"
                                    Background="#333333"
                                    Foreground="#F4F4F4"
                                    BorderBrush="#555555"/>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="32"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Filtros"
                                       Foreground="#DCDCDC"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <Button Grid.Column="2"
                                    Content="..."
                                    Command="{Binding FiltrosCommand}"
                                    Background="#333333"
                                    Foreground="#F4F4F4"
                                    BorderBrush="#555555"/>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="32"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Ordenação"
                                       Foreground="#DCDCDC"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <Button Grid.Column="2"
                                    Content="..."
                                    Command="{Binding OrdenacaoCommand}"
                                    Background="#333333"
                                    Foreground="#F4F4F4"
                                    BorderBrush="#555555"/>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="32"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Exibição"
                                       Foreground="#DCDCDC"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <Button Grid.Column="2"
                                    Content="..."
                                    Command="{Binding ExibicaoCommand}"
                                    Background="#333333"
                                    Foreground="#F4F4F4"
                                    BorderBrush="#555555"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:ProjectViewPropertiesViewModel}">
            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding Titulo}"
                           Foreground="#F4F4F4"
                           FontWeight="SemiBold"
                           Margin="10,10,10,8"/>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="10,0,10,10">
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Nome"
                                       Foreground="#DCDCDC"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding Nome, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     MinHeight="24"
                                     Padding="5,2"
                                     VerticalContentAlignment="Center"
                                     Background="#FFFFFFFF"
                                     Foreground="#FF000000"
                                     BorderBrush="#3A3A3A"
                                     BorderThickness="1"/>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Escala"
                                       Foreground="#DCDCDC"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding Escala, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     MinHeight="24"
                                     Padding="5,2"
                                     VerticalContentAlignment="Center"
                                     Background="#FFFFFFFF"
                                     Foreground="#FF000000"
                                     BorderBrush="#3A3A3A"
                                     BorderThickness="1"/>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Disciplina"
                                       Foreground="#DCDCDC"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding Disciplinas}"
                                      SelectedItem="{Binding Disciplina, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      ItemContainerStyle="{StaticResource LightComboBoxItemStyle}"
                                      MinHeight="24"
                                      Background="#FFFFFFFF"
                                      Foreground="#FF000000"
                                      BorderBrush="#3A3A3A"/>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Recortar vista"
                                       Foreground="#DCDCDC"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <CheckBox Grid.Column="1"
                                      IsChecked="{Binding RecortarVista, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       Foreground="#DCDCDC"
                                       VerticalAlignment="Center"
                                      HorizontalAlignment="Left"/>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Região de recorte visível"
                                       Foreground="#DCDCDC"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,0,8,0"/>
                            <CheckBox Grid.Column="1"
                                      IsChecked="{Binding RegiaoRecorteVisivel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Foreground="#DCDCDC"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Left"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:PropertiesViewModel}">
            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding Titulo}"
                           Foreground="#F4F4F4"
                           FontWeight="SemiBold"
                           Margin="10,10,10,4"/>

                <Grid Grid.Row="1"
                      Margin="10,4,10,8"
                      Visibility="{Binding ExibirSeletorTipo, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="32"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Tipo"
                               Foreground="#DCDCDC"
                               VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding TiposDisponiveis}"
                              SelectedItem="{Binding Tipo, Mode=TwoWay}"
                              ItemTemplate="{StaticResource TypeComboBoxSelectedTemplate}"
                              ItemContainerStyle="{StaticResource LightComboBoxItemStyle}"
                              MinHeight="24"
                              Background="#FFFFFFFF"
                              Foreground="#FF000000"
                              BorderBrush="#3A3A3A"/>
                    <Button Grid.Column="2"
                            Content="..."
                            Command="{Binding AbrirPropriedadesTipoCommand}"
                            IsEnabled="{Binding PodeAbrirPropriedadesTipo}"
                            Margin="4,0,0,0"
                            Background="#333333"
                            Foreground="#F4F4F4"
                            BorderBrush="#555555"/>
                </Grid>

                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Propriedades}"
                                  Margin="10,0,10,10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:PropertyDescriptorViewModel}">
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding DisplayName}"
                                               Foreground="#DCDCDC"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,8,0"/>
                                    <ContentControl Grid.Column="1"
                                                    Content="{Binding}">
                                        <ContentControl.Style>
                                            <Style TargetType="ContentControl">
                                                <Setter Property="ContentTemplate" Value="{StaticResource DefaultPropertyEditorTemplate}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBoolean}" Value="True">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource BooleanPropertyEditorTemplate}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsColor}" Value="True">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource ColorPropertyEditorTemplate}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ContentControl.Style>
                                    </ContentControl>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Border Margin="8"
            Background="#252526"
            BorderBrush="#F4F4F4"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0"
                    Background="#1E1E1E"
                    BorderBrush="#3A3A3A"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock Text="Propriedades"
                               Foreground="#F4F4F4"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="12,0,42,0"/>
                    <Button Content="×"
                            Width="28"
                            Height="28"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,6,0"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="#F4F4F4"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Click="OnCloseClick"/>
                </Grid>
            </Border>
            <ContentControl Grid.Row="1"
                            Content="{Binding Editor.ElementoSelecionado}"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"/>
        </Grid>
    </Border>
</UserControl>
