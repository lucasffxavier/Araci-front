				<ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
					<StackPanel Margin="10,0,10,10">
						<Grid Margin="0,0,0,6">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="110"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<TextBlock Grid.Column="0"
                                       Text="Nome"
                                       Foreground="#DCDCDC"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
							<TextBox Grid.Column="1"
                                     Text="{Binding Nome, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     MinHeight="24"
                                     Padding="5,2"
                                     VerticalContentAlignment="Center"
                                     Background="#FFFFFFFF"
                                     Foreground="#FF000000"
                                     BorderBrush="#3A3A3A"
                                     BorderThickness="1"/>
						</Grid>

						<Grid Margin="0,0,0,6">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="110"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<TextBlock Grid.Column="0"
                                       Text="Disciplina"
                                       Foreground="#DCDCDC"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
							<ComboBox Grid.Column="1"
                                      ItemsSource="{Binding Disciplinas}"
                                      SelectedItem="{Binding Disciplina, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      ItemContainerStyle="{StaticResource LightComboBoxItemStyle}"
                                      MinHeight="24"
                                      Background="#FFFFFFFF"
                                      Foreground="#FF000000"
                                      BorderBrush="#3A3A3A"/>
						</Grid>

						<Grid Margin="0,0,0,6">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="110"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="32"/>
							</Grid.ColumnDefinitions>
							<TextBlock Grid.Column="0"
                                       Text="Elementos"
                                       Foreground="#DCDCDC"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,0,8,0"/>
							<Button Grid.Column="2"
                                    Content="..."
                                    Command="{Binding ElementosTabelaCommand}"
                                    Background="#333333"
                                    Foreground="#F4F4F4"
                                    BorderBrush="#555555"/>
						</Grid>

						<Grid Margin="0,0,0,6">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="110"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="32"/>
							</Grid.ColumnDefinitions>
							<TextBlock Grid.Column="0"
                                       Text="Filtros"
                                       Foreground="#DCDCDC"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
							<Button Grid.Column="2"
                                    Content="..."
                                    Command="{Binding FiltrosCommand}"
                                    Background="#333333"
                                    Foreground="#F4F4F4"
                                    BorderBrush="#555555"/>
						</Grid>

						<Grid Margin="0,0,0,6">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="110"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="32"/>
							</Grid.ColumnDefinitions>
							<TextBlock Grid.Column="0"
                                       Text="Ordenação"
                                       Foreground="#DCDCDC"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
							<Button Grid.Column="2"
                                    Content="..."
                                    Command="{Binding OrdenacaoCommand}"
                                    Background="#333333"
                                    Foreground="#F4F4F4"
                                    BorderBrush="#555555"/>
						</Grid>

						<Grid Margin="0,0,0,6">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="110"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="32"/>
							</Grid.ColumnDefinitions>
							<TextBlock Grid.Column="0"
                                       Text="Exibição"
                                       Foreground="#DCDCDC"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
							<Button Grid.Column="2"
                                    Content="..."
                                    Command="{Binding ExibicaoCommand}"
                                    Background="#333333"
                                    Foreground="#F4F4F4"
                                    BorderBrush="#555555"/>
						</Grid>
					</StackPanel>
				</ScrollViewer>
			</Grid>
		</DataTemplate>

