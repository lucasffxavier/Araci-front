<Window x:Class="Araci.Properties.ExibicaoTabelaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Exibição da tabela"
        Width="560"
        Height="660"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#101010">
	<Window.Resources>
		<SolidColorBrush x:Key="WindowBackgroundBrush" Color="#101010"/>
		<SolidColorBrush x:Key="PanelBackgroundBrush" Color="#171717"/>
		<SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFFFF"/>
		<SolidColorBrush x:Key="InputTextBrush" Color="#1F2933"/>
		<SolidColorBrush x:Key="InputBorderBrush" Color="#C8CCD0"/>
		<SolidColorBrush x:Key="PrimaryTextBrush" Color="#F4F4F4"/>
		<SolidColorBrush x:Key="SecondaryTextBrush" Color="#D8D8D8"/>
		<SolidColorBrush x:Key="BorderLightBrush" Color="#FFFFFFFF"/>
		<SolidColorBrush x:Key="BorderSoftBrush" Color="#8AFFFFFF"/>

		<Style TargetType="{x:Type TextBlock}">
			<Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
		</Style>

		<Style TargetType="{x:Type CheckBox}">
			<Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
		</Style>

		<Style TargetType="{x:Type TextBox}">
			<Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
			<Setter Property="Foreground" Value="{StaticResource InputTextBrush}"/>
			<Setter Property="CaretBrush" Value="{StaticResource InputTextBrush}"/>
			<Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Padding" Value="5,2"/>
			<Setter Property="MinHeight" Value="24"/>
			<Setter Property="SelectionBrush" Value="#4A90E2"/>
			<Setter Property="SelectionTextBrush" Value="#FFFFFFFF"/>
		</Style>

		<DataTemplate x:Key="ComboBoxInputItemTemplate">
			<TextBlock Text="{Binding}"
                       Foreground="{StaticResource InputTextBrush}"
                       VerticalAlignment="Center"/>
		</DataTemplate>

		<Style x:Key="ComboBoxItemInputStyle" TargetType="{x:Type ComboBoxItem}">
			<Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
			<Setter Property="Foreground" Value="{StaticResource InputTextBrush}"/>
			<Setter Property="Padding" Value="6,2"/>
			<Setter Property="HorizontalContentAlignment" Value="Stretch"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
			<Setter Property="TextElement.Foreground" Value="{StaticResource InputTextBrush}"/>
			<Style.Triggers>
				<Trigger Property="IsHighlighted" Value="True">
					<Setter Property="Background" Value="#CFE8F8"/>
					<Setter Property="Foreground" Value="{StaticResource InputTextBrush}"/>
					<Setter Property="TextElement.Foreground" Value="{StaticResource InputTextBrush}"/>
				</Trigger>
				<Trigger Property="IsSelected" Value="True">
					<Setter Property="Background" Value="#DDEFFF"/>
					<Setter Property="Foreground" Value="{StaticResource InputTextBrush}"/>
					<Setter Property="TextElement.Foreground" Value="{StaticResource InputTextBrush}"/>
				</Trigger>
				<Trigger Property="IsEnabled" Value="False">
					<Setter Property="Foreground" Value="#707070"/>
					<Setter Property="TextElement.Foreground" Value="#707070"/>
				</Trigger>
			</Style.Triggers>
		</Style>

		<Style TargetType="{x:Type ComboBox}">
			<Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
			<Setter Property="Foreground" Value="{StaticResource InputTextBrush}"/>
			<Setter Property="TextElement.Foreground" Value="{StaticResource InputTextBrush}"/>
			<Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="MinHeight" Value="24"/>
			<Setter Property="ItemContainerStyle" Value="{StaticResource ComboBoxItemInputStyle}"/>
			<Setter Property="ItemTemplate" Value="{StaticResource ComboBoxInputItemTemplate}"/>
		</Style>

		<Style TargetType="{x:Type Button}">
			<Setter Property="Background" Value="#2A2A2A"/>
			<Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
			<Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Padding" Value="8,3"/>
			<Setter Property="MinHeight" Value="24"/>
		</Style>

		<Style TargetType="{x:Type GroupBox}">
			<Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="{x:Type GroupBox}">
						<Grid SnapsToDevicePixels="True">
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="*"/>
							</Grid.RowDefinitions>
							<ContentPresenter Grid.Row="0"
                                                  ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  Margin="12,0,0,4"
                                                  TextElement.Foreground="{StaticResource PrimaryTextBrush}"
                                                  TextElement.FontWeight="SemiBold"/>
							<Border Grid.Row="1"
                                    Background="{StaticResource PanelBackgroundBrush}"
                                    BorderBrush="{StaticResource BorderLightBrush}"
                                    BorderThickness="1">
								<ContentPresenter Margin="0"/>
							</Border>
						</Grid>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</Window.Resources>

	<Border Margin="10"
            Background="{StaticResource WindowBackgroundBrush}"
            BorderBrush="{StaticResource BorderLightBrush}"
            BorderThickness="1">
		<Grid Margin="12" TextElement.Foreground="{StaticResource PrimaryTextBrush}">
			<Grid.RowDefinitions>
				<RowDefinition Height="*"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<ScrollViewer Grid.Row="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="Transparent">
				<StackPanel>
					<GroupBox Header="Título" Margin="0,0,0,10">
						<Grid Margin="10,12,10,10">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="170"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
							</Grid.RowDefinitions>
							<CheckBox Grid.Row="0" Grid.ColumnSpan="2" x:Name="ExibirTituloCheckBox" Content="Exibir título" Margin="0,0,0,6"/>
							<TextBlock Grid.Row="1" Text="Fonte" VerticalAlignment="Center" Margin="0,0,8,6"/>
							<ComboBox Grid.Row="1" Grid.Column="1" x:Name="FonteTituloComboBox" Margin="0,0,0,6" IsEditable="True" IsTextSearchEnabled="True"/>
							<TextBlock Grid.Row="2" Text="Tamanho" VerticalAlignment="Center" Margin="0,0,8,6"/>
							<TextBox Grid.Row="2" Grid.Column="1" x:Name="TamanhoTituloTextBox" Margin="0,0,0,6"/>
							<CheckBox Grid.Row="3" Grid.ColumnSpan="2" x:Name="TituloNegritoCheckBox" Content="Negrito" Margin="0,0,0,6"/>
							<TextBlock Grid.Row="4" Text="Cor do texto" VerticalAlignment="Center" Margin="0,0,8,6"/>
							<Grid Grid.Row="4" Grid.Column="1" Margin="0,0,0,6">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="36"/>
								</Grid.ColumnDefinitions>
								<TextBox x:Name="CorTextoTituloTextBox" Margin="0,0,6,0" TextChanged="ColorTextBox_TextChanged"/>
								<Button x:Name="CorTextoTituloButton" Grid.Column="1" ToolTip="Selecionar cor" Click="CorTextoTituloButton_Click"/>
							</Grid>
							<TextBlock Grid.Row="5" Text="Cor de fundo" VerticalAlignment="Center" Margin="0,0,8,6"/>
							<Grid Grid.Row="5" Grid.Column="1" Margin="0,0,0,6">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="36"/>
								</Grid.ColumnDefinitions>
								<TextBox x:Name="CorFundoTituloTextBox" Margin="0,0,6,0" TextChanged="ColorTextBox_TextChanged"/>
								<Button x:Name="CorFundoTituloButton" Grid.Column="1" ToolTip="Selecionar cor" Click="CorFundoTituloButton_Click"/>
							</Grid>
							<TextBlock Grid.Row="6" Text="Altura" VerticalAlignment="Center" Margin="0,0,8,6"/>
							<TextBox Grid.Row="6" Grid.Column="1" x:Name="AlturaTituloTextBox" Margin="0,0,0,6"/>
							<TextBlock Grid.Row="7" Text="Alinhamento" VerticalAlignment="Center" Margin="0,0,8,0"/>
							<ComboBox Grid.Row="7" Grid.Column="1" x:Name="AlinhamentoTituloComboBox"/>
						</Grid>
					</GroupBox>

					<GroupBox Header="Cabeçalho" Margin="0,0,0,10">
						<Grid Margin="10,12,10,10">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="170"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
							</Grid.RowDefinitions>
							<CheckBox Grid.Row="0" Grid.ColumnSpan="2" x:Name="ExibirCabecalhoCheckBox" Content="Exibir cabeçalho" Margin="0,0,0,6"/>
							<TextBlock Grid.Row="1" Text="Fonte" VerticalAlignment="Center" Margin="0,0,8,6"/>
							<ComboBox Grid.Row="1" Grid.Column="1" x:Name="FonteCabecalhoComboBox" Margin="0,0,0,6" IsEditable="True" IsTextSearchEnabled="True"/>
							<TextBlock Grid.Row="2" Text="Tamanho" VerticalAlignment="Center" Margin="0,0,8,6"/>
							<TextBox Grid.Row="2" Grid.Column="1" x:Name="TamanhoCabecalhoTextBox" Margin="0,0,0,6"/>
							<CheckBox Grid.Row="3" Grid.ColumnSpan="2" x:Name="CabecalhoNegritoCheckBox" Content="Negrito" Margin="0,0,0,6"/>
							<TextBlock Grid.Row="4" Text="Cor do texto" VerticalAlignment="Center" Margin="0,0,8,6"/>
							<Grid Grid.Row="4" Grid.Column="1" Margin="0,0,0,6">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="36"/>
								</Grid.ColumnDefinitions>
								<TextBox x:Name="CorTextoCabecalhoTextBox" Margin="0,0,6,0" TextChanged="ColorTextBox_TextChanged"/>
								<Button x:Name="CorTextoCabecalhoButton" Grid.Column="1" ToolTip="Selecionar cor" Click="CorTextoCabecalhoButton_Click"/>
							</Grid>
							<TextBlock Grid.Row="5" Text="Cor de fundo" VerticalAlignment="Center" Margin="0,0,8,6"/>
							<Grid Grid.Row="5" Grid.Column="1" Margin="0,0,0,6">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="36"/>
								</Grid.ColumnDefinitions>
								<TextBox x:Name="CorFundoCabecalhoTextBox" Margin="0,0,6,0" TextChanged="ColorTextBox_TextChanged"/>
								<Button x:Name="CorFundoCabecalhoButton" Grid.Column="1" ToolTip="Selecionar cor" Click="CorFundoCabecalhoButton_Click"/>
							</Grid>
							<TextBlock Grid.Row="6" Text="Altura" VerticalAlignment="Center" Margin="0,0,8,6"/>
							<TextBox Grid.Row="6" Grid.Column="1" x:Name="AlturaCabecalhoTextBox" Margin="0,0,0,6"/>
							<TextBlock Grid.Row="7" Text="Alinhamento" VerticalAlignment="Center" Margin="0,0,8,0"/>
							<ComboBox Grid.Row="7" Grid.Column="1" x:Name="AlinhamentoCabecalhoComboBox"/>
						</Grid>
					</GroupBox>

					<GroupBox Header="Corpo" Margin="0,0,0,10">
						<Grid Margin="10,12,10,10">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="170"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
							</Grid.RowDefinitions>
							<TextBlock Grid.Row="0" Text="Fonte" VerticalAlignment="Center" Margin="0,0,8,6"/>
							<ComboBox Grid.Row="0" Grid.Column="1" x:Name="FonteCorpoComboBox" Margin="0,0,0,6" IsEditable="True" IsTextSearchEnabled="True"/>
							<TextBlock Grid.Row="1" Text="Tamanho" VerticalAlignment="Center" Margin="0,0,8,6"/>
							<TextBox Grid.Row="1" Grid.Column="1" x:Name="TamanhoCorpoTextBox" Margin="0,0,0,6"/>
							<TextBlock Grid.Row="2" Text="Cor do texto" VerticalAlignment="Center" Margin="0,0,8,6"/>
							<Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,6">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="36"/>
								</Grid.ColumnDefinitions>
								<TextBox x:Name="CorTextoCorpoTextBox" Margin="0,0,6,0" TextChanged="ColorTextBox_TextChanged"/>
								<Button x:Name="CorTextoCorpoButton" Grid.Column="1" ToolTip="Selecionar cor" Click="CorTextoCorpoButton_Click"/>
							</Grid>
							<TextBlock Grid.Row="3" Text="Cor de fundo" VerticalAlignment="Center" Margin="0,0,8,6"/>
							<Grid Grid.Row="3" Grid.Column="1" Margin="0,0,0,6">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="36"/>
								</Grid.ColumnDefinitions>
								<TextBox x:Name="CorFundoCorpoTextBox" Margin="0,0,6,0" TextChanged="ColorTextBox_TextChanged"/>
								<Button x:Name="CorFundoCorpoButton" Grid.Column="1" ToolTip="Selecionar cor" Click="CorFundoCorpoButton_Click"/>
							</Grid>
							<TextBlock Grid.Row="4" Text="Altura da linha" VerticalAlignment="Center" Margin="0,0,8,6"/>
							<TextBox Grid.Row="4" Grid.Column="1" x:Name="AlturaLinhaCorpoTextBox" Margin="0,0,0,6"/>
							<TextBlock Grid.Row="5" Text="Alinhamento" VerticalAlignment="Center" Margin="0,0,8,6"/>
							<ComboBox Grid.Row="5" Grid.Column="1" x:Name="AlinhamentoCorpoComboBox" Margin="0,0,0,6"/>
							<CheckBox Grid.Row="6" x:Name="LinhasAlternadasCheckBox" Content="Usar linhas alternadas" Margin="0,0,8,0"/>
							<Grid Grid.Row="6" Grid.Column="1">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="36"/>
								</Grid.ColumnDefinitions>
								<TextBox x:Name="CorLinhaAlternadaTextBox" Margin="0,0,6,0" TextChanged="ColorTextBox_TextChanged"/>
								<Button x:Name="CorLinhaAlternadaButton" Grid.Column="1" ToolTip="Selecionar cor" Click="CorLinhaAlternadaButton_Click"/>
							</Grid>
						</Grid>
					</GroupBox>

					<GroupBox Header="Bordas e grade">
						<Grid Margin="10,12,10,10">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="170"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
							</Grid.RowDefinitions>
							<CheckBox Grid.Row="0" Grid.ColumnSpan="2" x:Name="ExibirGradeCheckBox" Content="Exibir linhas de grade" Margin="0,0,0,6"/>
							<TextBlock Grid.Row="1" Text="Cor da grade" VerticalAlignment="Center" Margin="0,0,8,6"/>
							<Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,6">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="36"/>
								</Grid.ColumnDefinitions>
								<TextBox x:Name="CorGradeTextBox" Margin="0,0,6,0" TextChanged="ColorTextBox_TextChanged"/>
								<Button x:Name="CorGradeButton" Grid.Column="1" ToolTip="Selecionar cor" Click="CorGradeButton_Click"/>
							</Grid>
							<TextBlock Grid.Row="2" Text="Espessura da grade" VerticalAlignment="Center" Margin="0,0,8,6"/>
							<TextBox Grid.Row="2" Grid.Column="1" x:Name="EspessuraGradeTextBox" Margin="0,0,0,6"/>
							<CheckBox Grid.Row="3" Grid.ColumnSpan="2" x:Name="ExibirContornoCheckBox" Content="Exibir contorno externo" Margin="0,0,0,6"/>
							<TextBlock Grid.Row="4" Text="Cor do contorno" VerticalAlignment="Center" Margin="0,0,8,6"/>
							<Grid Grid.Row="4" Grid.Column="1" Margin="0,0,0,6">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="36"/>
								</Grid.ColumnDefinitions>
								<TextBox x:Name="CorContornoTextBox" Margin="0,0,6,0" TextChanged="ColorTextBox_TextChanged"/>
								<Button x:Name="CorContornoButton" Grid.Column="1" ToolTip="Selecionar cor" Click="CorContornoButton_Click"/>
							</Grid>
							<TextBlock Grid.Row="5" Text="Espessura do contorno" VerticalAlignment="Center" Margin="0,0,8,0"/>
							<TextBox Grid.Row="5" Grid.Column="1" x:Name="EspessuraContornoTextBox"/>
						</Grid>
					</GroupBox>
				</StackPanel>
			</ScrollViewer>

			<StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
				<Button Content="OK" Width="82" Margin="0,0,8,0" Click="OkButton_Click"/>
				<Button Content="Cancelar" Width="82" Click="CancelButton_Click"/>
			</StackPanel>
		</Grid>
	</Border>
</Window>