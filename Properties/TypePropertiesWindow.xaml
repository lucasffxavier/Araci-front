<Window x:Class="Araci.Properties.TypePropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Propriedades de Tipo"
        Width="560"
        Height="540"
        Background="#252526"
        WindowStartupLocation="CenterOwner">
    <Border Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                <ContentControl Content="{Binding}"/>
            </ScrollViewer>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="OK" Width="86" Height="26" Margin="0,0,8,0" IsDefault="True" Click="OnOkClick"/>
                <Button Content="Cancelar" Width="86" Height="26" IsCancel="True" Click="OnCancelarClick"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
