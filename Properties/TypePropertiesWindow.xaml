<Window x:Class="Araci.Properties.TypePropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:Araci.ViewModels"
        Title="Propriedades de Tipo"
        Width="460"
        Height="500"
        Background="#252526"
        WindowStartupLocation="CenterOwner">

    <Border Padding="12">

        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <ContentControl Content="{Binding}">

                <ContentControl.Resources>

                    <!-- CABO -->

                    <DataTemplate
                        DataType="{x:Type viewModels:TipoCaboViewModel}">

                        <StackPanel>

                            <TextBlock Text="PROPRIEDADES DE TIPO"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Margin="0,0,0,20"/>

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Nome do Tipo"
                                           Foreground="#CCCCCC"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,12"/>

                                <TextBox Grid.Column="1"
                                         Text="{Binding NomeTipo}"
                                         IsReadOnly="True"
                                         Margin="0,0,0,12"/>

                                <TextBlock Grid.Row="1"
                                           Text="Ampacidade"
                                           Foreground="#CCCCCC"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,12"/>

                                <TextBox Grid.Row="1"
                                         Grid.Column="1"
                                         Text="{Binding Ampacidade}"
                                         IsReadOnly="True"
                                         Margin="0,0,0,12"/>

                                <TextBlock Grid.Row="2"
                                           Text="Resistencia"
                                           Foreground="#CCCCCC"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,12"/>

                                <TextBox Grid.Row="2"
                                         Grid.Column="1"
                                         Text="{Binding Resistencia}"
                                         IsReadOnly="True"
                                         Margin="0,0,0,12"/>

                            </Grid>

                        </StackPanel>

                    </DataTemplate>

                    <!-- CARGA -->

                    <DataTemplate
                        DataType="{x:Type viewModels:TipoCargaViewModel}">

                        <StackPanel>

                            <TextBlock Text="PROPRIEDADES DE TIPO"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Margin="0,0,0,20"/>

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Nome do Tipo"
                                           Foreground="#CCCCCC"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,12"/>

                                <TextBox Grid.Column="1"
                                         Text="{Binding NomeTipo}"
                                         IsReadOnly="True"
                                         Margin="0,0,0,12"/>

                                <TextBlock Grid.Row="1"
                                           Text="Familia"
                                           Foreground="#CCCCCC"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,12"/>

                                <TextBox Grid.Row="1"
                                         Grid.Column="1"
                                         Text="{Binding Familia}"
                                         IsReadOnly="True"
                                         Margin="0,0,0,12"/>

                                <TextBlock Grid.Row="2"
                                           Text="Categoria"
                                           Foreground="#CCCCCC"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,12"/>

                                <TextBox Grid.Row="2"
                                         Grid.Column="1"
                                         Text="{Binding Categoria}"
                                         IsReadOnly="True"
                                         Margin="0,0,0,12"/>

                                <TextBlock Grid.Row="3"
                                           Text="Modelo de Carga"
                                           Foreground="#CCCCCC"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,12"/>

                                <TextBox Grid.Row="3"
                                         Grid.Column="1"
                                         Text="{Binding ModeloCarga}"
                                         IsReadOnly="True"
                                         Margin="0,0,0,12"/>

                                <TextBlock Grid.Row="4"
                                           Text="Conexao"
                                           Foreground="#CCCCCC"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,12"/>

                                <TextBox Grid.Row="4"
                                         Grid.Column="1"
                                         Text="{Binding Conexao}"
                                         IsReadOnly="True"
                                         Margin="0,0,0,12"/>

                                <TextBlock Grid.Row="5"
                                           Text="Tensao kV"
                                           Foreground="#CCCCCC"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,12"/>

                                <TextBox Grid.Row="5"
                                         Grid.Column="1"
                                         Text="{Binding TensaoKV}"
                                         IsReadOnly="True"
                                         Margin="0,0,0,12"/>

                                <TextBlock Grid.Row="6"
                                           Text="Fases"
                                           Foreground="#CCCCCC"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,12"/>

                                <TextBox Grid.Row="6"
                                         Grid.Column="1"
                                         Text="{Binding Fases}"
                                         IsReadOnly="True"
                                         Margin="0,0,0,12"/>

                                <TextBlock Grid.Row="7"
                                           Text="Fator de Potencia"
                                           Foreground="#CCCCCC"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,12"/>

                                <TextBox Grid.Row="7"
                                         Grid.Column="1"
                                         Text="{Binding FatorPotencia}"
                                         IsReadOnly="True"
                                         Margin="0,0,0,12"/>

                            </Grid>

                        </StackPanel>

                    </DataTemplate>

                    <!-- GERADOR -->

                    <DataTemplate
                        DataType="{x:Type viewModels:TipoGeradorViewModel}">

                        <StackPanel>

                            <TextBlock Text="PROPRIEDADES DE TIPO"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Margin="0,0,0,20"/>

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Nome do Tipo"
                                           Foreground="#CCCCCC"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,12"/>

                                <TextBox Grid.Column="1"
                                         Text="{Binding NomeTipo}"
                                         IsReadOnly="True"
                                         Margin="0,0,0,12"/>

                                <TextBlock Grid.Row="1"
                                           Text="Familia"
                                           Foreground="#CCCCCC"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,12"/>

                                <TextBox Grid.Row="1"
                                         Grid.Column="1"
                                         Text="{Binding Familia}"
                                         IsReadOnly="True"
                                         Margin="0,0,0,12"/>

                                <TextBlock Grid.Row="2"
                                           Text="Categoria"
                                           Foreground="#CCCCCC"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,12"/>

                                <TextBox Grid.Row="2"
                                         Grid.Column="1"
                                         Text="{Binding Categoria}"
                                         IsReadOnly="True"
                                         Margin="0,0,0,12"/>

                                <TextBlock Grid.Row="3"
                                           Text="Categoria gerador"
                                           Foreground="#CCCCCC"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,12"/>

                                <TextBox Grid.Row="3"
                                         Grid.Column="1"
                                         Text="{Binding CategoriaGerador}"
                                         IsReadOnly="True"
                                         Margin="0,0,0,12"/>

                                <TextBlock Grid.Row="4"
                                           Text="Fabricante"
                                           Foreground="#CCCCCC"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,12"/>

                                <TextBox Grid.Row="4"
                                         Grid.Column="1"
                                         Text="{Binding Fabricante}"
                                         IsReadOnly="True"
                                         Margin="0,0,0,12"/>

                                <TextBlock Grid.Row="5"
                                           Text="Modelo"
                                           Foreground="#CCCCCC"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,12"/>

                                <TextBox Grid.Row="5"
                                         Grid.Column="1"
                                         Text="{Binding Modelo}"
                                         IsReadOnly="True"
                                         Margin="0,0,0,12"/>

                                <TextBlock Grid.Row="6"
                                           Text="Potencia nominal"
                                           Foreground="#CCCCCC"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,12"/>

                                <TextBox Grid.Row="6"
                                         Grid.Column="1"
                                         Text="{Binding PotenciaNominalKW}"
                                         IsReadOnly="True"
                                         Margin="0,0,0,12"/>

                                <TextBlock Grid.Row="7"
                                           Text="Tensao kV"
                                           Foreground="#CCCCCC"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,12"/>

                                <TextBox Grid.Row="7"
                                         Grid.Column="1"
                                         Text="{Binding TensaoKV}"
                                         IsReadOnly="True"
                                         Margin="0,0,0,12"/>

                                <TextBlock Grid.Row="8"
                                           Text="Fases"
                                           Foreground="#CCCCCC"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,12"/>

                                <TextBox Grid.Row="8"
                                         Grid.Column="1"
                                         Text="{Binding Fases}"
                                         IsReadOnly="True"
                                         Margin="0,0,0,12"/>

                            </Grid>

                        </StackPanel>

                    </DataTemplate>

                </ContentControl.Resources>

            </ContentControl>

        </ScrollViewer>

    </Border>

</Window>
