<Window x:Class="Araci.Properties.TypePropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:Araci.ViewModels"
        Title="Propriedades de Tipo"
        Width="420"
        Height="500"
        Background="#252526"
        WindowStartupLocation="CenterOwner">

    <Border Padding="12">

        <ContentControl Content="{Binding}">

            <ContentControl.Resources>

                <!-- CABO -->

                <DataTemplate
                    DataType="{x:Type viewModels:TipoCaboViewModel}">

                    <StackPanel>

                        <TextBlock Text="PROPRIEDADES DE TIPO"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="Nome do Tipo"
                                   Foreground="#CCCCCC"/>

                        <TextBox Text="{Binding NomeTipo}"
                                 IsReadOnly="True"
                                 Margin="0,4,0,12"/>

                        <TextBlock Text="Ampacidade"
                                   Foreground="#CCCCCC"/>

                        <TextBox Text="{Binding Ampacidade}"
                                 IsReadOnly="True"
                                 Margin="0,4,0,12"/>

                        <TextBlock Text="Resistência"
                                   Foreground="#CCCCCC"/>

                        <TextBox Text="{Binding Resistencia}"
                                 IsReadOnly="True"
                                 Margin="0,4,0,12"/>

                    </StackPanel>

                </DataTemplate>

                <!-- CARGA -->

                <DataTemplate
                    DataType="{x:Type viewModels:TipoCargaViewModel}">

                    <StackPanel>

                        <TextBlock Text="PROPRIEDADES DE TIPO"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="Nome Tipo"
                                   Foreground="#CCCCCC"/>

                        <TextBox Text="{Binding NomeTipo}"
                                 IsReadOnly="True"
                                 Margin="0,4,0,12"/>

                        <TextBlock Text="Tensão"
                                   Foreground="#CCCCCC"/>

                        <TextBox Text="{Binding TensaoKV}"
                                 IsReadOnly="True"
                                 Margin="0,4,0,12"/>

                    </StackPanel>

                </DataTemplate>

            </ContentControl.Resources>

        </ContentControl>

    </Border>

</Window>