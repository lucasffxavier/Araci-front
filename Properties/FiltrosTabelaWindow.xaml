<Window x:Class="Araci.Properties.FiltrosTabelaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Filtros da tabela"
        Width="820"
        SizeToContent="Height"
        ResizeMode="NoResize"
        Background="#252526"
        WindowStartupLocation="CenterOwner">
    <Border Margin="10"
            Padding="16"
            BorderBrush="#F4F4F4"
            BorderThickness="1"
            Background="#252526">
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Content="OK"
                        Width="90"
                        Height="30"
                        Margin="0,0,8,0"
                        IsDefault="True"
                        Click="OkButton_Click"/>
                <Button Content="Cancelar"
                        Width="90"
                        Height="30"
                        IsCancel="True"
                        Click="CancelButton_Click"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Filtros da tabela"
                           Foreground="#F4F4F4"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           Margin="0,0,0,16"/>
                <TextBlock Text="Configure até 5 regras de filtro. A combinação das regras é definida pelo modo global."
                           Foreground="#DCDCDC"
                           TextWrapping="Wrap"
                           Margin="0,0,0,14"/>

                <Border BorderBrush="#3A3A3A"
                        BorderThickness="1"
                        Padding="10"
                        Background="#1E1E1E"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Combinar regras:"
                                   Foreground="#F4F4F4"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <RadioButton x:Name="TodasRadioButton"
                                     Content="Todas as regras devem ser verdadeiras"
                                     Foreground="#DCDCDC"
                                     Margin="0,0,0,6"
                                     GroupName="ModoFiltro"/>
                        <RadioButton x:Name="QualquerRadioButton"
                                     Content="Qualquer regra pode ser verdadeira"
                                     Foreground="#DCDCDC"
                                     GroupName="ModoFiltro"/>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="SemCamposTextBlock"
                           Text="Selecione campos em Elementos da tabela antes de configurar filtros."
                           Foreground="#DCDCDC"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"
                           Visibility="Collapsed"/>

                <Border BorderBrush="#3A3A3A"
                        BorderThickness="1"
                        Padding="10"
                        Background="#1E1E1E">
                    <Grid x:Name="FiltrosGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Parâmetro" Foreground="#F4F4F4" FontWeight="SemiBold" Margin="0,0,12,8"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Operador" Foreground="#F4F4F4" FontWeight="SemiBold" Margin="0,0,12,8"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Valor" Foreground="#F4F4F4" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <ComboBox x:Name="Campo1ComboBox" Grid.Row="1" Grid.Column="0" DisplayMemberPath="Texto" Margin="0,0,12,6"/>
                        <ComboBox x:Name="Operador1ComboBox" Grid.Row="1" Grid.Column="1" DisplayMemberPath="Texto" Margin="0,0,12,6"/>
                        <TextBox x:Name="Valor1TextBox" Grid.Row="1" Grid.Column="2" Margin="0,0,0,6"/>

                        <ComboBox x:Name="Campo2ComboBox" Grid.Row="2" Grid.Column="0" DisplayMemberPath="Texto" Margin="0,0,12,6"/>
                        <ComboBox x:Name="Operador2ComboBox" Grid.Row="2" Grid.Column="1" DisplayMemberPath="Texto" Margin="0,0,12,6"/>
                        <TextBox x:Name="Valor2TextBox" Grid.Row="2" Grid.Column="2" Margin="0,0,0,6"/>

                        <ComboBox x:Name="Campo3ComboBox" Grid.Row="3" Grid.Column="0" DisplayMemberPath="Texto" Margin="0,0,12,6"/>
                        <ComboBox x:Name="Operador3ComboBox" Grid.Row="3" Grid.Column="1" DisplayMemberPath="Texto" Margin="0,0,12,6"/>
                        <TextBox x:Name="Valor3TextBox" Grid.Row="3" Grid.Column="2" Margin="0,0,0,6"/>

                        <ComboBox x:Name="Campo4ComboBox" Grid.Row="4" Grid.Column="0" DisplayMemberPath="Texto" Margin="0,0,12,6"/>
                        <ComboBox x:Name="Operador4ComboBox" Grid.Row="4" Grid.Column="1" DisplayMemberPath="Texto" Margin="0,0,12,6"/>
                        <TextBox x:Name="Valor4TextBox" Grid.Row="4" Grid.Column="2" Margin="0,0,0,6"/>

                        <ComboBox x:Name="Campo5ComboBox" Grid.Row="5" Grid.Column="0" DisplayMemberPath="Texto" Margin="0,0,12,0"/>
                        <ComboBox x:Name="Operador5ComboBox" Grid.Row="5" Grid.Column="1" DisplayMemberPath="Texto" Margin="0,0,12,0"/>
                        <TextBox x:Name="Valor5TextBox" Grid.Row="5" Grid.Column="2"/>
                    </Grid>
                </Border>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
