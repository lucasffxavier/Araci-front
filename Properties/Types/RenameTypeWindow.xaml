<Window x:Class="Araci.Properties.Types.RenameTypeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Renomear Tipo"
        Width="420"
        Height="190"
        Background="#252526"
        Foreground="#F4F4F4"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Border Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Renomear tipo" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Nome atual" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding NomeAtual, Mode=OneWay}" IsReadOnly="True" Height="24" Padding="4,2" Margin="0,0,0,8" Background="#D0D0D0" Foreground="#1E1E1E"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Novo nome" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="NovoNomeTextBox" Grid.Row="1" Grid.Column="1" Text="{Binding NovoNome, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="24" Padding="4,2"/>
            </Grid>

            <TextBlock Grid.Row="2" Text="{Binding MensagemErro}" Foreground="#FF6B6B" Margin="92,8,0,0" TextWrapping="Wrap"/>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" Width="86" Height="26" Margin="0,0,8,0" Click="OnCancelarClick"/>
                <Button Content="OK" Width="86" Height="26" IsDefault="True" Click="OnOkClick"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
