<UserControl x:Class="Araci.Properties.Types.TipoLinhaAnotativaPropertiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<StackPanel>
		<TextBlock Text="PROPRIEDADES DE TIPO" Style="{StaticResource PropertyHeaderTextBlockStyle}"/>
		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="150"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<TextBlock Grid.Row="0" Text="Nome do tipo" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
			<TextBox Grid.Row="0" Grid.Column="1" Text="{Binding NomeTipo, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Style="{StaticResource PropertyValueTextBoxStyle}"/>

			<TextBlock Grid.Row="1" Text="Família" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
			<TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Familia}" Style="{StaticResource PropertyReadOnlyTextBoxStyle}"/>

			<TextBlock Grid.Row="2" Text="Categoria" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
			<TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Categoria}" Style="{StaticResource PropertyReadOnlyTextBoxStyle}"/>

			<TextBlock Grid.Row="3" Text="Estilo da linha" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
			<ComboBox Grid.Row="3" Grid.Column="1" ItemsSource="{Binding EstilosLinhaDisponiveis}" SelectedItem="{Binding EstiloLinha, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
		</Grid>
	</StackPanel>
</UserControl>