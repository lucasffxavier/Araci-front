<UserControl x:Class="Araci.Properties.Types.TipoLinhaAnotativaPropertiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<StackPanel>
		<TextBlock Text="PROPRIEDADES DE TIPO" Style="{StaticResource PropertyHeaderTextBlockStyle}"/>
		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="150"/>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="32"/>
			</Grid.ColumnDefinitions>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<TextBlock Grid.Row="0" Text="Nome do tipo" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
			<TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding NomeTipo, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Style="{StaticResource PropertyValueTextBoxStyle}"/>

			<TextBlock Grid.Row="1" Text="Família" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
			<TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding Familia}" Style="{StaticResource PropertyReadOnlyTextBoxStyle}"/>

			<TextBlock Grid.Row="2" Text="Categoria" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
			<TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding Categoria}" Style="{StaticResource PropertyReadOnlyTextBoxStyle}"/>

			<TextBlock Grid.Row="3" Text="Estilo da linha" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
			<ComboBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" ItemsSource="{Binding EstilosLinhaDisponiveis}" SelectedItem="{Binding EstiloLinha, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

			<TextBlock Grid.Row="4" Text="Cor da linha" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
			<TextBox Grid.Row="4" Grid.Column="1" Text="{Binding CorLinha, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Style="{StaticResource PropertyValueTextBoxStyle}"/>
			<Button Grid.Row="4" Grid.Column="2" Content="..." Command="{Binding EscolherCorCommand}" Margin="4,2,0,2"/>

			<TextBlock Grid.Row="5" Text="Espessura da linha" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
			<TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding EspessuraLinha, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Style="{StaticResource PropertyValueTextBoxStyle}"/>
		</Grid>
	</StackPanel>
</UserControl>