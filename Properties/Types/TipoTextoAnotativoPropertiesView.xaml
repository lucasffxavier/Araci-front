<UserControl x:Class="Araci.Properties.Types.TipoTextoAnotativoPropertiesView"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="PROPRIEDADES DE TIPO" Style="{StaticResource PropertyHeaderTextBlockStyle}"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="72"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Tipo" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
            <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding TiposDisponiveis}" SelectedItem="{Binding TipoSelecionado, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" DisplayMemberPath="NomeTipo" Height="24" Padding="4,2" Margin="0,0,8,12"/>
            <Button Grid.Row="0" Grid.Column="2" Content="Novo" Command="{Binding NovoTipoCommand}" Height="24" Margin="0,0,0,12"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Nome do tipo" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
            <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding NomeTipo, UpdateSourceTrigger=PropertyChanged}" Height="24" Padding="4,2" Margin="0,0,0,12"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Família" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
            <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding Familia}" Style="{StaticResource PropertyReadOnlyTextBoxStyle}"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Categoria" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
            <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding Categoria}" Style="{StaticResource PropertyReadOnlyTextBoxStyle}"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Cor do texto" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
            <Button Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" HorizontalAlignment="Stretch" Height="24" Padding="0" BorderBrush="#A0A0A0" BorderThickness="1" Command="{Binding EscolherCorCommand}" Margin="0,2,0,10">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{Binding CorTextoBrush}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"/>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Fonte" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
            <ComboBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" ItemsSource="{Binding FontesDisponiveis}" SelectedItem="{Binding Fonte, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="24" Padding="4,2" Margin="0,0,0,12"/>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="Altura do texto" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
            <TextBox Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding AlturaTexto, UpdateSourceTrigger=PropertyChanged}" Height="24" Padding="4,2" Margin="0,0,0,12"/>

            <TextBlock Grid.Row="7" Grid.Column="0" Text="Alinhamento" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
            <ComboBox Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2" ItemsSource="{Binding AlinhamentosDisponiveis}" SelectedItem="{Binding AlinhamentoHorizontal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="24" Padding="4,2" Margin="0,0,0,12"/>
        </Grid>
    </StackPanel>
</UserControl>
