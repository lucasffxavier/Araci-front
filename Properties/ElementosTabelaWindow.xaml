<Window x:Class="Araci.Properties.ElementosTabelaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Elementos da tabela"
        Width="920"
        SizeToContent="Height"
        ResizeMode="NoResize"
        Background="#252526"
        WindowStartupLocation="CenterOwner">
    <Border Margin="10"
            Padding="16"
            BorderBrush="#F4F4F4"
            BorderThickness="1"
            Background="#252526">
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Content="OK"
                        Width="90"
                        Height="30"
                        Margin="0,0,8,0"
                        IsDefault="True"
                        Click="OkButton_Click"/>
                <Button Content="Cancelar"
                        Width="90"
                        Height="30"
                        IsCancel="True"
                        Click="CancelButton_Click"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Elementos da tabela"
                           Foreground="#F4F4F4"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           Margin="0,0,0,16"/>
                <TextBlock Text="Selecione categorias e escolha os campos que serão usados futuramente como colunas da tabela."
                           Foreground="#DCDCDC"
                           TextWrapping="Wrap"
                           Margin="0,0,0,14"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="190"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            BorderBrush="#3A3A3A"
                            BorderThickness="1"
                            Padding="10"
                            Background="#1E1E1E">
                        <StackPanel>
                            <TextBlock Text="Categorias"
                                       Foreground="#F4F4F4"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>
                            <CheckBox x:Name="BarrasCheckBox" Content="Barras" Checked="OnCategoriaChanged" Unchecked="OnCategoriaChanged" Foreground="#DCDCDC" Margin="0,0,0,6"/>
                            <CheckBox x:Name="CabosCheckBox" Content="Cabos" Checked="OnCategoriaChanged" Unchecked="OnCategoriaChanged" Foreground="#DCDCDC" Margin="0,0,0,6"/>
                            <CheckBox x:Name="CargasCheckBox" Content="Cargas" Checked="OnCategoriaChanged" Unchecked="OnCategoriaChanged" Foreground="#DCDCDC" Margin="0,0,0,6"/>
                            <CheckBox x:Name="GeradoresCheckBox" Content="Geradores" Checked="OnCategoriaChanged" Unchecked="OnCategoriaChanged" Foreground="#DCDCDC" Margin="0,0,0,6"/>
                            <CheckBox x:Name="TransformadoresCheckBox" Content="Transformadores" Checked="OnCategoriaChanged" Unchecked="OnCategoriaChanged" Foreground="#DCDCDC" Margin="0,0,0,6"/>
                            <CheckBox x:Name="SinCheckBox" Content="SIN" Checked="OnCategoriaChanged" Unchecked="OnCategoriaChanged" Foreground="#DCDCDC"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            BorderBrush="#3A3A3A"
                            BorderThickness="1"
                            Padding="10"
                            Background="#1E1E1E">
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Top"
                                       Text="Campos disponíveis"
                                       Foreground="#F4F4F4"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>
                            <ListBox x:Name="CamposDisponiveisListBox"
                                     DisplayMemberPath="Texto"
                                     SelectionMode="Extended"
                                     Height="280"/>
                        </DockPanel>
                    </Border>

                    <StackPanel Grid.Column="3"
                                VerticalAlignment="Center"
                                Margin="10,0">
                        <Button Content="Adicionar &gt;"
                                Height="28"
                                Margin="0,0,0,8"
                                Click="AdicionarCampo_Click"/>
                        <Button Content="&lt; Remover"
                                Height="28"
                                Margin="0,0,0,20"
                                Click="RemoverCampo_Click"/>
                        <Button Content="Subir"
                                Height="28"
                                Margin="0,0,0,8"
                                Click="SubirCampo_Click"/>
                        <Button Content="Descer"
                                Height="28"
                                Click="DescerCampo_Click"/>
                    </StackPanel>

                    <Border Grid.Column="4"
                            BorderBrush="#3A3A3A"
                            BorderThickness="1"
                            Padding="10"
                            Background="#1E1E1E">
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Top"
                                       Text="Campos selecionados"
                                       Foreground="#F4F4F4"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>
                            <ListBox x:Name="CamposSelecionadosListBox"
                                     DisplayMemberPath="Texto"
                                     SelectionMode="Extended"
                                     Height="280"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
