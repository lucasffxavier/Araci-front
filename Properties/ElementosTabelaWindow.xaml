<Window x:Class="Araci.Properties.ElementosTabelaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Elementos da tabela"
        Width="460"
        SizeToContent="Height"
        ResizeMode="NoResize"
        Background="#252526"
        WindowStartupLocation="CenterOwner">
    <Border Margin="10"
            Padding="16"
            BorderBrush="#F4F4F4"
            BorderThickness="1"
            Background="#252526">
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Content="OK"
                        Width="90"
                        Height="30"
                        Margin="0,0,8,0"
                        IsDefault="True"
                        Click="OkButton_Click"/>
                <Button Content="Cancelar"
                        Width="90"
                        Height="30"
                        IsCancel="True"
                        Click="CancelButton_Click"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Elementos da tabela"
                           Foreground="#F4F4F4"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           Margin="0,0,0,16"/>
                <TextBlock Text="Selecione quais tipos de elementos poderão compor esta tabela."
                           Foreground="#DCDCDC"
                           TextWrapping="Wrap"
                           Margin="0,0,0,4"/>
                <TextBlock Text="A configuração completa será implementada em uma etapa futura."
                           Foreground="#DCDCDC"
                           TextWrapping="Wrap"
                           Margin="0,0,0,14"/>

                <StackPanel>
                    <CheckBox Content="Barras" IsEnabled="False" Foreground="#DCDCDC" Margin="0,0,0,6"/>
                    <CheckBox Content="Cabos" IsEnabled="False" Foreground="#DCDCDC" Margin="0,0,0,6"/>
                    <CheckBox Content="Cargas" IsEnabled="False" Foreground="#DCDCDC" Margin="0,0,0,6"/>
                    <CheckBox Content="Geradores" IsEnabled="False" Foreground="#DCDCDC" Margin="0,0,0,6"/>
                    <CheckBox Content="Transformadores" IsEnabled="False" Foreground="#DCDCDC" Margin="0,0,0,6"/>
                    <CheckBox Content="SIN" IsEnabled="False" Foreground="#DCDCDC"/>
                </StackPanel>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
