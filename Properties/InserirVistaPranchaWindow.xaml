<Window x:Class="Araci.Properties.InserirVistaPranchaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inserir vista na prancha"
        Width="520"
        Height="300"
        ResizeMode="NoResize"
        Background="#252526"
        WindowStartupLocation="CenterOwner">
    <Border Margin="10"
            Padding="16"
            BorderBrush="#F4F4F4"
            BorderThickness="1"
            Background="#252526">
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Content="OK"
                        Width="90"
                        Height="30"
                        Margin="0,0,8,0"
                        IsDefault="True"
                        Click="OkButton_Click"/>
                <Button Content="Cancelar"
                        Width="90"
                        Height="30"
                        IsCancel="True"
                        Click="CancelButton_Click"/>
            </StackPanel>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Inserir vista na prancha"
                           Foreground="#F4F4F4"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           Margin="0,0,0,16"/>

                <StackPanel Grid.Row="1"
                            Margin="0,0,0,14">
                    <TextBlock Text="Prancha"
                               Foreground="#F4F4F4"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <ComboBox x:Name="PranchaComboBox"
                              DisplayMemberPath="Nome"
                              MinHeight="26"/>
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Margin="0,0,0,14">
                    <TextBlock Text="Vista"
                               Foreground="#F4F4F4"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <ComboBox x:Name="VistaComboBox"
                              DisplayMemberPath="Nome"
                              MinHeight="26"/>
                </StackPanel>

                <TextBlock Grid.Row="3"
                           Text="A instância será criada na prancha usando a proporção da região de recorte da vista selecionada."
                           Foreground="#DCDCDC"
                           FontSize="12"
                           TextWrapping="Wrap"
                           VerticalAlignment="Top"/>
            </Grid>
        </DockPanel>
    </Border>
</Window>