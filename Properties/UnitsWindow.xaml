<Window x:Class="Araci.Properties.UnitsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Unidades"
        Width="520"
        MinHeight="430"
        SizeToContent="Height"
        ResizeMode="NoResize"
        Background="#252526"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="UnitLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,12,10"/>
        </Style>
        <Style x:Key="UnitComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Height" Value="26"/>
        </Style>
    </Window.Resources>
    <Border Margin="10"
            Padding="16"
            BorderBrush="#F4F4F4"
            BorderThickness="1"
            Background="#252526">
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Content="OK"
                        Width="90"
                        Height="30"
                        Margin="0,0,8,0"
                        IsDefault="True"
                        Click="OkButton_Click"/>
                <Button Content="Cancelar"
                        Width="90"
                        Height="30"
                        IsCancel="True"
                        Click="CancelButton_Click"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Unidades"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           Margin="0,0,0,18"/>
                <TextBlock Text="Unidades do projeto"
                           Foreground="#F4F4F4"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="190"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Comprimento" Style="{StaticResource UnitLabelStyle}"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" Style="{StaticResource UnitComboBoxStyle}" ItemsSource="{Binding LengthOptions}" SelectedValue="{Binding Length}" SelectedValuePath="Unit" DisplayMemberPath="Text"/>

                    <TextBlock Grid.Row="1" Text="Tensão" Style="{StaticResource UnitLabelStyle}"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" Style="{StaticResource UnitComboBoxStyle}" ItemsSource="{Binding VoltageOptions}" SelectedValue="{Binding Voltage}" SelectedValuePath="Unit" DisplayMemberPath="Text"/>

                    <TextBlock Grid.Row="2" Text="Corrente" Style="{StaticResource UnitLabelStyle}"/>
                    <ComboBox Grid.Row="2" Grid.Column="1" Style="{StaticResource UnitComboBoxStyle}" ItemsSource="{Binding CurrentOptions}" SelectedValue="{Binding Current}" SelectedValuePath="Unit" DisplayMemberPath="Text"/>

                    <TextBlock Grid.Row="3" Text="Potência ativa" Style="{StaticResource UnitLabelStyle}"/>
                    <ComboBox Grid.Row="3" Grid.Column="1" Style="{StaticResource UnitComboBoxStyle}" ItemsSource="{Binding ActivePowerOptions}" SelectedValue="{Binding ActivePower}" SelectedValuePath="Unit" DisplayMemberPath="Text"/>

                    <TextBlock Grid.Row="4" Text="Potência reativa" Style="{StaticResource UnitLabelStyle}"/>
                    <ComboBox Grid.Row="4" Grid.Column="1" Style="{StaticResource UnitComboBoxStyle}" ItemsSource="{Binding ReactivePowerOptions}" SelectedValue="{Binding ReactivePower}" SelectedValuePath="Unit" DisplayMemberPath="Text"/>

                    <TextBlock Grid.Row="5" Text="Potência aparente" Style="{StaticResource UnitLabelStyle}"/>
                    <ComboBox Grid.Row="5" Grid.Column="1" Style="{StaticResource UnitComboBoxStyle}" ItemsSource="{Binding ApparentPowerOptions}" SelectedValue="{Binding ApparentPower}" SelectedValuePath="Unit" DisplayMemberPath="Text"/>

                    <TextBlock Grid.Row="6" Text="Percentual" Style="{StaticResource UnitLabelStyle}"/>
                    <ComboBox Grid.Row="6" Grid.Column="1" Style="{StaticResource UnitComboBoxStyle}" ItemsSource="{Binding PercentOptions}" SelectedValue="{Binding Percent}" SelectedValuePath="Unit" DisplayMemberPath="Text"/>
                </Grid>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
