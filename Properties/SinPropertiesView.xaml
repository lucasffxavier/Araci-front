<UserControl x:Class="Araci.Properties.SinPropertiesView"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#252526">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="12">
                <TextBlock Text="SIN"
                           TextAlignment="Center"
                           HorizontalAlignment="Stretch"
                           Style="{StaticResource PropertyHeaderTextBlockStyle}"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ComboBox Grid.ColumnSpan="2"
Style="{StaticResource PropertyFullComboBoxStyle}"
ItemsSource="{Binding TiposDisponiveis}"
SelectedItem="{Binding Tipo}"
DisplayMemberPath="NomeTipo"/>
                    <Button Grid.Row="1"
Grid.ColumnSpan="2"
Style="{StaticResource PropertyFullButtonStyle}"
Content="Visualizar propriedades de tipo"
Command="{Binding AbrirPropriedadesTipoCommand}"/>
                    <TextBlock Grid.Row="2" Text="Nome" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Nome, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource PropertyValueTextBoxStyle}"/>
                    <TextBlock Grid.Row="3" Text="Tensão linha (kV)" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding TensaoLinha, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource PropertyValueTextBoxStyle}"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>