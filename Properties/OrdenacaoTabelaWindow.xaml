<Window x:Class="Araci.Properties.OrdenacaoTabelaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ordenação da Tabela"
        Width="660"
        SizeToContent="Height"
        ResizeMode="NoResize"
        Background="#252526"
        WindowStartupLocation="CenterOwner">
    <Border Margin="10"
            Padding="16"
            BorderBrush="#F4F4F4"
            BorderThickness="1"
            Background="#252526">
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Content="OK"
                        Width="90"
                        Height="30"
                        Margin="0,0,8,0"
                        IsDefault="True"
                        Click="OkButton_Click"/>
                <Button Content="Cancelar"
                        Width="90"
                        Height="30"
                        IsCancel="True"
                        Click="CancelButton_Click"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Ordenação da Tabela"
                           Foreground="#F4F4F4"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           Margin="0,0,0,16"/>
                <TextBlock Text="Configure até cinco campos selecionados da tabela para definir a futura sequência das linhas."
                           Foreground="#DCDCDC"
                           TextWrapping="Wrap"
                           Margin="0,0,0,14"/>

                <Border BorderBrush="#3A3A3A"
                        BorderThickness="1"
                        Padding="10"
                        Background="#1E1E1E">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Ordenar por" Foreground="#F4F4F4" FontWeight="SemiBold" Margin="0,0,12,8"/>
                        <ComboBox x:Name="Campo0ComboBox" Grid.Row="0" Grid.Column="1" DisplayMemberPath="Texto" Margin="0,0,8,8" SelectionChanged="CampoComboBox_SelectionChanged"/>
                        <ComboBox x:Name="Direcao0ComboBox" Grid.Row="0" Grid.Column="2" DisplayMemberPath="Texto" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Depois por" Foreground="#F4F4F4" FontWeight="SemiBold" Margin="0,0,12,8"/>
                        <ComboBox x:Name="Campo1ComboBox" Grid.Row="1" Grid.Column="1" DisplayMemberPath="Texto" Margin="0,0,8,8" SelectionChanged="CampoComboBox_SelectionChanged"/>
                        <ComboBox x:Name="Direcao1ComboBox" Grid.Row="1" Grid.Column="2" DisplayMemberPath="Texto" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Depois por" Foreground="#F4F4F4" FontWeight="SemiBold" Margin="0,0,12,8"/>
                        <ComboBox x:Name="Campo2ComboBox" Grid.Row="2" Grid.Column="1" DisplayMemberPath="Texto" Margin="0,0,8,8" SelectionChanged="CampoComboBox_SelectionChanged"/>
                        <ComboBox x:Name="Direcao2ComboBox" Grid.Row="2" Grid.Column="2" DisplayMemberPath="Texto" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Depois por" Foreground="#F4F4F4" FontWeight="SemiBold" Margin="0,0,12,8"/>
                        <ComboBox x:Name="Campo3ComboBox" Grid.Row="3" Grid.Column="1" DisplayMemberPath="Texto" Margin="0,0,8,8" SelectionChanged="CampoComboBox_SelectionChanged"/>
                        <ComboBox x:Name="Direcao3ComboBox" Grid.Row="3" Grid.Column="2" DisplayMemberPath="Texto" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Depois por" Foreground="#F4F4F4" FontWeight="SemiBold" Margin="0,0,12,0"/>
                        <ComboBox x:Name="Campo4ComboBox" Grid.Row="4" Grid.Column="1" DisplayMemberPath="Texto" Margin="0,0,8,0" SelectionChanged="CampoComboBox_SelectionChanged"/>
                        <ComboBox x:Name="Direcao4ComboBox" Grid.Row="4" Grid.Column="2" DisplayMemberPath="Texto"/>
                    </Grid>
                </Border>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
