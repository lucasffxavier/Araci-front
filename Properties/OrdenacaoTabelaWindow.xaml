<Window x:Class="Araci.Properties.OrdenacaoTabelaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ordenação da tabela"
        Width="560"
        SizeToContent="Height"
        ResizeMode="NoResize"
        Background="#252526"
        WindowStartupLocation="CenterOwner">
    <Border Margin="10"
            Padding="16"
            BorderBrush="#F4F4F4"
            BorderThickness="1"
            Background="#252526">
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Content="OK"
                        Width="90"
                        Height="30"
                        Margin="0,0,8,0"
                        IsDefault="True"
                        Click="OkButton_Click"/>
                <Button Content="Cancelar"
                        Width="90"
                        Height="30"
                        IsCancel="True"
                        Click="CancelButton_Click"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Ordenação da tabela"
                           Foreground="#F4F4F4"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           Margin="0,0,0,16"/>
                <TextBlock Text="A ordenação permitirá definir a sequência das linhas da tabela. A configuração completa será implementada em uma etapa futura."
                           Foreground="#DCDCDC"
                           TextWrapping="Wrap"
                           Margin="0,0,0,14"/>

                <Border BorderBrush="#3A3A3A"
                        BorderThickness="1"
                        Padding="10"
                        Background="#1E1E1E">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Campo" Foreground="#F4F4F4" FontWeight="SemiBold" Margin="0,0,12,8"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Direção" Foreground="#F4F4F4" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Nome" Foreground="#DCDCDC" Margin="0,0,12,6"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="Crescente" Foreground="#DCDCDC" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Potência ativa" Foreground="#DCDCDC" Margin="0,0,12,6"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="Decrescente" Foreground="#DCDCDC" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Tensão" Foreground="#DCDCDC" Margin="0,0,12,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="Crescente" Foreground="#DCDCDC"/>
                    </Grid>
                </Border>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
