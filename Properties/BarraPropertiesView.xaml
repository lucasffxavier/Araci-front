<UserControl x:Class="Araci.Properties.BarraPropertiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:props="clr-namespace:Araci.Properties">
    <UserControl.Resources>
        <props:UnitValueConverter x:Key="UnitValueConverter"/>
    </UserControl.Resources>
    <Grid Style="{StaticResource PropertyRootGridStyle}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Style="{StaticResource PropertyPanelStackStyle}">
                <TextBlock Text="BARRA" Style="{StaticResource PropertyHeaderTextBlockStyle}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.ColumnSpan="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="32"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Tipo" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                        <ComboBox Style="{StaticResource PropertyInlineTypeComboBoxStyle}" ItemsSource="{Binding TiposDisponiveis}" SelectedItem="{Binding Tipo}" DisplayMemberPath="NomeTipo"/>
                        <Button Style="{StaticResource PropertyInlineTypeButtonStyle}" Command="{Binding AbrirPropriedadesTipoCommand}"/>
                    </Grid>
                    <TextBlock Grid.Row="2" Text="Nome" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Nome}" Style="{StaticResource PropertyReadOnlyTextBoxStyle}"/>
                    <TextBlock Grid.Row="3" Text="Tensão" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Tensao, Mode=TwoWay, UpdateSourceTrigger=LostFocus, Converter={StaticResource UnitValueConverter}, ConverterParameter=VoltageKV}" Style="{StaticResource PropertyNumericTextBoxStyle}"/>
                    <TextBlock Grid.Row="4" Text="Altura" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Altura, Mode=TwoWay, UpdateSourceTrigger=LostFocus, Converter={StaticResource UnitValueConverter}, ConverterParameter=LengthMeter, ValidatesOnDataErrors=True, ValidatesOnExceptions=True, NotifyOnValidationError=True}" Style="{StaticResource PropertyNumericTextBoxStyle}"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
