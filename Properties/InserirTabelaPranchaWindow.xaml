<Window x:Class="Araci.Properties.InserirTabelaPranchaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inserir tabela na prancha"
        Width="720"
        Height="520"
        ResizeMode="NoResize"
        Background="#252526"
        WindowStartupLocation="CenterOwner">
    <Border Margin="10"
            Padding="16"
            BorderBrush="#F4F4F4"
            BorderThickness="1"
            Background="#252526">
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Content="OK"
                        Width="90"
                        Height="30"
                        Margin="0,0,8,0"
                        IsDefault="True"
                        Click="OkButton_Click"/>
                <Button Content="Cancelar"
                        Width="90"
                        Height="30"
                        IsCancel="True"
                        Click="CancelButton_Click"/>
            </StackPanel>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Inserir tabela na prancha"
                           Foreground="#F4F4F4"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           Margin="0,0,0,16"/>

                <StackPanel Grid.Row="1"
                            Margin="0,0,0,14">
                    <TextBlock Text="Prancha"
                               Foreground="#F4F4F4"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <ComboBox x:Name="PranchaComboBox"
                              DisplayMemberPath="Nome"/>
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="132"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Tabelas disponiveis"
                               Foreground="#F4F4F4"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <ListBox x:Name="TabelasDisponiveisListBox"
                             Grid.Row="1"
                             Grid.Column="0"
                             DisplayMemberPath="Nome"
                             SelectionMode="Extended"/>

                    <StackPanel Grid.Row="1"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Margin="12,0">
                        <Button Content="Adicionar"
                                Height="30"
                                Margin="0,0,0,8"
                                Click="AdicionarButton_Click"/>
                        <Button Content="Remover"
                                Height="30"
                                Margin="0,0,0,8"
                                Click="RemoverButton_Click"/>
                        <Button Content="Adicionar todas"
                                Height="30"
                                Margin="0,0,0,8"
                                Click="AdicionarTodasButton_Click"/>
                        <Button Content="Remover todas"
                                Height="30"
                                Click="RemoverTodasButton_Click"/>
                    </StackPanel>

                    <TextBlock Grid.Column="2"
                               Text="Tabelas para inserir"
                               Foreground="#F4F4F4"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <ListBox x:Name="TabelasSelecionadasListBox"
                             Grid.Row="1"
                             Grid.Column="2"
                             DisplayMemberPath="Nome"
                             SelectionMode="Extended"/>
                </Grid>
            </Grid>
        </DockPanel>
    </Border>
</Window>
