<Window x:Class="Araci.Properties.InserirTabelaPranchaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inserir tabela na prancha"
        Width="420"
        SizeToContent="Height"
        ResizeMode="NoResize"
        Background="#252526"
        WindowStartupLocation="CenterOwner">
    <Border Margin="10"
            Padding="16"
            BorderBrush="#F4F4F4"
            BorderThickness="1"
            Background="#252526">
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Content="OK"
                        Width="90"
                        Height="30"
                        Margin="0,0,8,0"
                        IsDefault="True"
                        Click="OkButton_Click"/>
                <Button Content="Cancelar"
                        Width="90"
                        Height="30"
                        IsCancel="True"
                        Click="CancelButton_Click"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Inserir tabela na prancha"
                           Foreground="#F4F4F4"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           Margin="0,0,0,16"/>

                <TextBlock Text="Prancha"
                           Foreground="#F4F4F4"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"/>
                <ComboBox x:Name="PranchaComboBox"
                          DisplayMemberPath="Nome"
                          Margin="0,0,0,12"/>

                <TextBlock Text="Tabela"
                           Foreground="#F4F4F4"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"/>
                <ComboBox x:Name="TabelaComboBox"
                          DisplayMemberPath="Nome"/>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
