<UserControl x:Class="Araci.Properties.TransformadorPropertiesView"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#252526">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="12">
                <TextBlock Text="TRANSFORMADOR"
                           TextAlignment="Center"
                           HorizontalAlignment="Stretch"
                           Style="{StaticResource PropertyHeaderTextBlockStyle}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ComboBox Grid.ColumnSpan="2"
Style="{StaticResource PropertyFullComboBoxStyle}"
ItemsSource="{Binding TiposDisponiveis}"
SelectedItem="{Binding Tipo}"
DisplayMemberPath="NomeTipo"/>
                    <Button Grid.Row="1"
Grid.ColumnSpan="2"
Style="{StaticResource PropertyFullButtonStyle}"
Content="Visualizar propriedades de tipo"
Command="{Binding AbrirPropriedadesTipoCommand}"/>
                    <TextBlock Grid.Row="2" Text="Nome" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Nome}" Style="{StaticResource PropertyValueTextBoxStyle}"/>
                    <TextBlock Grid.Row="3" Text="Barra" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Barra}" Style="{StaticResource PropertyValueTextBoxStyle}"/>
                    <TextBlock Grid.Row="4" Text="Alimentador" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Alimentador, ValidatesOnDataErrors=True, ValidatesOnExceptions=True, NotifyOnValidationError=True}" Style="{StaticResource PropertyNumericTextBoxStyle}"/>
                    <TextBlock Grid.Row="5" Text="Fases" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Fases, ValidatesOnDataErrors=True, ValidatesOnExceptions=True, NotifyOnValidationError=True}" Style="{StaticResource PropertyNumericTextBoxStyle}"/>
                    <TextBlock Grid.Row="6" Text="Enrolamentos" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                    <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Enrolamentos, ValidatesOnDataErrors=True, ValidatesOnExceptions=True, NotifyOnValidationError=True}" Style="{StaticResource PropertyNumericTextBoxStyle}"/>
                    <TextBlock Grid.Row="7" Text="Tensão primário (kV)" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                    <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding TensaoPrimarioKV, ValidatesOnDataErrors=True, ValidatesOnExceptions=True, NotifyOnValidationError=True}" Style="{StaticResource PropertyNumericTextBoxStyle}"/>
                    <TextBlock Grid.Row="8" Text="Tensão secundário (kV)" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                    <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding TensaoSecundarioKV, ValidatesOnDataErrors=True, ValidatesOnExceptions=True, NotifyOnValidationError=True}" Style="{StaticResource PropertyNumericTextBoxStyle}"/>
                    <TextBlock Grid.Row="9" Text="Potência aparente (kVA)" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                    <TextBox Grid.Row="9" Grid.Column="1" Text="{Binding PotenciaAparente, ValidatesOnDataErrors=True, ValidatesOnExceptions=True, NotifyOnValidationError=True}" Style="{StaticResource PropertyNumericTextBoxStyle}"/>
                    <TextBlock Grid.Row="10" Text="R (%)" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                    <TextBox Grid.Row="10" Grid.Column="1" Text="{Binding RPercentual, ValidatesOnDataErrors=True, ValidatesOnExceptions=True, NotifyOnValidationError=True}" Style="{StaticResource PropertyNumericTextBoxStyle}"/>
                    <TextBlock Grid.Row="11" Text="X (%)" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                    <TextBox Grid.Row="11" Grid.Column="1" Text="{Binding XPercentual, ValidatesOnDataErrors=True, ValidatesOnExceptions=True, NotifyOnValidationError=True}" Style="{StaticResource PropertyNumericTextBoxStyle}"/>
                    <TextBlock Grid.Row="12" Text="Ligação primário" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                    <TextBox Grid.Row="12" Grid.Column="1" Text="{Binding LigacaoPrimario}" Style="{StaticResource PropertyValueTextBoxStyle}"/>
                    <TextBlock Grid.Row="13" Text="Ligação secundário" Style="{StaticResource PropertyLabelTextBlockStyle}"/>
                    <TextBox Grid.Row="13" Grid.Column="1" Text="{Binding LigacaoSecundario}" Style="{StaticResource PropertyValueTextBoxStyle}"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>