<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="PropertyHeaderTextBlockStyle"
           TargetType="TextBlock">
        <Setter Property="FontSize"
                Value="18"/>
        <Setter Property="FontWeight"
                Value="SemiBold"/>
        <Setter Property="Foreground"
                Value="White"/>
        <Setter Property="Margin"
                Value="0,0,0,20"/>
    </Style>

    <Style x:Key="PropertyLabelTextBlockStyle"
           TargetType="TextBlock">
        <Setter Property="Foreground"
                Value="#CCCCCC"/>
        <Setter Property="VerticalAlignment"
                Value="Center"/>
        <Setter Property="Margin"
                Value="0,0,10,12"/>
    </Style>

    <Style x:Key="PropertyValueTextBoxStyle"
           TargetType="TextBox">
        <Setter Property="Grid.Column"
                Value="1"/>
        <Setter Property="Margin"
                Value="0,0,0,12"/>
        <Setter Property="Validation.ErrorTemplate">
            <Setter.Value>
                <ControlTemplate>
                    <DockPanel LastChildFill="True">
                        <Border BorderBrush="#E05A47"
                                BorderThickness="1"
                                CornerRadius="2">
                            <AdornedElementPlaceholder/>
                        </Border>
                    </DockPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Validation.HasError"
                     Value="True">
                <Setter Property="ToolTip"
                        Value="{Binding RelativeSource={RelativeSource Self},
                                        Path=(Validation.Errors)[0].ErrorContent}"/>
                <Setter Property="BorderBrush"
                        Value="#E05A47"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PropertyNumericTextBoxStyle"
           TargetType="TextBox"
           BasedOn="{StaticResource PropertyValueTextBoxStyle}"/>

    <Style x:Key="PropertyReadOnlyTextBoxStyle"
           TargetType="TextBox"
           BasedOn="{StaticResource PropertyValueTextBoxStyle}">
        <Setter Property="IsReadOnly"
                Value="True"/>
    </Style>

    <Style x:Key="PropertyFullComboBoxStyle"
           TargetType="ComboBox">
        <Setter Property="Grid.ColumnSpan"
                Value="2"/>
        <Setter Property="Margin"
                Value="0,0,0,12"/>
    </Style>

    <Style x:Key="PropertyFullButtonStyle"
           TargetType="Button">
        <Setter Property="Grid.ColumnSpan"
                Value="2"/>
        <Setter Property="Height"
                Value="32"/>
        <Setter Property="Margin"
                Value="0,0,0,20"/>
    </Style>

</ResourceDictionary>
